# ========== 目标设备 ==========
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_qualcommax_ipq60xx_DEVICE_qihoo_360v6=y
# 128MB 闪存优化：最小化固件大小
CONFIG_TARGET_ROOTFS_PARTSIZE=20  # 最小 overlay 分区
CONFIG_TARGET_ROOTFS_SQUASHFS=y

# ========== 编译优化 ==========
CONFIG_CCACHE=y
CONFIG_SSTRIP=y

# ========== LuCI 基础（极致精简）==========
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
# CONFIG_PACKAGE_luci-ssl is not set  # 移除 SSL，节省 ~2MB
# CONFIG_PACKAGE_px5g-wolfssl is not set
# CONFIG_PACKAGE_luci-theme-argon is not set  # 移除主题，节省 ~3MB
CONFIG_PACKAGE_luci-theme-bootstrap=y  # 只保留默认主题

# ========== 中文界面 ==========
CONFIG_LUCI_LANG_zh-cn=y
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y

# ========== 无线驱动 ==========
CONFIG_PACKAGE_kmod-ath11k=y
CONFIG_PACKAGE_ath11k-firmware-qcn9074=y

# ========== 强制保留 sing-box ==========
CONFIG_PACKAGE_sing-box=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_luci-app-homeproxy=y
CONFIG_PACKAGE_luci-i18n-homeproxy-zh-cn=y
# 移除可选扩展
# CONFIG_PACKAGE_sing-box-tiny is not set

# ========== 移除所有其他重型应用（安装到USB）==========
# Docker 完全移除
# CONFIG_PACKAGE_docker is not set
# CONFIG_PACKAGE_dockerd is not set
# CONFIG_PACKAGE_docker-compose is not set
# CONFIG_PACKAGE_luci-app-dockerman is not set

# Samba 完全移除
# CONFIG_PACKAGE_samba4-server is not set
# CONFIG_PACKAGE_samba36-server is not set
# CONFIG_PACKAGE_luci-app-samba4 is not set

# AdGuardHome 完全移除
# CONFIG_PACKAGE_adguardhome is not set
# CONFIG_PACKAGE_luci-app-adguardhome is not set

# Lucky 完全移除
# CONFIG_PACKAGE_lucky is not set
# CONFIG_PACKAGE_luci-app-lucky is not set

# Docker 相关内核模块（精简）
CONFIG_PACKAGE_kmod-veth=y  # 保留，sing-box 可能需要
CONFIG_PACKAGE_kmod-br-netfilter=y
CONFIG_PACKAGE_kmod-nf-conntrack=y
CONFIG_PACKAGE_kmod-nf-conntrack6=y
CONFIG_PACKAGE_kmod-nf-nat=y
# 移除不必要的模块
# CONFIG_PACKAGE_kmod-nft-bridge is not set
# CONFIG_PACKAGE_kmod-dummy is not set

# ========== 其他必需包（极致精简）==========
# 保留最小 LuCI 运行时
CONFIG_PACKAGE_luci-lua-runtime=y

# 只保留最必要的应用
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-i18n-autoreboot-zh-cn=y
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_luci-i18n-ddns-zh-cn=y
CONFIG_PACKAGE_luci-app-smartdns=y
CONFIG_PACKAGE_luci-i18n-smartdns-zh-cn=y
CONFIG_PACKAGE_smartdns=y

# 移除以下应用节省空间：
# CONFIG_PACKAGE_luci-app-fileassistant is not set
# CONFIG_PACKAGE_luci-app-wol is not set
# CONFIG_PACKAGE_luci-app-crontabs is not set
# CONFIG_PACKAGE_luci-app-cpufreq is not set
# CONFIG_PACKAGE_luci-app-ttyd is not set
# CONFIG_PACKAGE_luci-app-nlbwmon is not set
# CONFIG_PACKAGE_luci-app-upnp is not set
# CONFIG_PACKAGE_luci-app-ipv6helper is not set

# ========== USB 支持（精简）==========
CONFIG_PACKAGE_kmod-usb-dwc3=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_kmod-fs-ext4=y
# CONFIG_PACKAGE_kmod-fs-ntfs3 is not set
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_automount=y
CONFIG_PACKAGE_luci-app-diskman=y
CONFIG_PACKAGE_luci-i18n-diskman-zh-cn=y

# ========== 网络加速 ==========
CONFIG_PACKAGE_kmod-sfe=y
CONFIG_PACKAGE_kmod-fast-classifier=y
CONFIG_PACKAGE_kmod-tcp-bbr=y

# ========== 系统工具（极致精简）==========
# CONFIG_PACKAGE_htop is not set
# CONFIG_PACKAGE_bash is not set
CONFIG_PACKAGE_busybox=y  # 包含 ash, top 等基础工具
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y
CONFIG_PACKAGE_opkg=y
# CONFIG_PACKAGE_file is not set

# ========== 明确禁用的包 ==========
# CONFIG_PACKAGE_luci-app-passwall is not set
# CONFIG_PACKAGE_luci-app-openclash is not set
# CONFIG_PACKAGE_luci-app-mosdns is not set