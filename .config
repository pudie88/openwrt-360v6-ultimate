# ============================================================
# OpenWrt for 360 V6 — IPQ6000 / qualcommax ipq60xx
# ============================================================

# ========== 目标设备 ==========
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq60xx=y
CONFIG_TARGET_qualcommax_ipq60xx_DEVICE_qihoo_360v6=y
# CONFIG_TARGET_ROOTFS_PARTSIZE is not set
CONFIG_TARGET_ROOTFS_SQUASHFS=y

# ========== 编译优化 ==========
CONFIG_CCACHE=y
CONFIG_SSTRIP=y

# ========== 基础系统 ==========
CONFIG_PACKAGE_netifd=y
CONFIG_PACKAGE_ubus=y
CONFIG_PACKAGE_ubusd=y
CONFIG_PACKAGE_uci=y
CONFIG_PACKAGE_procd=y
CONFIG_PACKAGE_procd-ujail=y

# ========== TLS / HTTPS ==========
CONFIG_PACKAGE_apk-openssl=y
# CONFIG_PACKAGE_apk-mbedtls is not set
CONFIG_PACKAGE_libustream-openssl=y
# CONFIG_PACKAGE_libustream-mbedtls is not set
CONFIG_PACKAGE_libopenssl=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_ca-certificates=y

# ========== LuCI ==========
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-ssl=y
CONFIG_PACKAGE_luci-theme-argon=y
# CONFIG_PACKAGE_luci-theme-bootstrap is not set
CONFIG_LUCI_LANG_zh-cn=y
CONFIG_LUCI_LANG_zh_Hans=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y
CONFIG_PACKAGE_luci-i18n-firewall-zh-cn=y

# ========== 网络基础 ==========
CONFIG_PACKAGE_dnsmasq-full=y
# CONFIG_PACKAGE_dnsmasq is not set
CONFIG_PACKAGE_firewall4=y
CONFIG_PACKAGE_nftables=y
CONFIG_PACKAGE_kmod-nft-offload=y
CONFIG_PACKAGE_kmod-nft-nat=y
CONFIG_PACKAGE_kmod-nft-nat6=y

# ========== 无线驱动 ==========
CONFIG_PACKAGE_kmod-ath11k=y
CONFIG_PACKAGE_ath11k-firmware-ipq60xx=y
# CONFIG_PACKAGE_ath11k-firmware-qcn9074 is not set
CONFIG_PACKAGE_wireless-regdb=y
CONFIG_PACKAGE_iw=y
CONFIG_PACKAGE_iwinfo=y

# ========== USB 支持 ==========
CONFIG_PACKAGE_kmod-usb-dwc3=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_kmod-fs-ntfs3=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_automount=y
CONFIG_PACKAGE_luci-app-diskman=y
CONFIG_PACKAGE_luci-i18n-diskman-zh-cn=y

# ========== 安装脚本依赖（只需这一个！）==========
CONFIG_PACKAGE_e2fsprogs=y          # mkfs.ext4, blkid, tune2fs

# ========== 安装脚本依赖（96-install-extras 需要）==========
CONFIG_PACKAGE_e2fsprogs=y          # mkfs.ext4, blkid, tune2fs（必须）
CONFIG_PACKAGE_bash=y               # 脚本语法
CONFIG_PACKAGE_htop=y               # 进程监控
CONFIG_PACKAGE_smartmontools=y      # 硬盘检测
CONFIG_PACKAGE_fdisk=y              # 分区工具
CONFIG_PACKAGE_lsblk=y              # 列出块设备

# ========== HomeProxy + sing-box ==========
CONFIG_PACKAGE_luci-app-homeproxy=y
CONFIG_PACKAGE_luci-i18n-homeproxy-zh-cn=y
CONFIG_PACKAGE_sing-box=y
# CONFIG_PACKAGE_sing-box-tiny is not set
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_kmod-nft-tproxy=y
CONFIG_PACKAGE_ucode-mod-digest=y

# ========== 终端 ==========
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y

# ========== 基础工具 ==========
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-ssl=y

# ========== 网络唤醒 ==========
CONFIG_PACKAGE_luci-app-wol=y
CONFIG_PACKAGE_luci-i18n-wol-zh-cn=y
CONFIG_PACKAGE_etherwake=y

# ========== 定时重启 ==========
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-i18n-autoreboot-zh-cn=y

# ========== SmartDNS ==========
CONFIG_PACKAGE_luci-app-smartdns=y
CONFIG_PACKAGE_luci-i18n-smartdns-zh-cn=y
CONFIG_PACKAGE_smartdns=y

# ========== DDNS ==========
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_luci-i18n-ddns-zh-cn=y
CONFIG_PACKAGE_ddns-scripts=y
CONFIG_PACKAGE_ddns-scripts-cloudflare=y

# ========== UPnP ==========
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-i18n-upnp-zh-cn=y
CONFIG_PACKAGE_miniupnpd-nftables=y

# ========== 流量监控 ==========
CONFIG_PACKAGE_luci-app-nlbwmon=y
CONFIG_PACKAGE_luci-i18n-nlbwmon-zh-cn=y

# ========== IPv6 ==========
CONFIG_PACKAGE_luci-app-ipv6helper=y
CONFIG_PACKAGE_ipv6helper=y
CONFIG_PACKAGE_odhcp6c=y
CONFIG_PACKAGE_odhcpd-ipv6only=y
# CONFIG_PACKAGE_kmod-ip6tables is not set

# ========== Docker 内核模块（必须内置，二进制运行时安装）==========
# dockerd/dockerman 体积太大不内置，运行时通过 96-install-extras 安装
# CONFIG_PACKAGE_dockerd is not set
# CONFIG_PACKAGE_luci-app-dockerman is not set
# CONFIG_PACKAGE_luci-i18n-dockerman-zh-cn is not set
CONFIG_PACKAGE_kmod-veth=y
CONFIG_PACKAGE_kmod-br-netfilter=y
CONFIG_PACKAGE_kmod-nft-bridge=y
CONFIG_PACKAGE_kmod-dummy=y
CONFIG_PACKAGE_kmod-nf-conntrack=y
CONFIG_PACKAGE_kmod-nf-conntrack6=y
CONFIG_PACKAGE_kmod-nf-nat=y
CONFIG_PACKAGE_kmod-ipt-nat=y
CONFIG_PACKAGE_kmod-ipt-nat6=y
CONFIG_PACKAGE_kmod-ipt-physdev=y
CONFIG_PACKAGE_kmod-nf-ipvs=y
CONFIG_PACKAGE_kmod-nft-compat=y
CONFIG_PACKAGE_kmod-ip6tables=y
CONFIG_PACKAGE_kmod-ipt-extra=y
CONFIG_PACKAGE_kmod-ipt-core=y

# ========== CPU 频率 ==========
CONFIG_PACKAGE_luci-app-cpufreq=y

# ========== BBR ==========
CONFIG_PACKAGE_kmod-tcp-bbr=y

# ========== 硬件随机数 ==========
CONFIG_PACKAGE_kmod-qca-rng=y

# ========== 硬件加速 ==========
# CONFIG_PACKAGE_kmod-sfe is not set
# CONFIG_PACKAGE_kmod-fast-classifier is not set
# CONFIG_PACKAGE_kmod-qca-nss-drv is not set

# ========== 明确禁用 ==========
# CONFIG_PACKAGE_luci-app-passwall is not set
# CONFIG_PACKAGE_luci-app-openclash is not set
# CONFIG_PACKAGE_v2ray-geoip is not set
# CONFIG_PACKAGE_v2ray-geosite is not set
# CONFIG_PACKAGE_xray-core is not set
# CONFIG_PACKAGE_sing-box-tiny is not set
