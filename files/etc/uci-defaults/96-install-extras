[ "${_l1:-0}" -gt "$_ncpu" ] && _warn "负载: $_load（${_ncpu} 核）" || _ok "负载: $_load（${_ncpu} 核）"
_ups=$(awk '{printf "%d",$1}' /proc/uptime 2>/dev/null); [ -n "$_ups" ] && _info "运行: $((_ups/3600))时$((_ups%3600/60))分"
_temp=$(cat /sys/class/thermal/thermal_zone0/temp 2>/dev/null)
[ -n "$_temp" ] && { _tc=$((_temp/1000)); [ "$_temp" -gt 75000 ] && _err "CPU: ${_tc}°C" || { [ "$_temp" -gt 65000 ] && _warn "CPU: ${_tc}°C" || _ok "CPU: ${_tc}°C"; }; }

_title "【USB & 应用】"
if [ -n "$_USB" ]; then
    _udev=$(awk -v mp="$_USB" '$2==mp{print $1; exit}' /proc/mounts 2>/dev/null)
    _ufs=$(awk -v mp="$_USB" '$2==mp{print $3; exit}' /proc/mounts 2>/dev/null)
    _ok "USB: $_USB (${_udev:-?}) fs=${_ufs:-?}"
    _info "容量: $(df -h "$_USB" 2>/dev/null | awk 'NR==2{print $3"/"$2"，剩余 "$4}')"
    case "${_ufs:-}" in vfat|exfat|fat*) _warn "文件系统 ${_ufs} 不支持 swap"; _hint "执行 360v6-format-usb 格式化为 ext4" ;; esac
else
    _err "USB: 未检测到"
fi

printf "\n${_BOLD}[ Docker ]${_N}\n"
if [ -n "$_USB" ] && [ -f "$_USB/docker-bin/dockerd" ]; then
    _dver=$(cat "$_USB/docker-bin/version.txt" 2>/dev/null || echo "?")
    if [ ! -f /etc/docker/daemon.json ]; then
        _warn "Docker ${_dver}: daemon.json 缺失"
        _hint "下次 USB 恢复时自动重建，或手动: /etc/init.d/dockerd restart"
    elif docker info >/dev/null 2>&1; then
        _crun=$(docker ps -q 2>/dev/null | wc -l | tr -d ' ')
        _drv=$(docker info 2>/dev/null | awk '/Storage Driver/{print $3}')
