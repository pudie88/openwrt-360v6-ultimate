        [ "${_drv:-}" = "vfs" ] && _warn "驱动: vfs（缺 overlay 模块）" || _info "驱动: ${_drv:-?}"
    else
        _warn "Docker ${_dver}: 未运行"
        _hint "尝试: rm -f /var/run/docker.pid; /etc/init.d/dockerd restart"
    fi
else
    _warn "Docker: 未安装"
fi

printf "\n${_BOLD}[ AdGuardHome ]${_N}\n"
if [ -n "$_USB" ] && [ -f "$_USB/adguardhome-bin/AdGuardHome" ]; then
    _aver=$(cat "$_USB/adguardhome-bin/version.txt" 2>/dev/null || echo "?")
    _wp=3000
    _yaml="$_USB/AdGuardHome/AdGuardHome.yaml"
    if [ -f "$_yaml" ]; then
        _wpt=$(awk '
            /^http:/{in_http=1; next}
            in_http && /^[^ ]/{in_http=0}
            in_http && /address:/{
                match($0, /:[0-9]+$/)
                if (RSTART>0) { print substr($0, RSTART+1, RLENGTH-1); exit }
