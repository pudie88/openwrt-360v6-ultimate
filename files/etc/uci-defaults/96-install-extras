_DNSMASQ_BACKUP="/etc/config/dhcp.agh-backup"

_user="${1:-}"
_pass="${2:-}"

if [ -z "$_user" ]; then
    echo "用法: agh-finalize <用户名> [密码]"
    echo "      密码可省略，省略时将交互式输入（不回显）"
    exit 1
fi

# FIX-V35-E: 密码为空时改为交互式输入，避免明文出现在进程列表
if [ -z "$_pass" ]; then
    printf "密码: "
    stty -echo 2>/dev/null
    read _pass
    stty echo 2>/dev/null
    echo ""
fi

if [ -z "$_pass" ]; then
    echo "[ERR] 密码不能为空"
    exit 1
fi

if ! command -v curl >/dev/null 2>&1; then
    echo "[ERR] 需要 curl"
    exit 1
fi

if ! pgrep -f "AdGuardHome" >/dev/null 2>&1; then
    echo "[ERR] AGH 进程未运行"
    exit 1
fi

# 自动检测 AGH Web 端口
_agh_port=""
for _p in 3000 5354 8080; do
    _hc=$(curl -s -o /dev/null -w "%{http_code}" --max-time 3 \
        -u "${_user}:${_pass}" "http://127.0.0.1:${_p}/control/status" 2>/dev/null)
    if [ "$_hc" = "200" ]; then
        _agh_port="$_p"
        break
    fi
done

if [ -z "$_agh_port" ]; then
    echo "[ERR] 无法连接到 AGH（尝试端口 3000/5354/8080），请确认向导已完成且凭据正确"
    exit 1
fi

echo "[OK] AGH 登录验证成功（端口 $_agh_port），开始接管 DNS..."

uci set dhcp.@dnsmasq[0].port='0' 2>/dev/null
uci commit dhcp 2>/dev/null
/etc/init.d/dnsmasq reload >/dev/null 2>&1 || true
echo "[OK] dnsmasq DNS 端口已禁用"

/etc/init.d/adguardhome restart >/dev/null 2>&1 || true
echo "[OK] AGH 已重启接管 DNS"

date '+%Y-%m-%d %H:%M:%S' > "$_SD/agh-done"
echo "[OK] agh-done 标记已写入"

__cron_job='0 3 * * 0 _MP=$(cat /etc/install-usb-mount 2>/dev/null); [ -n "$_MP" ] && find "$_MP/AdGuardHome/data/logs" -name "*.log" -mtime +30 -delete 2>/dev/null'
if ! grep -qF "AdGuardHome/data/logs" /etc/crontabs/root 2>/dev/null; then
    echo "$__cron_job" >> /etc/crontabs/root
    /etc/init.d/cron restart >/dev/null 2>&1 || true
    echo "[OK] AGH 日志清理 cron 已注册"
fi

echo "[OK] 完成！AGH 已全面接管 DNS"
echo "     状态查看: 360v6-status"
FINALEOF
        chmod +x /usr/bin/agh-finalize

        /etc/init.d/adguardhome enable 2>/dev/null
        pkill -f AdGuardHome 2>/dev/null; sleep 2
        /etc/init.d/adguardhome start 2>/dev/null

        __agh_up=0
        __wi=0
        while [ "$__wi" -lt 15 ]; do
            if pgrep -f "AdGuardHome" >/dev/null 2>&1; then
                __agh_up=1; break
            fi
            sleep 1; __wi=$((__wi + 1))
        done

