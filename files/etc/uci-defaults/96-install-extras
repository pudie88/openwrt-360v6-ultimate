ping -c1 -W2 223.5.5.5 >/dev/null 2>&1 && _ok "互联网: 已连接" || _warn "互联网: 不通"
grep -q "^root::" /etc/shadow 2>/dev/null && _err "SSH root 密码为空！执行: passwd root"

_title "【Wi-Fi】"
_wf=0
for _phy in /sys/class/ieee80211/phy*; do
    [ -d "$_phy" ] || continue; _wf=1; _pn="${_phy##*/}"
    _bd=$(iw phy "$_pn" info 2>/dev/null | awk '/MHz/{if($2+0>5000){b="5GHz";exit} else b="2.4GHz"} END{print b}')
    _if=$(iw dev 2>/dev/null | awk -v p="$_pn" '$0~"phy#"substr(p,4){f=1} f && /Interface/{print $2; exit}')
    if [ -n "$_if" ]; then
        _ss=$(iwinfo "$_if" info 2>/dev/null | awk -F'"' '/ESSID/{print $2}')
        _ch=$(iwinfo "$_if" info 2>/dev/null | awk '/Channel/{print $4}')
        _cl=$(iw dev "$_if" station dump 2>/dev/null | grep -c "^Station")
        _ok "${_bd:-?} (${_if}): ${_ss:-?} CH${_ch:-?} 客户端=$_cl"
    else
        _warn "${_bd:-?} (${_pn}): 未启用"
    fi
done
[ "$_wf" -eq 0 ] && _warn "未检测到无线网卡"

_title "【系统资源】"
_fp=$(df /overlay 2>/dev/null | awk 'NR==2{gsub(/%/,"",$5); print $5}')
_fu=$(df -h /overlay 2>/dev/null | awk 'NR==2{print $3}'); _ft=$(df -h /overlay 2>/dev/null | awk 'NR==2{print $2}')
if [ -n "$_fp" ]; then
    [ "$_fp" -ge 90 ] && _err "Flash: ${_fu}/${_ft} (${_fp}%)" || { [ "$_fp" -ge 75 ] && _warn "Flash: ${_fu}/${_ft} (${_fp}%)" || _ok "Flash: ${_fu}/${_ft} (${_fp}%)"; }
fi

_mt=$(awk '/MemTotal/{printf "%d",$2/1024}' /proc/meminfo 2>/dev/null)
_ma=$(awk '/MemAvailable/{printf "%d",$2/1024}' /proc/meminfo 2>/dev/null)
_mt=${_mt:-0}; _ma=${_ma:-0}; _mu=$((_mt - _ma)); _mp2=0
[ "$_mt" -gt 0 ] 2>/dev/null && _mp2=$(( _mu * 100 / _mt ))
[ "$_mp2" -ge 85 ] && _warn "内存: ${_mu}/${_mt}MB (${_mp2}%)" || _ok "内存: ${_mu}/${_mt}MB (${_mp2}%)"

_st=$(awk '/SwapTotal/{print $2}' /proc/meminfo 2>/dev/null)
_sf=$(awk '/SwapFree/{print $2}' /proc/meminfo 2>/dev/null)
if [ "${_st:-0}" -gt 0 ]; then
    _su=$(( (_st - ${_sf:-0}) / 1024 )); _stm=$(( _st / 1024 ))
    _ok "Swap: ${_su}/${_stm}MB"
    while IFS= read -r _sl; do
        _sd=$(echo "$_sl" | awk '{print $1}'); [ "$_sd" = "Filename" ] && continue; [ -z "$_sd" ] && continue
        _ssz=$(echo "$_sl" | awk '{printf "%d",$3/1024}'); _spr=$(echo "$_sl" | awk '{print $5}')
        case "$_sd" in /dev/zram*) _info "  zram: ${_ssz}MB (pri ${_spr})" ;; */swapfile) _info "  swapfile: ${_ssz}MB (pri ${_spr})" ;; *) _info "  ${_sd}: ${_ssz}MB" ;; esac
    done < /proc/swaps
else
    _warn "Swap: 未激活"
    [ -n "$_USB" ] && {
        [ -f "$_USB/swapfile" ] && _hint "swapfile 存在但未激活，运行: swapon $_USB/swapfile" || _hint "swapfile 不存在，下次恢复时自动创建"
