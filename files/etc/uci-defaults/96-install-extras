        _log "下载 Docker ${_dv}..."; wget -4 -q --timeout=300 --tries=2 -O "${_tgz}.tmp" "$_DOCKER_BASE/docker-${_dv}.tgz" 2>/dev/null
        [ -f "${_tgz}.tmp" ] && gzip -t "${_tgz}.tmp" 2>/dev/null && mv "${_tgz}.tmp" "$_tgz" || { rm -f "${_tgz}.tmp"; continue; }
        /etc/init.d/dockerd stop 2>/dev/null
        __wi=0; while [ "$__wi" -lt 15 ]; do pgrep -f dockerd >/dev/null 2>&1 || break; sleep 1; __wi=$((__wi+1)); done
        rm -f /var/run/docker.pid 2>/dev/null
        _tar_extract "$_tgz" "$_USB/docker-bin" "docker" && [ -f "$_USB/docker-bin/dockerd" ] && {
            echo "$_dv" > "$_USB/docker-bin/version.txt"
            /etc/init.d/dockerd start 2>/dev/null; sleep 5
            _log "Docker: $_cur → ${_dv}"; return 0
        }
    done; _log "升级失败"; return 1
}

_upgrade_agh() {
    _cur=$(cat "$_USB/adguardhome-bin/version.txt" 2>/dev/null || echo "?"); _log "当前 AGH: $_cur"
    /etc/init.d/adguardhome stop 2>/dev/null; pkill -f AdGuardHome 2>/dev/null; sleep 2
