cat > /usr/lib/install-extras/run.sh << 'RUNEOF'
#!/bin/sh
_LT="install-main"
_DONE="/etc/install-extras-done"
_LOCK="/tmp/install-main.lock"
_SD="/etc/install-state"

log() { echo "[$(date '+%H:%M:%S')] $1" | logger -t "$_LT"; }

mkdir -p "$_SD"
[ -f "$_DONE" ] && { log "基础环境已完成，跳过"; exit 0; }

if [ -f "$_LOCK" ]; then
    __lp=$(cat "$_LOCK" 2>/dev/null)
    kill -0 "$__lp" 2>/dev/null && exit 0
    rm -f "$_LOCK"
fi
echo $$ > "$_LOCK"

__fail=$(cat "$_SD/phase1-failures" 2>/dev/null || echo 0)
[ "${__fail:-0}" -ge 3 ] && { rm -f "$_LOCK"; exit 1; }

log "基础环境启动"
sleep 10

# 等待网络
__ok=0; __i=1
while [ "$__i" -le 36 ]; do
    ping -c1 -W2 223.5.5.5 >/dev/null 2>&1 && { __ok=1; break; }
    sleep 5; __i=$((__i + 1))
done
if [ "$__ok" -eq 0 ]; then
    echo $((__fail + 1)) > "$_SD/phase1-failures"
    rm -f "$_LOCK"
    exit 1
fi

# 自动检测包管理器（ImmortalWrt 新版用 apk，旧版/OpenWrt 23.05 用 opkg）
if command -v apk >/dev/null 2>&1; then
    _pkg_install() { apk add --no-cache "$@" >/dev/null 2>&1; }
    log "包管理器: apk"
elif command -v opkg >/dev/null 2>&1; then
    _pkg_install() { opkg update >/dev/null 2>&1; opkg install "$@" >/dev/null 2>&1; }
    log "包管理器: opkg"
else
    _pkg_install() { log "无可用包管理器，跳过安装 $*"; return 1; }
    log "警告：未找到包管理器"
fi

for __p in bash htop lsblk smartmontools fdisk curl; do
    _pkg_install "$__p" && log "已安装: $__p"
done

date '+%Y-%m-%d %H:%M:%S' > "$_DONE"
rm -f "$_SD/phase1-failures" "$_LOCK"
log "基础环境完成"

