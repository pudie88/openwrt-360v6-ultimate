IFACEEOF
chmod +x /etc/hotplug.d/iface/96-install-extras

# ══════════════════════════════════════════════════════════════
# Hotplug：block（V4.0）
# ══════════════════════════════════════════════════════════════
cat > /etc/hotplug.d/block/96-install-usb << 'BLOCKEOF'
#!/bin/sh
case "${DEVNAME:-}" in sd[a-z]*|mmcblk[0-9]*) ;; *) exit 0 ;; esac

if [ "${ACTION:-}" = "remove" ]; then
    logger -t "usb-extras" "U 盘移除，停止依赖服务"
    /etc/init.d/dockerd stop 2>/dev/null
    /etc/init.d/adguardhome stop 2>/dev/null
    exit 0
fi

[ "${ACTION:-}" = "add" ] || exit 0
[ -f /etc/install-extras-done ] || exit 0

_mp=""
for _i in $(seq 1 12); do
    for _m in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        grep -q "^[^ ]* $_m " /proc/mounts 2>/dev/null && { _mp="$_m"; break 2; }
    done
    sleep 2
done

[ -n "$_mp" ] && /usr/lib/install-extras/install-usb.sh "$_mp" &
BLOCKEOF
chmod +x /etc/hotplug.d/block/96-install-usb

# ══════════════════════════════════════════════════════════════
# Docker 防火墙（V4.0：iptables/nftables 自动检测）
# ══════════════════════════════════════════════════════════════
cat > /etc/hotplug.d/iface/99-docker-net << 'DOCKERFWEOF'
#!/bin/sh
[ "${ACTION}" = "ifup" ]   || exit 0
[ "${INTERFACE}" = "lan" ] || exit 0
sleep 2

if command -v nft >/dev/null 2>&1; then
    # nftables
    nft list table ip filter 2>/dev/null | grep -q "DOCKER-USER" || {
        nft add table ip filter 2>/dev/null
        nft add chain ip filter DOCKER-USER 2>/dev/null
        nft add rule ip filter DOCKER-USER iifname "docker0" oifname "br-lan" accept 2>/dev/null
        nft add rule ip filter DOCKER-USER iifname "br-lan" oifname "docker0" accept 2>/dev/null
    }
elif command -v iptables >/dev/null 2>&1; then
    # iptables（旧版 OpenWrt）
    iptables -C FORWARD -i docker0 -o br-lan -j ACCEPT 2>/dev/null || \
        iptables -I FORWARD -i docker0 -o br-lan -j ACCEPT 2>/dev/null
    iptables -C FORWARD -i br-lan -o docker0 -j ACCEPT 2>/dev/null || \
        iptables -I FORWARD -i br-lan -o docker0 -j ACCEPT 2>/dev/null
fi
DOCKERFWEOF
chmod +x /etc/hotplug.d/iface/99-docker-net

rm -f /etc/uci-defaults/96-install-extras

log "V4.0 安装完成"
__flush_logs
exit 0
