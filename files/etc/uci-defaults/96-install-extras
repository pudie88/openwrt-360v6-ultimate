    procd_set_param stdout 1; procd_set_param stderr 1
    # FIX-V35-G: max_failures 改为 3，避免崩溃时无限重启
    procd_set_param respawn 3600 5 3
    procd_close_instance
}
stop_service() { pkill dockerd 2>/dev/null || true; pkill containerd 2>/dev/null || true; }
DINITEOF
        chmod +x /etc/init.d/dockerd
