#!/bin/sh
# 96-install-extras [V3.5 STABLE]
# 适用：360 V6 / 小米 CR660x / IPQ6000 (128M Flash / ImmortalWrt / busybox ash)
#
# V3.5 修复清单（相对 V3.4）：
#   FIX-V35-A: FIX-V34-C 实现缺失——二进制已存在时旧配置含 users 字段应清除
#              而非仅打日志，修复：检测到旧配置含 users 字段时执行 rm 清除
#   FIX-V35-B: _dnsmasq_restore EXIT trap 总是回滚——install-usb.sh 生命周期内
#              $SD/agh-done 由用户手动执行 agh-finalize 写入，脚本内永远不存在
#              导致每次正常退出都回滚 dnsmasq，AGH 下次启动报 53 端口冲突
#              修复：增加脚本内部标志变量 _AGH_STARTED，AGH 进程确认启动后置 1
#              EXIT trap 通过该标志决定是否跳过回滚
#   FIX-V35-C: _tar_extract 空目录静默返回 0——glob 不展开时循环体从不执行
#              函数返回 0，调用方误以为成功，实际目标目录为空
#              修复：循环前置空文件计数器，循环后检测是否有文件被移动
#   FIX-V35-D: tgz 完整性校验仅靠文件大小——截断 tgz（>5MB 但尾部损坏）或
#              CDN 错误页面（200 OK + HTML）无法被拦截，导致 tar 解压损坏
#              修复：下载完成后用 gzip -t 校验完整性，失败则删除重试
#   FIX-V35-E: agh-finalize 密码明文出现在进程列表（ps aux / /proc/pid/cmdline）
#              修复：密码参数为空时改为交互式 stty -echo 读取
#   FIX-V35-F: block hotplug sleep 5 在慢速 U 盘上不足，挂载点未就绪时
#              静默退出，事件永久丢失
#              修复：改为最多 24 秒轮询（每 2 秒一次，共 12 次）
#   FIX-V35-G: dockerd respawn max_failures=0 导致崩溃时无限重启
#              修复：改为 3600 5 3（最多连续失败 3 次后停止）
#   FIX-V35-H: DNS 冲突检测通过 UCI 未配置 port 等价为 53，可能误报
#              修复：改用 netstat 直接检测 dnsmasq 是否占用 53 端口
#   FIX-V35-I: 360v6-status 中 AGH 统计 JSON 解析不健壮（键值间有空格时失败）
#              修复：改用 sed 兼容写法
#   FIX-V35-J: wget 无重试，网络抖动时直接放弃当前版本
#              修复：用 shell 循环包裹，最多重试 3 次
#   FIX-V35-K: 360v6-uninstall 在 status 帮助中提示但从未生成
#              修复：补充生成 360v6-uninstall 工具
#   FIX-V35-L: overlay2 可用性判断用 modinfo（IPQ6000 上可能不存在）
#              修复：仅用 /proc/filesystems 判断

_SD="/etc/install-state"
mkdir -p "$_SD" /usr/lib/install-extras /usr/bin \
         /etc/hotplug.d/iface /etc/hotplug.d/block \
         /etc/dbus-1 /etc/dbus-1/system.d /etc/crontabs

# 预置：nlbwmon 缓冲区告警抑制
echo "1048576" > /proc/sys/net/core/rmem_max 2>/dev/null
echo "1048576" > /proc/sys/net/core/wmem_max 2>/dev/null

# 动态获取 USB 挂载点函数
_get_usb_mount() {
    for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        grep -q "^[^ ]* $_mp " /proc/mounts 2>/dev/null && { echo "$_mp"; return 0; }
    done
    return 1
}

# ══════════════════════════════════════════════════════════════
# 模块 0：360v6-status（V3.5）
# ══════════════════════════════════════════════════════════════
cat > /usr/bin/360v6-status << 'STATUSEOF'
#!/bin/sh
_SD="/etc/install-state"
_get_usb_mount() {
    for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        grep -q "^[^ ]* $_mp " /proc/mounts 2>/dev/null && { echo "$_mp"; return 0; }
    done
    return 1
}

_timeout() {
    __tt="$1"; shift
    if command -v timeout >/dev/null 2>&1; then
        if timeout --help 2>&1 | grep -q '\-t'; then
            timeout -t "$__tt" "$@"
        else
            timeout "$__tt" "$@"
        fi
        return $?
    fi
    "$@" &
    __tp=$!
    ( sleep "$__tt"; kill "$__tp" 2>/dev/null ) &
    __kp=$!
    wait "$__tp" 2>/dev/null
    __tr=$?
    kill "$__kp" 2>/dev/null
    wait "$__kp" 2>/dev/null
    return $__tr
}

echo "=== 360 V6 状态 @ $(date '+%Y-%m-%d %H:%M:%S') ==="
echo "版本  : V3.5 STABLE"
echo ""

if [ -f /etc/install-extras-done ]; then
    echo "[OK] 基础环境：已完成 ($(cat /etc/install-extras-done 2>/dev/null))"
else
    echo "[..] 基础环境：待触发"
fi

if [ -f /etc/install-usb-done ]; then
    echo "[OK] 重型应用：已完成 ($(cat /etc/install-usb-done 2>/dev/null))"
    [ -f "$_SD/docker-done" ] && echo "     Docker : OK" || echo "     Docker : 未完成"
    if [ -f "$_SD/agh-done" ]; then
        echo "     AGH    : OK（已完成初始化）"
        if command -v curl >/dev/null 2>&1; then
            _stats=$(_timeout 3 curl -s http://127.0.0.1:3000/control/stats 2>/dev/null)
            if [ -n "$_stats" ]; then
                # FIX-V35-I: 用 sed 兼容解析，支持键值间有空格的标准 JSON
                _qcnt=$(echo "$_stats" | sed 's/.*"num_dns_queries":[[:space:]]*\([0-9]*\).*/\1/' \
                        | grep -E '^[0-9]+$')
                [ -n "$_qcnt" ] && echo "     AGH统计: 总查询 ${_qcnt} 次"
            fi
        fi
    elif pgrep -f "AdGuardHome" >/dev/null 2>&1; then
        echo "     AGH    : 运行中（等待初始化向导）"
        echo "     请访问 http://192.168.2.1:3000 完成初始化"
    else
        echo "     AGH    : 未完成"
    fi
else
    echo "[..] 重型应用：待 U 盘"
fi

echo ""
df -h /overlay 2>/dev/null | awk 'NR==2{print "Flash : "$3" / "$2" ("$5")"}'
free 2>/dev/null | awk '/Mem:/{printf "Mem   : %dMB used / %dMB total\n",$3/1024,$2/1024}'
echo ""

_USB=$(_get_usb_mount)
[ -n "$_USB" ] && echo "USB   : $_USB (已挂载)" || echo "USB   : 未检测到"
[ -f /etc/install-usb-mount ] && echo "PATH  : $(cat /etc/install-usb-mount)"
grep -q swapfile /proc/swaps 2>/dev/null && echo "Swap  : swapfile 已激活"
echo ""

_dver=$(_timeout 4 docker info --format '{{.ServerVersion}}' 2>/dev/null)
if [ -n "$_dver" ]; then
    echo "[OK] Docker      : ${_dver}"
else
    echo "[--] Docker      : 未启动"
fi

if pgrep -f "AdGuardHome" >/dev/null 2>&1; then
    echo "[OK] AdGuardHome : 运行中"
else
    echo "[--] AdGuardHome : 未启动"
fi

echo ""
echo "AGH 管理: http://192.168.2.1:3000"
echo "健康检查: 360v6-health [--fix]"
echo "卸载    : 360v6-uninstall"
STATUSEOF
chmod +x /usr/bin/360v6-status

# ══════════════════════════════════════════════════════════════
# 模块 0b：360v6-health（V3.5）
# ══════════════════════════════════════════════════════════════
cat > /usr/bin/360v6-health << 'HEALTHEOF'
#!/bin/sh
_SD="/etc/install-state"
_fix=0
[ "$1" = "--fix" ] && _fix=1

_ok()   { echo "[OK]  $1"; }
_warn() { echo "[WARN] $1"; }
_err()  { echo "[ERR]  $1"; }
_fix()  { [ "$_fix" -eq 1 ] && { echo "[FIX]  $1"; eval "$2"; } || echo "[HINT] 修复: $2"; }

echo "=== 360 V6 健康检查 @ $(date '+%Y-%m-%d %H:%M:%S') ==="
[ "$_fix" -eq 1 ] && echo "（修复模式已启用）"
echo ""

_errs=0

# 1. Flash 空间
_flash_pct=$(df /overlay 2>/dev/null | awk 'NR==2{gsub(/%/,"",$5);print $5}')
if [ -n "$_flash_pct" ] && [ "$_flash_pct" -ge 90 ]; then
    _err "Flash 使用率 ${_flash_pct}%（>= 90%），有写满风险"
    _fix "清理 apk 缓存" "rm -rf /tmp/opkg-lists /var/cache/apk 2>/dev/null; true"
    _errs=$((_errs+1))
else
    _ok "Flash 使用率 ${_flash_pct:-?}%"
fi

# 2. Swap
if grep -q swapfile /proc/swaps 2>/dev/null; then
    _ok "Swap 已激活"
else
    _warn "Swap 未激活"
    _USB=""
    for _m in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        grep -q "^[^ ]* $_m " /proc/mounts 2>/dev/null && { _USB="$_m"; break; }
    done
    [ -n "$_USB" ] && [ -f "$_USB/swapfile" ] && \
        _fix "激活 swapfile" "swapon '$_USB/swapfile' 2>/dev/null && echo 10 > /proc/sys/vm/swappiness"
fi

# 3. Docker
if [ -f "$_SD/docker-done" ]; then
    _dver=$(docker info --format '{{.ServerVersion}}' 2>/dev/null)
    if [ -n "$_dver" ]; then
        _ok "Docker 运行中（$_dver）"
    else
        _err "Docker 已安装但未运行"
        _fix "启动 dockerd" "/etc/init.d/dockerd start"
        _errs=$((_errs+1))
    fi
else
    _warn "Docker 未部署"
fi

# 4. AGH 进程
if pgrep -f "AdGuardHome" >/dev/null 2>&1; then
    _ok "AdGuardHome 进程运行中"
else
    if [ -f "$_SD/agh-done" ] || [ -f /etc/install-usb-done ]; then
        _err "AdGuardHome 未运行"
        _fix "启动 AGH" "/etc/init.d/adguardhome start"
        _errs=$((_errs+1))
    else
        _warn "AdGuardHome 未部署"
    fi
fi

# 5. DNS 冲突检测
# FIX-V35-H: 改用 netstat 直接检测 dnsmasq 是否实际占用 53 端口
# UCI 未配置 port 不等于 dnsmasq 一定在监听 53，避免误报
if [ -f "$_SD/agh-done" ]; then
    _dnsmasq_on_53=$(netstat -lnup 2>/dev/null | awk '$4 ~ /:53$/ && $NF ~ /dnsmasq/{print 1; exit}')
    if [ "${_dnsmasq_on_53}" = "1" ]; then
        _err "DNS 冲突：AGH 已 finalize 但 dnsmasq 仍监听 53 端口"
        _fix "禁用 dnsmasq DNS 端口" \
            "uci set dhcp.@dnsmasq[0].port='0'; uci commit dhcp; /etc/init.d/dnsmasq reload"
        _errs=$((_errs+1))
    else
        _ok "DNS 分配正常（dnsmasq 未占用 53 端口，AGH 接管）"
    fi
else
    _ok "DNS 分配正常（dnsmasq 提供 DNS，AGH 向导未完成）"
fi

# 6. AGH 端口可达性
if pgrep -f "AdGuardHome" >/dev/null 2>&1; then
    if command -v curl >/dev/null 2>&1; then
        _hc=$(curl -s -o /dev/null -w "%{http_code}" --max-time 3 http://127.0.0.1:3000/ 2>/dev/null)
        if [ "$_hc" = "200" ] || [ "$_hc" = "302" ] || [ "$_hc" = "301" ]; then
            _ok "AGH Web 端口 3000 可达（HTTP $_hc）"
        else
            _warn "AGH Web 端口 3000 响应异常（HTTP $_hc），可能使用其他端口"
        fi
    fi
fi

# 7. U 盘挂载
_USB=""
for _m in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
    grep -q "^[^ ]* $_m " /proc/mounts 2>/dev/null && { _USB="$_m"; break; }
done
if [ -n "$_USB" ]; then
    _ok "U 盘挂载于 $_USB"
    _usb_free=$(df -k "$_USB" 2>/dev/null | awk 'NR==2{print $4}')
    [ "${_usb_free:-0}" -lt 524288 ] && \
        _warn "U 盘剩余空间不足 512MB（${_usb_free}KB）"
else
    [ -f /etc/install-usb-done ] && _warn "U 盘未挂载，Docker/AGH 可能无法运行"
fi

echo ""
if [ "$_errs" -eq 0 ]; then
    echo "健康检查完成，无异常"
else
    echo "发现 ${_errs} 个问题$([ "$_fix" -eq 0 ] && echo '，运行 360v6-health --fix 自动修复' || echo '（已尝试修复）')"
fi
HEALTHEOF
chmod +x /usr/bin/360v6-health

# ══════════════════════════════════════════════════════════════
# 模块 0c：360v6-uninstall（V3.5 新增，FIX-V35-K）
# ══════════════════════════════════════════════════════════════
cat > /usr/bin/360v6-uninstall << 'UNINSTEOF'
#!/bin/sh
# 360v6-uninstall：完整卸载 install-extras 部署的所有组件
# 用法：360v6-uninstall [--yes]
_SD="/etc/install-state"

_confirm() {
    [ "$1" = "--yes" ] && return 0
    printf "此操作将停止 Docker 和 AdGuardHome，删除所有状态标记。继续？[y/N] "
    read _ans
    case "$_ans" in y|Y) return 0 ;; *) echo "已取消"; exit 0 ;; esac
}
_confirm "$1"

echo "[1/7] 停止 AdGuardHome..."
/etc/init.d/adguardhome stop 2>/dev/null
/etc/init.d/adguardhome disable 2>/dev/null
pkill -f AdGuardHome 2>/dev/null
sleep 2

echo "[2/7] 停止 Docker..."
/etc/init.d/dockerd stop 2>/dev/null
/etc/init.d/dockerd disable 2>/dev/null
pkill dockerd 2>/dev/null
pkill containerd 2>/dev/null
sleep 2

echo "[3/7] 恢复 dnsmasq DNS 端口..."
_cur=$(uci get dhcp.@dnsmasq[0].port 2>/dev/null)
if [ "${_cur}" = "0" ]; then
    uci delete dhcp.@dnsmasq[0].port 2>/dev/null
    uci commit dhcp 2>/dev/null
    /etc/init.d/dnsmasq restart >/dev/null 2>&1
    echo "     dnsmasq DNS 端口已恢复"
fi

echo "[4/7] 删除符号链接和工具..."
for _b in docker dockerd containerd containerd-shim-runc-v2 ctr runc docker-proxy docker-init; do
    [ -L "/usr/bin/$_b" ] && rm -f "/usr/bin/$_b"
done
rm -f /usr/bin/AdGuardHome /usr/bin/agh-finalize

echo "[5/7] 删除 init.d 脚本..."
rm -f /etc/init.d/dockerd

echo "[6/7] 删除状态标记..."
rm -f /etc/install-extras-done /etc/install-usb-done /etc/install-usb-mount
rm -f "$_SD/docker-done" "$_SD/agh-done"
rm -f "$_SD/docker-failures" "$_SD/agh-failures" "$_SD/phase1-failures"
rm -f "$_SD/last-self-heal"
rm -f /etc/docker/daemon.json
rm -f /etc/adguardhome.yaml /etc/adguardhome/adguardhome.yaml
rm -f /etc/config/dhcp.agh-backup

echo "[7/7] 删除 hotplug 脚本..."
rm -f /etc/hotplug.d/iface/96-install-extras
rm -f /etc/hotplug.d/block/96-install-usb

echo ""
echo "卸载完成。U 盘上的数据（Docker 镜像、AGH 数据）未删除。"
echo "如需彻底清理，请手动删除 U 盘上的 docker-bin/ docker-data/ adguardhome-bin/ AdGuardHome/ swapfile"
UNINSTEOF
chmod +x /usr/bin/360v6-uninstall

# ══════════════════════════════════════════════════════════════
# 模块 A：install-usb.sh（Phase 2 - V3.5）
# ══════════════════════════════════════════════════════════════
cat > /usr/lib/install-extras/install-usb.sh << 'USBEOF'
#!/bin/sh
_LT="usb-extras"
_DONE="/etc/install-usb-done"
_LOCK="/tmp/install-usb.lock"
_SD="/etc/install-state"
_MF="/etc/install-usb-mount"
_DNSMASQ_BACKUP="/etc/config/dhcp.agh-backup"

_DOCKER_VERS="28.1.0 27.5.1 26.1.4"
_DOCKER_BASE="https://download.docker.com/linux/static/stable/aarch64"
_AGH_URL="https://static.adguard.com/adguardhome/release/AdGuardHome_linux_arm64.tar.gz"

log() { __lm="[$(date '+%H:%M:%S')] $1"; echo "$__lm"; echo "$__lm" | logger -t "$_LT"; }
_is_mounted() { grep -q "^[^ ]* $1 " /proc/mounts 2>/dev/null; }
_get_usb_mount() {
    for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        _is_mounted "$_mp" && { echo "$_mp"; return 0; }
    done
    return 1
}

_is_usb_dev() {
    case "$1" in
        /dev/sd[a-z][0-9]*|/dev/mmcblk[0-9]*p[0-9]*) return 0 ;;
        *) return 1 ;;
    esac
}

_timeout() {
    __tt="$1"; shift
    if command -v timeout >/dev/null 2>&1; then
        if timeout --help 2>&1 | grep -q '\-t'; then
            timeout -t "$__tt" "$@"
        else
            timeout "$__tt" "$@"
        fi
        return $?
    fi
    "$@" &
    __tp=$!
    ( sleep "$__tt"; kill "$__tp" 2>/dev/null ) &
    __kp=$!
    wait "$__tp" 2>/dev/null
    __tr=$?
    kill "$__kp" 2>/dev/null
    wait "$__kp" 2>/dev/null
    return $__tr
}

# FIX-V35-C: 增加文件计数检测，空目录时返回失败而非静默成功
_tar_extract() {
    __tgz="$1"; __dst="$2"; __subdir="$3"
    __tmp="${__dst}.xtmp$$"
    rm -rf "$__tmp"; mkdir -p "$__tmp" "$__dst"
    tar xzf "$__tgz" -C "$__tmp" 2>/dev/null || { rm -rf "$__tmp"; log "tar 解压失败: $__tgz"; return 1; }
    if [ -n "$__subdir" ] && [ -d "$__tmp/$__subdir" ]; then
        __src="$__tmp/$__subdir"
    else
        __src="$__tmp"
    fi
    __moved=0
    for __f in "$__src/"*; do
        [ -e "$__f" ] || continue
        __bn="${__f##*/}"
        [ -d "$__dst/$__bn" ] && rm -rf "$__dst/$__bn"
        [ -f "$__dst/$__bn" ] && rm -f "$__dst/$__bn"
        mv "$__f" "$__dst/" 2>/dev/null || { rm -rf "$__tmp"; log "tar mv 失败: $__f"; return 1; }
        __moved=$((__moved + 1))
    done
    rm -rf "$__tmp"
    if [ "$__moved" -eq 0 ]; then
        log "tar 解压结果为空（目录结构与预期不符）: $__tgz"
        return 1
    fi
    return 0
}

# FIX-V35-J: wget 带重试，最多 3 次，间隔 3 秒
_wget_retry() {
    __url="$1"; __out="$2"; __min_size="${3:-0}"
    __r=0
    while [ "$__r" -lt 3 ]; do
        wget -q --timeout=120 -O "$__out" "$__url" 2>/dev/null
        __sz=$(wc -c < "$__out" 2>/dev/null || echo 0)
        if [ "${__sz:-0}" -ge "$__min_size" ] && [ "${__sz:-0}" -gt 0 ]; then
            return 0
        fi
        rm -f "$__out"
        __r=$((__r + 1))
        [ "$__r" -lt 3 ] && { log "下载失败，${__r}/3，等待 3 秒重试..."; sleep 3; }
    done
    log "下载失败（已重试 3 次）: $__url"
    return 1
}

mkdir -p "$_SD"

# 参数解析
__self_heal=0; __force=0; __mp_arg=""
for _a in "$@"; do
    case "$_a" in
        --self-heal) __self_heal=1 ;;
        --force)     __force=1 ;;
        --*)         ;;
        *)           [ -z "$__mp_arg" ] && __mp_arg="$_a" ;;
    esac
done

# 自愈模式
if [ "$__self_heal" -eq 1 ]; then
    [ -f /etc/install-extras-done ] || exit 0
    [ -f "$_DONE" ] && exit 0
    __last_heal=$(cat "$_SD/last-self-heal" 2>/dev/null || echo 0)
    __now=$(date '+%s' 2>/dev/null || awk '{print int($1)}' /proc/uptime 2>/dev/null || echo 0)
    __elapsed=$((__now - __last_heal))
    if [ "$__elapsed" -lt 300 ]; then
        log "自愈冷却中（距上次 ${__elapsed}s < 300s），跳过"
        exit 0
    fi
    __dsf=$(cat "$_SD/docker-failures" 2>/dev/null || echo 0)
    __asf=$(cat "$_SD/agh-failures" 2>/dev/null || echo 0)
    [ "${__dsf:-0}" -ge 3 ] && [ "${__asf:-0}" -ge 3 ] && exit 0
    if [ -f "$_LOCK" ]; then
        __lp=$(cat "$_LOCK" 2>/dev/null)
        kill -0 "$__lp" 2>/dev/null && exit 0
        rm -f "$_LOCK"
    fi
    _USB=$(_get_usb_mount)
    if [ -n "$_USB" ]; then
        echo "$__now" > "$_SD/last-self-heal"
        log "自愈触发: $_USB"
        exec /usr/lib/install-extras/install-usb.sh "$_USB"
    fi
    exit 0
fi

# --force 清理在 $_DONE 检查之前执行（FIX-V34-B 保留）
if [ "$__force" -eq 1 ]; then
    rm -f "$_DONE"
    rm -f "$_SD/docker-failures" "$_SD/agh-failures" "$_SD/docker-done" "$_SD/agh-done"
    rm -f /etc/adguardhome.yaml /etc/adguardhome/adguardhome.yaml
    log "--force：失败计数、组件标记及 AGH 配置已清零"
fi

# 已完成检查（在 force 清理之后）
