        _new=$(cat "$_USB/adguardhome-bin/version.txt" 2>/dev/null || echo "?")
        _log "AGH: $_cur → ${_new}"; return 0
    fi
    _log "升级失败"; return 1
}

case "$1" in --docker) _upgrade_docker ;; --agh) _upgrade_agh ;; *)
    echo "用法: 360v6-upgrade --docker | --agh"
    echo "Docker: $(cat "$_USB/docker-bin/version.txt" 2>/dev/null || echo '未安装')"
