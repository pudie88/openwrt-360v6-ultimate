cat > /etc/hotplug.d/block/96-install-usb << 'BLOCKEOF'
#!/bin/sh
[ -f /usr/lib/install-extras/lib.sh ] && . /usr/lib/install-extras/lib.sh

case "${DEVNAME:-}" in sd[a-z][0-9]*|mmcblk[0-9]*p[0-9]*) ;; *) exit 0 ;; esac

if [ "${ACTION:-}" = "remove" ]; then
    logger -t "usb-extras" "U 盘移除 (${DEVNAME})"
    while IFS= read -r _line; do
        _dev=$(echo "$_line" | awk '{print $1}')
        _mp=$(echo "$_line" | awk '{print $2}')
        case "$_dev" in
            /dev/sd[a-z]*|/dev/mmcblk[0-9]*)
                if [ -f "$_mp/swapfile" ] && _is_swap_active "$_mp/swapfile" 2>/dev/null; then
                    swapoff "$_mp/swapfile" 2>/dev/null && logger -t "usb-extras" "swapoff: $_mp/swapfile"
                fi ;;
        esac
    done < /proc/mounts
    /etc/init.d/dockerd stop 2>/dev/null
    /etc/init.d/adguardhome stop 2>/dev/null
    rm -f /etc/install-usb-done 2>/dev/null
    exit 0
fi

# hotplug block/96-install-usb 修改
[ "${ACTION:-}" = "add" ] || exit 0

_DEV="/dev/${DEVNAME}"
_mp="/mnt/${DEVNAME}"

# 等待设备节点就绪
_i=1
while [ "$_i" -le 10 ]; do
    [ -b "$_DEV" ] && break
    sleep 1; _i=$((_i+1))
done
[ -b "$_DEV" ] || { logger -t "usb-extras" "设备节点不存在: $_DEV"; exit 1; }

# 检查是否已挂载
_already=$(awk -v d="$_DEV" '$1==d{print $2; exit}' /proc/mounts 2>/dev/null)
if [ -n "$_already" ]; then
    _mp="$_already"
else
    # 未挂载，读取 fs 类型
    _fs=$(blkid -o value -s TYPE "$_DEV" 2>/dev/null || echo "")
    case "${_fs:-}" in
        ext2|ext3|ext4|btrfs|xfs|f2fs)
            # 支持的格式，正常挂载
            mkdir -p "$_mp"
            mount "$_DEV" "$_mp" 2>/dev/null || { logger -t "usb-extras" "挂载失败: $_DEV"; exit 1; }
            ;;
        *)
            # NTFS/FAT/exFAT/未知/dirty卷 → 直接格式化
            logger -t "usb-extras" "文件系统 [${_fs:-未知}] 不支持或挂载失败，格式化为 ext4: $_DEV"
            command -v mkfs.ext4 >/dev/null 2>&1 || _pkg_install e2fsprogs 2>/dev/null
            mkfs.ext4 -L "OPENWRT-USB" -F "$_DEV" >/dev/null 2>&1 || { logger -t "usb-extras" "格式化失败"; exit 1; }
            mkdir -p "$_mp"
            mount -t ext4 "$_DEV" "$_mp" 2>/dev/null || { logger -t "usb-extras" "格式化后挂载失败"; exit 1; }
            ;;
    esac
fi

[ -f /etc/install-extras-done ] || { logger -t "usb-extras" "等待 Phase 1"; exit 0; }
logger -t "usb-extras" "U 盘就绪: $_mp (${DEVNAME})"
/usr/lib/install-extras/install-usb.sh "$_mp" </dev/null >/dev/null 2>&1 &
BLOCKEOF
chmod +x /etc/hotplug.d/block/96-install-usb

