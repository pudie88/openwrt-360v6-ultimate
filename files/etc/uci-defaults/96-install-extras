    fi
elif [ -n "$_USB" ]; then
    __dl_fails=$(cat "$_USB/.agh-download-fails" 2>/dev/null || echo 0)
    if [ "${__dl_fails:-0}" -ge 3 ]; then
        _warn "AGH: 下载失败 ${__dl_fails} 次，已暂停自动安装"
        _hint "手动: 360v6-upgrade --agh"
    else
        _warn "AGH: 二进制未安装"
