#!/bin/sh
# 96-install-extras [V3.3 STABLE]
# 适用：360 V6 / 小米 CR660x / IPQ6000 (128M Flash / ImmortalWrt / busybox ash)
#
# V3.3 修复清单（相对 V3.2）：
#   FIX-A: 移除 AGH --pidfile 参数（AGH 不支持，导致进程立即退出）
#          改用 pgrep 检测进程存活，更可靠
#   FIX-B: service_started() 是 procd 死代码（procd 从不调用此函数）
#          dnsmasq 禁用移入 start_service()，在 procd_close_instance 后同步执行
#          （向导完成前不执行，向导完成后 reboot 时先禁再启，消除端口冲突）
#   FIX-C: trap EXIT 无条件调用 _dnsmasq_restore，破坏已 finalize 的 AGH DNS
#          修复：_dnsmasq_restore 开头检查 agh-done 标记，已 finalize 则跳过
#   FIX-D: Docker daemon.json 写死 overlay2，IPQ6000 内核无此模块导致 dockerd 崩溃
#          修复：启动前检测 overlay2 可用性，不可用则降级为 vfs
#   FIX-E: Docker init.d cgroup2 挂载时机错误（在 procd 沙箱就绪前挂载）
#          修复：start_service 内先检查是否已挂载，避免重复挂载和时序问题
#   FIX-F: Docker tgz 仅校验大小，损坏文件永久阻塞
#          修复：解压失败时删除对应 tgz 缓存，强制重新下载
#   FIX-G: 自愈模式无冷却，date +%s fallback 用 awk srand() 返回随机值而非时间
#          修复：fallback 改为读 /proc/uptime，冷却逻辑可靠
#   FIX-H: agh-finalize 无认证访问 /control/status 必然 401，finalize 永远失败
#          修复：agh-finalize 接收用户名密码参数，用 Basic Auth 验证登录
#   FIX-I: swapon 后未设置 swappiness，USB 随机写慢导致系统假死
#          修复：swapon 后立即设置 vm.swappiness=10 及其他内存参数
#   FIX-J: run.sh 硬编码包管理器命令，无法兼容新旧版本
#          修复：自动检测 apk（ImmortalWrt 新版/OpenWrt snapshot）或
#          opkg（ImmortalWrt 旧版/OpenWrt 23.05），运行时动态选择
#   FIX-K: install-usb.sh 中裸用 timeout 命令，BusyBox 参数格式可能不同
#          修复：统一用 _timeout() 封装，自动检测 BusyBox timeout 格式
#   FIX-L: cgroup2 重复挂载（install 阶段 + init.d 各挂载一次）
#          修复：挂载前先检查 /proc/mounts，已挂载则跳过
#   FIX-M: docker info + docker version 两次调用间 dockerd 可能退出
#          修复：改用一次 docker info --format 同时获取状态和版本
#   FIX-N: --force 不清理旧 AGH yaml，重跑时 AGH 读旧配置跳过向导
#          修复：--force 时同时删除 /etc/adguardhome.yaml
#   FIX-O: _DNSMASQ_BACKUP 路径名误导（dnsmasq.conf 暗示 /etc/dnsmasq.conf 格式）
#          修复：改为 /etc/config/dhcp.agh-backup（备份的是 UCI dhcp 配置）
#   FIX-P: dirty_ratio=5 过于激进，128MB 设备频繁小 IO 写 USB 反而降性能
#          修复：dirty_ratio=20，dirty_background_ratio=10
#   FIX-Q: 360v6-health 工具缺失，status 脚本提示但命令不存在
#          新增：完整的健康检查 + --fix 自动修复工具

_SD="/etc/install-state"
mkdir -p "$_SD" /usr/lib/install-extras /usr/bin \
         /etc/hotplug.d/iface /etc/hotplug.d/block \
         /etc/dbus-1 /etc/dbus-1/system.d /etc/crontabs

# 预置：nlbwmon 缓冲区告警抑制
echo "1048576" > /proc/sys/net/core/rmem_max 2>/dev/null
echo "1048576" > /proc/sys/net/core/wmem_max 2>/dev/null

# 动态获取 USB 挂载点函数
_get_usb_mount() {
    for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        grep -q "^[^ ]* $_mp " /proc/mounts 2>/dev/null && { echo "$_mp"; return 0; }
    done
    return 1
}

# ══════════════════════════════════════════════════════════════
# 模块 0：360v6-status（V3.3）
# ══════════════════════════════════════════════════════════════
cat > /usr/bin/360v6-status << 'STATUSEOF'
#!/bin/sh
_SD="/etc/install-state"
_get_usb_mount() {
    for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        grep -q "^[^ ]* $_mp " /proc/mounts 2>/dev/null && { echo "$_mp"; return 0; }
    done
    return 1
}
_is_mounted() { grep -q "^[^ ]* $1 " /proc/mounts 2>/dev/null; }

# FIX-K: BusyBox 兼容的 timeout 封装
_timeout() {
    __tt="$1"; shift
    if command -v timeout >/dev/null 2>&1; then
        # 检测 BusyBox timeout 是否需要 -t 参数
        if timeout --help 2>&1 | grep -q '\-t'; then
            timeout -t "$__tt" "$@"
        else
            timeout "$__tt" "$@"
        fi
        return $?
    fi
    # 无 timeout 命令：后台 + sleep kill 模拟
    "$@" &
    __tp=$!
    ( sleep "$__tt"; kill "$__tp" 2>/dev/null ) &
    __kp=$!
    wait "$__tp" 2>/dev/null
    __tr=$?
    kill "$__kp" 2>/dev/null
    wait "$__kp" 2>/dev/null
    return $__tr
}

echo "=== 360 V6 状态 @ $(date '+%Y-%m-%d %H:%M:%S') ==="
echo "版本  : V3.3 STABLE"
echo ""

if [ -f /etc/install-extras-done ]; then
    echo "[OK] 基础环境：已完成 ($(cat /etc/install-extras-done 2>/dev/null))"
else
    echo "[..] 基础环境：待触发"
fi

if [ -f /etc/install-usb-done ]; then
    echo "[OK] 重型应用：已完成 ($(cat /etc/install-usb-done 2>/dev/null))"
    [ -f "$_SD/docker-done" ] && echo "     Docker : OK" || echo "     Docker : 未完成"
    if [ -f "$_SD/agh-done" ]; then
        echo "     AGH    : OK（已完成初始化）"
        if command -v curl >/dev/null 2>&1; then
            _stats=$(_timeout 3 curl -s http://127.0.0.1:3000/control/stats 2>/dev/null)
            [ -n "$_stats" ] && echo "     AGH统计: 总查询 $(echo "$_stats" | grep -o '"num_dns_queries":[0-9]*' | cut -d: -f2) 次"
        fi
    elif pgrep -f "AdGuardHome.*--config" >/dev/null 2>&1; then
        echo "     AGH    : 运行中（等待初始化向导）"
        echo "     请访问 http://192.168.2.1:3000 完成初始化"
    else
        echo "     AGH    : 未完成"
    fi
else
    echo "[..] 重型应用：待 U 盘"
fi

echo ""
df -h /overlay 2>/dev/null | awk 'NR==2{print "Flash : "$3" / "$2" ("$5")"}'
free 2>/dev/null | awk '/Mem:/{printf "Mem   : %dMB used / %dMB total\n",$3/1024,$2/1024}'
echo ""

_USB=$(_get_usb_mount)
[ -n "$_USB" ] && echo "USB   : $_USB (已挂载)" || echo "USB   : 未检测到"
[ -f /etc/install-usb-mount ] && echo "PATH  : $(cat /etc/install-usb-mount)"
grep -q swapfile /proc/swaps 2>/dev/null && echo "Swap  : swapfile 已激活"
echo ""

# FIX-M: 一次调用同时获取状态和版本，避免两次调用间 dockerd 可能退出
_dver=$(_timeout 4 docker info --format '{{.ServerVersion}}' 2>/dev/null)
if [ -n "$_dver" ]; then
    echo "[OK] Docker      : ${_dver}"
else
    echo "[--] Docker      : 未启动"
fi

# FIX-A: 用 pgrep 检测 AGH 进程，不依赖 pid 文件
if pgrep -f "AdGuardHome.*--config" >/dev/null 2>&1; then
    echo "[OK] AdGuardHome : 运行中"
else
    echo "[--] AdGuardHome : 未启动"
fi

echo ""
echo "AGH 管理: http://192.168.2.1:3000"
echo "健康检查: 360v6-health [--fix]"
echo "卸载    : 360v6-uninstall"
STATUSEOF

chmod +x /usr/bin/360v6-status

# ══════════════════════════════════════════════════════════════
# 模块 0b：360v6-health（V3.3）
# ══════════════════════════════════════════════════════════════
cat > /usr/bin/360v6-health << 'HEALTHEOF'
#!/bin/sh
# 健康检查工具，--fix 自动修复已知问题
_SD="/etc/install-state"
_fix=0
[ "$1" = "--fix" ] && _fix=1

_ok()   { echo "[OK]  $1"; }
_warn() { echo "[WARN] $1"; }
_err()  { echo "[ERR]  $1"; }
_fix()  { [ "$_fix" -eq 1 ] && { echo "[FIX]  $1"; eval "$2"; } || echo "[HINT] 修复: $2"; }

echo "=== 360 V6 健康检查 @ $(date '+%Y-%m-%d %H:%M:%S') ==="
[ "$_fix" -eq 1 ] && echo "（修复模式已启用）"
echo ""

_errs=0

# 1. Flash 空间
_flash_pct=$(df /overlay 2>/dev/null | awk 'NR==2{gsub(/%/,"",$5);print $5}')
if [ -n "$_flash_pct" ] && [ "$_flash_pct" -ge 90 ]; then
    _err "Flash 使用率 ${_flash_pct}%（>= 90%），有写满风险"
    _fix "清理 opkg/apk 缓存" "rm -rf /tmp/opkg-lists /var/cache/apk 2>/dev/null; opkg clean 2>/dev/null || true"
    _errs=$((_errs+1))
else
    _ok "Flash 使用率 ${_flash_pct:-?}%"
fi

# 2. Swap
if grep -q swapfile /proc/swaps 2>/dev/null; then
    _ok "Swap 已激活"
else
    _warn "Swap 未激活"
    _USB=""
    for _m in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        grep -q "^[^ ]* $_m " /proc/mounts 2>/dev/null && { _USB="$_m"; break; }
    done
    [ -n "$_USB" ] && [ -f "$_USB/swapfile" ] &&         _fix "激活 swapfile" "swapon '$_USB/swapfile' 2>/dev/null && echo 10 > /proc/sys/vm/swappiness"
fi

# 3. Docker
if [ -f "$_SD/docker-done" ]; then
    _dver=$(docker info --format '{{.ServerVersion}}' 2>/dev/null)
    if [ -n "$_dver" ]; then
        _ok "Docker 运行中（$_dver）"
    else
        _err "Docker 已安装但未运行"
        _fix "启动 dockerd" "/etc/init.d/dockerd start"
        _errs=$((_errs+1))
    fi
else
    _warn "Docker 未部署"
fi

# 4. AGH 进程
if pgrep -f "AdGuardHome.*--config" >/dev/null 2>&1; then
    _ok "AdGuardHome 进程运行中"
else
    if [ -f "$_SD/agh-done" ] || [ -f /etc/install-usb-done ]; then
        _err "AdGuardHome 未运行"
        _fix "启动 AGH" "/etc/init.d/adguardhome start"
        _errs=$((_errs+1))
    else
        _warn "AdGuardHome 未部署"
    fi
fi

# 5. DNS 冲突检测
_dnsmasq_port=$(uci get dhcp.@dnsmasq[0].port 2>/dev/null)
if [ -f "$_SD/agh-done" ]; then
    # AGH 已 finalize，dnsmasq 应禁用
    if [ "${_dnsmasq_port:-53}" != "0" ]; then
        _err "DNS 冲突：AGH 已 finalize 但 dnsmasq 仍监听（port=${_dnsmasq_port:-53}）"
        _fix "禁用 dnsmasq DNS 端口"             "uci set dhcp.@dnsmasq[0].port='0'; uci commit dhcp; /etc/init.d/dnsmasq reload"
        _errs=$((_errs+1))
    else
        _ok "DNS 分配正常（dnsmasq DNS 已禁用，AGH 接管）"
    fi
else
    _ok "DNS 分配正常（dnsmasq 提供 DNS，AGH 向导未完成）"
fi

# 6. AGH 端口 3000 可达性
if pgrep -f "AdGuardHome.*--config" >/dev/null 2>&1; then
    if command -v curl >/dev/null 2>&1; then
        _hc=$(curl -s -o /dev/null -w "%{http_code}" --max-time 3 http://127.0.0.1:3000/ 2>/dev/null)
        if [ "$_hc" = "200" ] || [ "$_hc" = "302" ] || [ "$_hc" = "301" ]; then
            _ok "AGH Web 端口 3000 可达（HTTP $_hc）"
        else
            _warn "AGH Web 端口 3000 响应异常（HTTP $_hc）"
        fi
    fi
fi

# 7. U 盘挂载
_USB=""
for _m in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
    grep -q "^[^ ]* $_m " /proc/mounts 2>/dev/null && { _USB="$_m"; break; }
done
if [ -n "$_USB" ]; then
    _ok "U 盘挂载于 $_USB"
    _usb_free=$(df -k "$_USB" 2>/dev/null | awk 'NR==2{print $4}')
    [ "${_usb_free:-0}" -lt 524288 ] &&         _warn "U 盘剩余空间不足 512MB（${_usb_free}KB）"
else
    [ -f /etc/install-usb-done ] && _warn "U 盘未挂载，Docker/AGH 可能无法运行"
fi

echo ""
if [ "$_errs" -eq 0 ]; then
    echo "健康检查完成，无异常"
else
    echo "发现 ${_errs} 个问题$([ "$_fix" -eq 0 ] && echo '，运行 360v6-health --fix 自动修复' || echo '（已尝试修复）')"
fi
HEALTHEOF
chmod +x /usr/bin/360v6-health

# ══════════════════════════════════════════════════════════════
# 模块 A：install-usb.sh（Phase 2 - V3.3）
# ══════════════════════════════════════════════════════════════
cat > /usr/lib/install-extras/install-usb.sh << 'USBEOF'
#!/bin/sh
_LT="usb-extras"
_DONE="/etc/install-usb-done"
_LOCK="/tmp/install-usb.lock"
_SD="/etc/install-state"
_MF="/etc/install-usb-mount"
_DNSMASQ_BACKUP="/etc/config/dhcp.agh-backup"

_DOCKER_VERS="28.1.0 27.5.1 26.1.4"
_DOCKER_BASE="https://download.docker.com/linux/static/stable/aarch64"
_AGH_URL="https://static.adguard.com/adguardhome/release/AdGuardHome_linux_arm64.tar.gz"

log() { __lm="[$(date '+%H:%M:%S')] $1"; echo "$__lm"; echo "$__lm" | logger -t "$_LT"; }
_is_mounted() { grep -q "^[^ ]* $1 " /proc/mounts 2>/dev/null; }
_get_usb_mount() {
    for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        _is_mounted "$_mp" && { echo "$_mp"; return 0; }
    done
    return 1
}

_is_usb_dev() {
    case "$1" in
        /dev/sd[a-z][0-9]*|/dev/mmcblk[0-9]*p[0-9]*) return 0 ;;
        *) return 1 ;;
    esac
}

# FIX-K: BusyBox 兼容的 timeout 封装（统一用此函数，不裸调 timeout）
_timeout() {
    __tt="$1"; shift
    if command -v timeout >/dev/null 2>&1; then
        if timeout --help 2>&1 | grep -q '\-t'; then
            timeout -t "$__tt" "$@"
        else
            timeout "$__tt" "$@"
        fi
        return $?
    fi
    "$@" &
    __tp=$!
    ( sleep "$__tt"; kill "$__tp" 2>/dev/null ) &
    __kp=$!
    wait "$__tp" 2>/dev/null
    __tr=$?
    kill "$__kp" 2>/dev/null
    wait "$__kp" 2>/dev/null
    return $__tr
}

_tar_extract() {
    __tgz="$1"; __dst="$2"; __subdir="$3"
    __tmp="${__dst}.xtmp$$"
    rm -rf "$__tmp"; mkdir -p "$__tmp" "$__dst"
    tar xzf "$__tgz" -C "$__tmp" 2>/dev/null || { rm -rf "$__tmp"; log "tar 解压失败: $__tgz"; return 1; }
    if [ -n "$__subdir" ] && [ -d "$__tmp/$__subdir" ]; then
        __src="$__tmp/$__subdir"
    else
        __src="$__tmp"
    fi
    for __f in "$__src/"*; do
        [ -e "$__f" ] || continue
        __bn="${__f##*/}"
        [ -d "$__dst/$__bn" ] && rm -rf "$__dst/$__bn"
        # FIX: 目标文件存在且只读时先强制删除
        [ -f "$__dst/$__bn" ] && rm -f "$__dst/$__bn"
        mv "$__f" "$__dst/" 2>/dev/null || { rm -rf "$__tmp"; return 1; }
    done
    rm -rf "$__tmp"
    return 0
}

mkdir -p "$_SD"
__self_heal=0; __force=0; __mp_arg=""
for _a in "$@"; do
    case "$_a" in
        --self-heal) __self_heal=1 ;;
        --force)     __force=1 ;;
        --*)         ;;
        *)           [ -z "$__mp_arg" ] && __mp_arg="$_a" ;;
    esac
done

# 自愈模式
if [ "$__self_heal" -eq 1 ]; then
    [ -f /etc/install-extras-done ] || exit 0
    [ -f "$_DONE" ] && exit 0
    # FIX-G: 冷却保护，两次自愈间隔 < 300s 则跳过
    __last_heal=$(cat "$_SD/last-self-heal" 2>/dev/null || echo 0)
    __now=$(date '+%s' 2>/dev/null || awk '{print int($1)}' /proc/uptime 2>/dev/null || echo 0)
    __elapsed=$((__now - __last_heal))
    if [ "$__elapsed" -lt 300 ]; then
        log "自愈冷却中（距上次 ${__elapsed}s < 300s），跳过"
        exit 0
    fi
    __dsf=$(cat "$_SD/docker-failures" 2>/dev/null || echo 0)
    __asf=$(cat "$_SD/agh-failures" 2>/dev/null || echo 0)
    [ "${__dsf:-0}" -ge 3 ] && [ "${__asf:-0}" -ge 3 ] && exit 0
    if [ -f "$_LOCK" ]; then
        __lp=$(cat "$_LOCK" 2>/dev/null)
        kill -0 "$__lp" 2>/dev/null && exit 0
        rm -f "$_LOCK"
    fi
    _USB=$(_get_usb_mount)
    if [ -n "$_USB" ]; then
        echo "$__now" > "$_SD/last-self-heal"
        log "自愈触发: $_USB"
        exec /usr/lib/install-extras/install-usb.sh "$_USB"
    fi
    exit 0
fi

[ -f "$_DONE" ] && { log "已完成，跳过"; exit 0; }

__dns_old=$(cat /etc/resolv.conf 2>/dev/null)
[ -z "$__dns_old" ] && __dns_old="nameserver 127.0.0.1"

_dns_restore() {
    rm -f "$_LOCK"
    printf '%s\n' "$__dns_old" > /etc/resolv.conf 2>/dev/null
    sync 2>/dev/null || true
}

# FIX-C: _dnsmasq_restore 检查 agh-done，已 finalize 则不回滚，防止破坏 DNS 配置
_dnsmasq_restore() {
    if [ -f "$_SD/agh-done" ]; then
        log "AGH 已 finalize，跳过 dnsmasq 回滚"
        return 0
    fi
    if [ -f "$_DNSMASQ_BACKUP" ]; then
        cp "$_DNSMASQ_BACKUP" /etc/config/dhcp 2>/dev/null
        /etc/init.d/dnsmasq restart >/dev/null 2>&1 || true
        log "dnsmasq 配置已回滚"
    fi
}
trap '_dns_restore; _dnsmasq_restore' EXIT INT TERM

if [ -f "$_LOCK" ]; then
    __lp=$(cat "$_LOCK" 2>/dev/null)
    kill -0 "$__lp" 2>/dev/null && { log "运行中 (pid=$__lp)，跳过"; exit 0; }
    rm -f "$_LOCK"
fi
echo $$ > "$_LOCK"

if [ "$__force" -eq 1 ]; then
    rm -f "$_SD/docker-failures" "$_SD/agh-failures" "$_SD/docker-done" "$_SD/agh-done"
    # 同时删除旧 AGH yaml：否则 AGH 会读取旧配置跳过向导，无法重新初始化
    rm -f /etc/adguardhome.yaml
    log "--force：失败计数、组件标记及 AGH 配置已清零"
fi

__docker_fail_count=$(cat "$_SD/docker-failures" 2>/dev/null || echo 0)
__agh_fail_count=$(cat "$_SD/agh-failures" 2>/dev/null || echo 0)

_USB=""
[ -n "$__mp_arg" ] && _is_mounted "$__mp_arg" && _USB="$__mp_arg"
if [ -z "$_USB" ]; then
    _USB=$(_get_usb_mount)
fi

if [ -z "$_USB" ]; then
    log "未找到 U 盘挂载点"
    exit 1
fi

__dev=$(awk -v mp="$_USB " '$0 ~ mp {print $1; exit}' /proc/mounts 2>/dev/null)
if ! _is_usb_dev "$__dev"; then
    log "设备 $__dev 不是 USB/SD 分区，跳过"
    exit 0
fi

echo "$_USB" > "$_MF"
log "重型应用部署 | U 盘: $_USB ($__dev)"

__usb_free=$(df -k "$_USB" 2>/dev/null | awk 'NR==2{print $4}')
if [ "${__usb_free:-0}" -lt 1048576 ]; then
    log "U 盘空间不足（${__usb_free}KB < 1GB）"
    exit 1
fi

printf 'nameserver 223.5.5.5\nnameserver 8.8.8.8\n' > /etc/resolv.conf
log "临时 DNS 已注入"

# ── Swapfile ──────────────────────────────────────────────────
__swapfile="$_USB/swapfile"
if ! grep -q swapfile /proc/swaps 2>/dev/null; then
    if [ ! -f "$__swapfile" ]; then
        log "创建 256MB swapfile..."
        if dd if=/dev/zero of="${__swapfile}.tmp" bs=1M count=256 2>/dev/null; then
            mv "${__swapfile}.tmp" "$__swapfile" && \
            chmod 600 "$__swapfile" && \
            mkswap "$__swapfile" >/dev/null 2>&1 || {
                rm -f "$__swapfile"
                log "swapfile 格式化失败，已清理"
            }
        else
            rm -f "${__swapfile}.tmp"
            log "swapfile 创建失败（空间不足？），已清理"
        fi
    fi
    if [ -f "$__swapfile" ] && swapon "$__swapfile" 2>/dev/null; then
        log "swapfile 已激活"
        # FIX-I: 激活 swap 后立即调整内存参数，防止 USB 慢速 swap 导致假死
        echo 10   > /proc/sys/vm/swappiness          2>/dev/null
        echo 8192 > /proc/sys/vm/min_free_kbytes     2>/dev/null
        echo 20   > /proc/sys/vm/dirty_ratio         2>/dev/null
        echo 10   > /proc/sys/vm/dirty_background_ratio 2>/dev/null
        log "内存参数已优化（swappiness=10）"
    fi
fi

__dl_dir="$_USB/.downloads"
mkdir -p "$__dl_dir"

# ══ Docker 部署 ═══════════════════════════════════════════════
_DOCKER_FAIL=0
log "--- Docker 部署 ---"
if [ -f "$_SD/docker-done" ]; then
    log "Docker 已完成（跳过）"
elif [ "${__docker_fail_count:-0}" -ge 3 ]; then
    log "Docker 失败次数过多（${__docker_fail_count}/3），跳过"
    _DOCKER_FAIL=1
else
    __dbin="$_USB/docker-bin"
    __ddata="$_USB/docker-data"
    mkdir -p "$__dbin" "$__ddata" /etc/docker
    __docker_ver=""
    for _dv in $_DOCKER_VERS; do
        __dtgz="$__dl_dir/docker-${_dv}.tgz"
        if [ ! -f "$__dtgz" ]; then
            log "下载 Docker ${_dv}..."
            wget -q --timeout=180 -O "${__dtgz}.tmp" "$_DOCKER_BASE/docker-${_dv}.tgz" 2>/dev/null
            __tsz=$(wc -c < "${__dtgz}.tmp" 2>/dev/null || echo 0)
            if [ "${__tsz:-0}" -lt 5242880 ]; then
                rm -f "${__dtgz}.tmp"
                log "Docker ${_dv} 下载失败或文件过小，尝试下一版本"
                continue
            fi
            mv "${__dtgz}.tmp" "$__dtgz"
        fi
        log "解压 Docker ${_dv}..."
        rm -rf "$__dbin"/* 2>/dev/null
        if _tar_extract "$__dtgz" "$__dbin" "docker"; then
            if [ -f "$__dbin/dockerd" ]; then
                __docker_ver="$_dv"
                break
            else
                # FIX-F: 解压成功但二进制不存在，说明 tgz 结构异常或损坏，删除缓存
                log "Docker ${_dv} tgz 结构异常，删除缓存"
                rm -f "$__dtgz"
            fi
        else
            # FIX-F: 解压失败，删除损坏的 tgz，下次重新下载
            log "Docker ${_dv} 解压失败，删除缓存"
            rm -f "$__dtgz"
        fi
    done
    [ -z "$__docker_ver" ] && _DOCKER_FAIL=1
    if [ "$_DOCKER_FAIL" -eq 0 ]; then
        for _b in docker dockerd containerd containerd-shim-runc-v2 ctr runc docker-proxy docker-init; do
            [ -f "$__dbin/$_b" ] && ln -sf "$__dbin/$_b" "/usr/bin/$_b" 2>/dev/null
        done

        # FIX-D: 检测 overlay2 内核模块可用性，不可用则降级 vfs
        __storage_driver="overlay2"
        if ! modinfo overlay >/dev/null 2>&1 && ! grep -q overlay /proc/filesystems 2>/dev/null; then
            log "overlay2 模块不可用，降级使用 vfs（性能较低但兼容性 100%）"
            __storage_driver="vfs"
        fi

        cat > /etc/docker/daemon.json << DOCKEREOF
{
  "data-root": "$__ddata",
  "storage-driver": "$__storage_driver",
  "log-driver": "json-file",
  "log-opts": {"max-size": "5m", "max-file": "2"},
  "registry-mirrors": ["https://docker.m.daocloud.io", "https://docker.nju.edu.cn"]
}
DOCKEREOF
        log "Docker daemon.json 已写入（storage-driver: $__storage_driver）"

        # FIX-E + FIX-L: init.d 中幂等挂载 cgroup2，检查已挂载则跳过
        cat > /etc/init.d/dockerd << 'DINITEOF'
#!/bin/sh /etc/rc.common
START=99; STOP=10; USE_PROCD=1
start_service() {
    [ -f /etc/install-state/docker-done ] || return 1
    _mp=$(cat /etc/install-usb-mount 2>/dev/null)
    [ -n "$_mp" ] && [ -f "$_mp/docker-bin/dockerd" ] || return 1
    # FIX-L: 幂等挂载 cgroup2，已挂载则跳过，避免叠加挂载
    if ! grep -q "^[^ ]* /sys/fs/cgroup cgroup2" /proc/mounts 2>/dev/null; then
        mount -t cgroup2 none /sys/fs/cgroup 2>/dev/null || true
    fi
    procd_open_instance
    procd_set_param command "$_mp/docker-bin/dockerd" --config-file /etc/docker/daemon.json
    procd_set_param stdout 1; procd_set_param stderr 1; procd_set_param respawn 3600 5 0
    procd_close_instance
}
stop_service() { pkill dockerd 2>/dev/null || true; pkill containerd 2>/dev/null || true; }
DINITEOF
        chmod +x /etc/init.d/dockerd
        /etc/init.d/dockerd enable 2>/dev/null

        # FIX-L: 安装阶段挂载 cgroup2，同样幂等检查
        if ! grep -q "^[^ ]* /sys/fs/cgroup cgroup2" /proc/mounts 2>/dev/null; then
            mount -t cgroup2 none /sys/fs/cgroup 2>/dev/null || true
        fi

        /etc/init.d/dockerd start 2>/dev/null
        sleep 5
        # FIX-K: 用 _timeout 封装，兼容 BusyBox timeout
        _timeout 5 docker info >/dev/null 2>&1 && log "Docker $__docker_ver 已启动" || log "Docker 后台初始化中"
        date '+%Y-%m-%d %H:%M:%S' > "$_SD/docker-done"
        rm -f "$_SD/docker-failures"
    else
        echo $((__docker_fail_count + 1)) > "$_SD/docker-failures"
    fi
fi

# ══ AdGuardHome 部署（V3.3）══════════════════════════════════
_AGH_FAIL=0
log "--- AdGuardHome 部署 ---"

if [ -f "$_SD/agh-done" ]; then
    log "AdGuardHome 已完成（跳过）"
elif [ "${__agh_fail_count:-0}" -ge 3 ]; then
    log "AGH 失败次数过多（${__agh_fail_count}/3），跳过"
    _AGH_FAIL=1
else
    __abin="$_USB/adguardhome-bin"
    __adata="$_USB/AdGuardHome/data"
    mkdir -p "$__abin" "$__adata"

    __atgz="$__dl_dir/AdGuardHome_linux_arm64.tar.gz"
    if [ ! -f "$__abin/AdGuardHome" ]; then
        if [ ! -f "$__atgz" ]; then
            log "下载 AdGuardHome..."
            wget -q --timeout=180 -O "${__atgz}.tmp" "$_AGH_URL" 2>/dev/null
            __asz=$(wc -c < "${__atgz}.tmp" 2>/dev/null || echo 0)
            if [ "${__asz:-0}" -lt 10485760 ]; then
                rm -f "${__atgz}.tmp"
                log "AGH 下载失败或文件过小（${__asz}B < 10MB）"
                _AGH_FAIL=1
            else
                mv "${__atgz}.tmp" "$__atgz"
            fi
        fi
        if [ "$_AGH_FAIL" -eq 0 ] && [ -f "$__atgz" ]; then
            log "解压 AdGuardHome..."
            if _tar_extract "$__atgz" "$__abin" "AdGuardHome"; then
                if [ -f "$__abin/AdGuardHome" ]; then
                    chmod +x "$__abin/AdGuardHome"
                    log "AdGuardHome 二进制就绪"
                else
                    # FIX-F: 解压后二进制不存在，删缓存
                    log "AGH tgz 结构异常，删除缓存"
                    rm -f "$__atgz"
                    _AGH_FAIL=1
                fi
            else
                log "AGH 解压失败，删除缓存"
                rm -f "$__atgz"
                _AGH_FAIL=1
            fi
        fi
    fi

    if [ "$_AGH_FAIL" -eq 0 ] && [ -f "$__abin/AdGuardHome" ]; then
        ln -sf "$__abin/AdGuardHome" /usr/bin/AdGuardHome 2>/dev/null

        # 备份 dnsmasq 配置（供向导完成后禁用时回滚用）
        if [ ! -f "$_DNSMASQ_BACKUP" ]; then
            cp /etc/config/dhcp "$_DNSMASQ_BACKUP" 2>/dev/null
        fi

        # FIX-A: 移除 --pidfile 参数（AGH 不支持，会导致进程立即退出）
        # FIX-B: service_started() 是 procd 死代码，dnsmasq 禁用逻辑移至后台子进程
        cat > /etc/init.d/adguardhome << 'AINITEOF'
#!/bin/sh /etc/rc.common
START=98; STOP=10; USE_PROCD=1

start_service() {
    _mp=$(cat /etc/install-usb-mount 2>/dev/null)
    [ -f "$_mp/adguardhome-bin/AdGuardHome" ] || return 1
    # 向导已完成（agh-done 存在）时，必须先释放 53 端口再启动 AGH
    # 否则 AGH 绑定 53 失败后立即退出，procd respawn 无限循环
    if [ -f /etc/install-state/agh-done ]; then
        uci set dhcp.@dnsmasq[0].port='0' 2>/dev/null
        uci commit dhcp 2>/dev/null
        /etc/init.d/dnsmasq reload >/dev/null 2>&1 || true
        logger -t "adguardhome" "dnsmasq DNS 端口已释放，AGH 准备接管"
    fi
    procd_open_instance
    procd_set_param command "$_mp/adguardhome-bin/AdGuardHome" \
        --config /etc/adguardhome.yaml \
        --work-dir "$_mp/AdGuardHome/data" \
        --no-check-update
    procd_set_param stdout 1; procd_set_param stderr 1; procd_set_param respawn 3600 5 0
    procd_close_instance
}

stop_service() {
    pkill -f "AdGuardHome.*--config" 2>/dev/null || true
}
AINITEOF
        chmod +x /etc/init.d/adguardhome
        /etc/init.d/adguardhome enable 2>/dev/null
        /etc/init.d/adguardhome start 2>/dev/null

        # FIX-A: 等待 AGH 进程启动（最多 15 秒），用 pgrep 检测，不依赖 pid 文件
        __agh_up=0
        __wi=0
        while [ "$__wi" -lt 15 ]; do
            if pgrep -f "AdGuardHome.*--config" >/dev/null 2>&1; then
                __agh_up=1; break
            fi
            sleep 1; __wi=$((__wi + 1))
        done

        if [ "$__agh_up" -eq 1 ]; then
            log "AdGuardHome 进程已启动"
            log ">>> 请访问 http://192.168.2.1:3000 完成初始化向导 <<<"
            log "    向导完成后执行: agh-finalize  （完成 DNS 接管）"

            # FIX-H: agh-finalize 改用 API 检测向导完成，不依赖 yaml 内容格式
            # agh-finalize：向导完成后由用户手动执行一次，需传入管理员凭据
            cat > /usr/bin/agh-finalize << 'FINALEOF'
#!/bin/sh
# 在 AGH 初始化向导完成后执行此命令，完成 DNS 接管和状态标记
# 用法：agh-finalize <用户名> <密码>
_SD="/etc/install-state"
_DNSMASQ_BACKUP="/etc/config/dhcp.agh-backup"

_user="${1:-}"
_pass="${2:-}"

if [ -z "$_user" ] || [ -z "$_pass" ]; then
    echo "用法: agh-finalize <用户名> <密码>"
    echo "      用户名和密码为 AGH 向导中设置的管理员账户"
    exit 1
fi

if ! command -v curl >/dev/null 2>&1; then
    echo "[ERR] 需要 curl"
    exit 1
fi

if ! pgrep -f "AdGuardHome.*--config" >/dev/null 2>&1; then
    echo "[ERR] AGH 进程未运行"
    exit 1
fi

echo "[..] 验证 AGH 登录凭据..."
# 向导完成后 /control/status 需要 Basic Auth
# -L 跟随重定向：向导未完成时会 302 到 /install.html
_http_code=$(curl -s -o /tmp/agh-resp.tmp -w "%{http_code}" \
    --max-time 5 -L \
    -u "${_user}:${_pass}" \
    http://127.0.0.1:3000/control/status 2>/dev/null)

# 被重定向到向导页（响应体含 install）
if grep -qi "install" /tmp/agh-resp.tmp 2>/dev/null; then
    rm -f /tmp/agh-resp.tmp
    echo "[ERR] AGH 向导尚未完成，请先访问 http://192.168.2.1:3000 完成初始化"
    exit 1
fi
rm -f /tmp/agh-resp.tmp

if [ "$_http_code" = "401" ] || [ "$_http_code" = "403" ]; then
    echo "[ERR] 用户名或密码错误（HTTP $_http_code）"
    exit 1
fi

if [ "$_http_code" != "200" ]; then
    echo "[ERR] AGH 响应异常（HTTP $_http_code）"
    exit 1
fi

echo "[OK] AGH 登录验证成功，开始接管 DNS..."

# 禁用 dnsmasq DNS 端口
uci set dhcp.@dnsmasq[0].port='0' 2>/dev/null
uci commit dhcp 2>/dev/null
/etc/init.d/dnsmasq reload >/dev/null 2>&1 || true
echo "[OK] dnsmasq DNS 端口已禁用"

# 写入完成标记
date '+%Y-%m-%d %H:%M:%S' > "$_SD/agh-done"
echo "[OK] agh-done 标记已写入"

# 注册日志清理 cron（每周日 03:00）
__cron_job='0 3 * * 0 _MP=$(cat /etc/install-usb-mount 2>/dev/null); [ -n "$_MP" ] && find "$_MP/AdGuardHome/data/logs" -name "*.log" -mtime +30 -delete 2>/dev/null'
if ! grep -qF "AdGuardHome/data/logs" /etc/crontabs/root 2>/dev/null; then
    echo "$__cron_job" >> /etc/crontabs/root
    /etc/init.d/cron restart >/dev/null 2>&1 || true
    echo "[OK] AGH 日志清理 cron 已注册"
fi

echo "[OK] 完成！AGH 已全面接管 DNS"
echo "     状态查看: 360v6-status"
FINALEOF
            chmod +x /usr/bin/agh-finalize
            rm -f "$_SD/agh-failures"
        else
            log "AdGuardHome 进程启动失败"
            _AGH_FAIL=1
        fi
    else
        _AGH_FAIL=1
    fi

    if [ "$_AGH_FAIL" -eq 1 ]; then
        echo $((__agh_fail_count + 1)) > "$_SD/agh-failures"
    fi
fi

rm -f /tmp/luci-indexcache* 2>/dev/null
/etc/init.d/rpcd reload 2>/dev/null || true

# ── 最终判定 ──────────────────────────────────────────────────
if [ "$_DOCKER_FAIL" -eq 0 ] && [ "$_AGH_FAIL" -eq 0 ]; then
    date '+%Y-%m-%d %H:%M:%S' > "$_DONE"
    log "重型应用完成 [Docker:OK AGH:OK]"
    log ">>> 请访问 http://192.168.2.1:3000 完成 AGH 初始化向导 <<<"
    log "    向导完成后执行: agh-finalize"
    exit 0
elif [ "$_DOCKER_FAIL" -eq 0 ] || [ "$_AGH_FAIL" -eq 0 ]; then
    log "重型应用部分完成 [Docker:$([ "$_DOCKER_FAIL" -eq 0 ] && echo OK || echo FAIL) AGH:$([ "$_AGH_FAIL" -eq 0 ] && echo OK || echo FAIL)]"
    exit 2
else
    log "重型应用全部失败"
    exit 1
fi
USBEOF
chmod +x /usr/lib/install-extras/install-usb.sh

