#!/bin/sh
# 96-install-extras [v1]
# 适用：360 V6 / 小米 CR660x / IPQ6000 (128M Flash / ImmortalWrt / busybox ash)
#
# 修复清单（相对 v12）：
#   1. AGH 二进制提取路径逻辑修正
#   2. 格式化 U 盘后重新创建必要目录
#   3. Phase 2 热插拔触发不再强制清零失败计数
#   4. apk update 成功判断改用退出码
#   5. 卸载脚本补全残留文件清理
#   6. read 加 -r 防反斜杠解析
#   7. _svc_check 逻辑修正（移除无效重试）
#   8. 去除重复 Flash 读取

_STATE_DIR="/etc/install-state"
mkdir -p "$_STATE_DIR" /usr/lib/install-extras /usr/bin \
         /etc/hotplug.d/iface /etc/hotplug.d/block \
         /etc/dbus-1 /etc/dbus-1/system.d /etc/crontabs

# ====================================================================
# 预置系统级修复（avahi + nlbwmon）
# ====================================================================

cat > /etc/dbus-1/system.d/avahi-dbus.conf << 'DBUSEOF'
<!DOCTYPE busconfig PUBLIC "-//freedesktop//DTD D-BUS Bus Configuration 1.0//EN"
 "http://www.freedesktop.org/standards/dbus/1.0/busconfig.dtd">
<busconfig>
  <policy user="avahi">
    <allow own="org.freedesktop.Avahi"/>
    <allow send_destination="org.freedesktop.Avahi"/>
    <allow receive_sender="org.freedesktop.Avahi"/>
  </policy>
  <policy context="default">
    <allow send_destination="org.freedesktop.Avahi"/>
    <allow receive_sender="org.freedesktop.Avahi"/>
  </policy>
</busconfig>
DBUSEOF
chmod 644 /etc/dbus-1/system.d/avahi-dbus.conf

echo "1048576" > /proc/sys/net/core/rmem_max 2>/dev/null
echo "1048576" > /proc/sys/net/core/wmem_max 2>/dev/null

# ====================================================================
# 模块 0：360v6-status
# ====================================================================
cat > /usr/bin/360v6-status << 'STATUSEOF'
#!/bin/sh
_SD="/etc/install-state"
_is_mounted() { grep -q "^[^ ]* $1 " /proc/mounts 2>/dev/null; }

echo "=== 360 V6 状态 @ $(date '+%Y-%m-%d %H:%M:%S') ==="
echo ""

if [ -f /etc/install-extras-done ]; then
    echo "[OK] 基础环境：已完成 ($(cat /etc/install-extras-done 2>/dev/null))"
else
    echo "[..] 基础环境：待触发"
    _p1=$(cat "$_SD/phase1-failures" 2>/dev/null || echo 0)
    [ "$_p1" -gt 0 ] && echo "     失败次数: $_p1/3"
fi

if [ -f /etc/install-usb-done ]; then
    echo "[OK] 重型应用：已完成 ($(cat /etc/install-usb-done 2>/dev/null))"
else
    echo "[..] 重型应用：待 U 盘"
    _p2=$(cat "$_SD/phase2-failures" 2>/dev/null || echo 0)
    [ "$_p2" -gt 0 ] && echo "     失败次数: $_p2/3"
fi

echo ""
df -h /overlay 2>/dev/null | awk 'NR==2{print "Flash : "$3" / "$2" ("$5")"}'
free 2>/dev/null | awk '/Mem:/{printf "Mem   : %dMB used / %dMB total\n",$3/1024,$2/1024}'
echo ""

_USB=""
for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
    _is_mounted "$_mp" && { echo "USB   : $_mp (已挂载)"; _USB="$_mp"; break; }
done
[ -z "$_USB" ] && echo "USB   : 未检测到"
[ -f /etc/install-usb-mount ] && echo "PATH  : $(cat /etc/install-usb-mount)"
grep -q swapfile /proc/swaps 2>/dev/null && echo "Swap  : swapfile 已激活"
grep -q zram     /proc/swaps 2>/dev/null && echo "Swap  : zram 已激活"
echo ""

if docker info >/dev/null 2>&1; then
    _dv=$(docker version --format '{{.Server.Version}}' 2>/dev/null)
    echo "[OK] Docker      : ${_dv:-运行中}"
else
    echo "[--] Docker      : 未启动"
fi

if pgrep -x AdGuardHome >/dev/null 2>&1; then
    _av=$(AdGuardHome --version 2>&1 | grep -oE 'v[0-9.]+' | head -1)
    echo "[OK] AdGuardHome : ${_av:-运行中}"
else
    echo "[--] AdGuardHome : 未启动"
fi

echo ""
echo "重跑基础: rm -f /etc/install-extras-done $_SD/phase1-failures && /usr/lib/install-extras/run.sh"
echo "重跑重型: rm -f /etc/install-usb-done $_SD/phase2-failures && /usr/lib/install-extras/install-usb.sh --force"
echo "健康检查: 360v6-health [--fix]"
echo "卸载    : 360v6-uninstall"
STATUSEOF
chmod +x /usr/bin/360v6-status

# ====================================================================
# 模块 A：install-usb.sh（Phase 2）
# ====================================================================
cat > /usr/lib/install-extras/install-usb.sh << 'USBEOF'
#!/bin/sh
_LT="usb-extras"
_DONE="/etc/install-usb-done"
_LOCK="/tmp/install-usb.lock"
_SD="/etc/install-state"
_MF="/etc/install-usb-mount"

_DOCKER_VERS="28.1.0 28.0.4 27.5.1 26.1.4 25.0.5 24.0.7"
_DOCKER_BASE="https://download.docker.com/linux/static/stable/aarch64"
_AGH_URL="https://static.adguard.com/adguardhome/release/AdGuardHome_linux_arm64.tar.gz"

log() { __lm="[$(date '+%H:%M:%S')] $1"; echo "$__lm"; echo "$__lm" | logger -t "$_LT"; }
_is_mounted() { grep -q "^[^ ]* $1 " /proc/mounts 2>/dev/null; }
_is_usb_dev() {
    case "$1" in
        /dev/sd[a-z]*|/dev/mmcblk[0-9]*) return 0 ;;
        *) return 1 ;;
    esac
}

mkdir -p "$_SD"
__self_heal=0; __force=0; __mp_arg=""
for _a in "$@"; do
    case "$_a" in
        --self-heal) __self_heal=1 ;;
        --force)     __force=1 ;;
        --*)         ;;
        *)           [ -z "$__mp_arg" ] && __mp_arg="$_a" ;;
    esac
done

# 自愈模式：不传 --force，保留失败计数保护
if [ "$__self_heal" -eq 1 ]; then
    [ -f /etc/install-extras-done ] || exit 0
    [ -f "$_DONE" ] && exit 0
    __sf=$(cat "$_SD/phase2-failures" 2>/dev/null || echo 0)
    [ "${__sf:-0}" -ge 3 ] && exit 0
    if [ -f "$_LOCK" ]; then
        __lp=$(cat "$_LOCK" 2>/dev/null)
        kill -0 "$__lp" 2>/dev/null && exit 0
        rm -f "$_LOCK"
    fi
    for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        _is_mounted "$_mp" && { log "自愈触发: $_mp"; exec /usr/lib/install-extras/install-usb.sh "$_mp"; }
    done
    exit 0
fi

[ -f "$_DONE" ] && { log "已完成，跳过"; exit 0; }

__dns_old=$(cat /etc/resolv.conf 2>/dev/null)
[ -z "$__dns_old" ] && __dns_old="nameserver 127.0.0.1"
_dns_restore() {
    printf '%s' "$__dns_old" > /etc/resolv.conf
    /etc/init.d/dnsmasq reload >/dev/null 2>&1 || true
}
trap 'rm -f "$_LOCK"; _dns_restore' EXIT INT TERM

if [ -f "$_LOCK" ]; then
    __lp=$(cat "$_LOCK" 2>/dev/null)
    kill -0 "$__lp" 2>/dev/null && { log "运行中 (pid=$__lp)，跳过"; exit 0; }
    rm -f "$_LOCK"
fi
echo $$ > "$_LOCK"

# 失败计数（--force 清零，允许重跑）
if [ "$__force" -eq 1 ]; then
    rm -f "$_SD/phase2-failures"; __fail=0
    log "--force：失败计数已清零"
else
    __fail=$(cat "$_SD/phase2-failures" 2>/dev/null || echo 0)
    [ "${__fail:-0}" -ge 3 ] && {
        log "失败次数过多（$__fail/3），停止自动重试"
        log "手动修复: rm -f /etc/install-usb-done $_SD/phase2-failures && $0 --force"
        exit 1
    }
fi

# 挂载点检测
_USB=""
[ -n "$__mp_arg" ] && _is_mounted "$__mp_arg" && _USB="$__mp_arg"
if [ -z "$_USB" ]; then
    for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        _is_mounted "$_mp" && { _USB="$_mp"; break; }
    done
fi
[ -z "$_USB" ] && \
    _USB=$(awk '/^\/dev\/(sd[a-z][0-9]*|mmcblk[0-9]p?[0-9]*) /{print $2; exit}' /proc/mounts 2>/dev/null)

if [ -z "$_USB" ]; then
    log "未找到 U 盘挂载点"
    echo $((__fail + 1)) > "$_SD/phase2-failures"
    exit 1
fi

# 确认是 USB/SD 设备
__dev=$(awk -v mp="$_USB " '$0 ~ mp {print $1; exit}' /proc/mounts 2>/dev/null)
if ! _is_usb_dev "$__dev"; then
    log "设备 $__dev 不是 USB/SD，跳过"
    exit 0
fi

echo "$_USB" > "$_MF"
log "重型应用部署 | U 盘: $_USB ($__dev)"

# 空间预检
__usb_free=$(df -k "$_USB" 2>/dev/null | awk 'NR==2{print $4}')
if [ "${__usb_free:-0}" -lt 1048576 ]; then
    log "U 盘空间不足（${__usb_free}KB < 1GB）"
    echo $((__fail + 1)) > "$_SD/phase2-failures"
    exit 1
fi

# 写入健康检查
__wtest="$_USB/.write-test-$$"
if ! echo "ok" > "$__wtest" 2>/dev/null; then
    log "U 盘写入失败（只读？）"
    echo $((__fail + 1)) > "$_SD/phase2-failures"
    exit 1
fi
rm -f "$__wtest"

printf 'nameserver 223.5.5.5\nnameserver 8.8.8.8\n' > /etc/resolv.conf
log "临时 DNS 已注入"

# I/O 调度优化
__udev=$(echo "$__dev" | sed 's|/dev/||;s|[0-9]*$||')
__sched="/sys/block/${__udev}/queue/scheduler"
if [ -f "$__sched" ]; then
    grep -q "mq-deadline" "$__sched" 2>/dev/null \
        && echo "mq-deadline" > "$__sched" 2>/dev/null \
        || echo "deadline"    > "$__sched" 2>/dev/null
    log "I/O 调度器: $(grep -oE '\[[^]]+\]' "$__sched" 2>/dev/null | tr -d '[]')"
fi
echo "10"    > /proc/sys/vm/swappiness       2>/dev/null
echo "16384" > /proc/sys/vm/min_free_kbytes  2>/dev/null

# Flash 空间判断（一次性读取）
__flash_free=$(df /overlay 2>/dev/null | awk 'NR==2{print $4}')
__skip_luci=0
[ "${__flash_free:-99999}" -lt 25000 ] && __skip_luci=1 && log "Flash <25MB，跳过 LuCI 插件"

__dl_dir="$_USB/.downloads"; mkdir -p "$__dl_dir"

# 下载函数
_download() {
    __url="$1"; __out="$2"; __desc="$3"
    __i=1
    while [ "$__i" -le 3 ]; do
        log "下载 $__desc（$__i/3）..."
        wget -q --timeout=120 --tries=1 -O "${__out}.tmp" "$__url" 2>/dev/null \
            && mv "${__out}.tmp" "$__out" \
            && { log "下载完成: $__desc"; return 0; }
        rm -f "${__out}.tmp"
        log "下载失败: $__desc ($__i/3)"
        __i=$((__i + 1)); sleep 5
    done
    log "下载彻底失败: $__desc"
    return 1
}

# ========== Swap ==========
__swapfile="$_USB/swapfile"
if ! grep -q swapfile /proc/swaps 2>/dev/null; then
    if [ ! -f "$__swapfile" ]; then
        log "创建 256MB swapfile..."
        if dd if=/dev/zero of="${__swapfile}.tmp" bs=1M count=256 2>/dev/null; then
            mv "${__swapfile}.tmp" "$__swapfile"
            sync; chmod 600 "$__swapfile"
            mkswap "$__swapfile" >/dev/null 2>&1
        else
            rm -f "${__swapfile}.tmp"
            log "swapfile 创建失败"
        fi
    fi
    if [ -f "$__swapfile" ]; then
        swapon "$__swapfile" 2>/dev/null && log "swapfile 已激活"
        grep -qF "$__swapfile" /etc/fstab 2>/dev/null \
            || echo "$__swapfile none swap sw 0 0" >> /etc/fstab
    fi
fi

# ========== Docker ==========
_DOCKER_FAIL=0
log "--- Docker 部署 ---"

__fs_type=$(awk -v mp="$_USB" '$2==mp {print $3; exit}' /proc/mounts 2>/dev/null)
case "$__fs_type" in
    ext4) ;;
    ext[23]|f2fs) log "⚠ 文件系统: $__fs_type（建议 ext4）" ;;
    *)
        if [ "$__force" -eq 1 ]; then
            log "⚠ 自动格式化 $__dev 为 ext4..."
            umount "$_USB" 2>/dev/null
            if mkfs.ext4 -F "$__dev" >/dev/null 2>&1 && mount "$__dev" "$_USB"; then
                log "格式化并重新挂载完成"
                # 格式化后重建必要目录
                mkdir -p "$__dl_dir"
                __fs_type="ext4"
            else
                log "格式化或重挂载失败"
                _DOCKER_FAIL=1
            fi
        else
            log "Docker 需要 ext4（当前: ${__fs_type:-未知}），使用 --force 自动格式化"
            _DOCKER_FAIL=1
        fi
        ;;
esac

__docker_ver=""; __dtgz=""
__dbin="$_USB/docker-bin"; __ddata="$_USB/docker-data"

if [ "$_DOCKER_FAIL" -eq 0 ]; then
    mkdir -p "$__dbin" "$__ddata" /etc/docker
    for _dv in $_DOCKER_VERS; do
        __dtgz_try="$__dl_dir/docker-${_dv}.tgz"
        # 验证缓存完整性
        if [ -f "$__dtgz_try" ] && tar -tzf "$__dtgz_try" >/dev/null 2>&1; then
            log "使用缓存: docker-${_dv}.tgz"
            __docker_ver="$_dv"; __dtgz="$__dtgz_try"; break
        fi
        rm -f "$__dtgz_try"
        log "尝试 Docker ${_dv}..."
        if wget -q --timeout=120 -O "${__dtgz_try}.tmp" \
               "$_DOCKER_BASE/docker-${_dv}.tgz" 2>/dev/null \
            && mv "${__dtgz_try}.tmp" "$__dtgz_try" \
            && tar -tzf "$__dtgz_try" >/dev/null 2>&1; then
            log "Docker ${_dv} 下载成功"
            __docker_ver="$_dv"; __dtgz="$__dtgz_try"; break
        fi
        rm -f "${__dtgz_try}.tmp" "$__dtgz_try"
    done
    [ -z "$__docker_ver" ] && { log "所有 Docker 版本均失败"; _DOCKER_FAIL=1; }
fi

if [ "$_DOCKER_FAIL" -eq 0 ]; then
    tar -xzf "$__dtgz" -C "$__dbin" --strip-components=1 2>/dev/null
    [ -f "$__dbin/dockerd" ] || { log "解压验证失败"; rm -f "$__dtgz"; _DOCKER_FAIL=1; }
fi

if [ "$_DOCKER_FAIL" -eq 0 ]; then
    for _b in docker dockerd containerd containerd-shim-runc-v2 ctr runc; do
        [ -f "$__dbin/$_b" ] && ln -sf "$__dbin/$_b" "/usr/bin/$_b" 2>/dev/null
    done

    cat > /etc/docker/daemon.json << DOCKEREOF
{
  "data-root": "$__ddata",
  "storage-driver": "overlay2",
  "log-driver": "json-file",
  "log-opts": {"max-size": "5m", "max-file": "2"}
}
DOCKEREOF

    cat > /etc/init.d/dockerd << 'DINITEOF'
#!/bin/sh /etc/rc.common
START=99; STOP=10; USE_PROCD=1
start_service() {
    [ -f /etc/install-usb-done ] || return 0
    _mp=$(cat /etc/install-usb-mount 2>/dev/null)
    [ -n "$_mp" ] && [ -f "$_mp/docker-bin/dockerd" ] || return 1
    grep -q "^[^ ]* /sys/fs/cgroup " /proc/mounts 2>/dev/null \
        || mount -t cgroup2 none /sys/fs/cgroup 2>/dev/null || true
    procd_open_instance
    procd_set_param command "$_mp/docker-bin/dockerd" --config-file /etc/docker/daemon.json
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param respawn 3600 5 0
    procd_close_instance
}
stop_service() {
    pkill dockerd     2>/dev/null || true
    pkill containerd  2>/dev/null || true
}
DINITEOF
    chmod +x /etc/init.d/dockerd
    /etc/init.d/dockerd enable 2>/dev/null
    /etc/init.d/dockerd start  2>/dev/null
    sleep 3
    docker info >/dev/null 2>&1 \
        && log "Docker $__docker_ver 已启动" \
        || log "Docker 启动超时（后台可能仍在初始化）"

    [ "$__skip_luci" -eq 0 ] && \
        apk add --no-cache luci-app-dockerman luci-i18n-dockerman-zh-cn 2>/dev/null && \
        log "luci-app-dockerman 安装完成"
fi

# ========== AdGuardHome ==========
_AGH_FAIL=0
log "--- AdGuardHome 部署 ---"

__atgz="$__dl_dir/AdGuardHome_linux_arm64.tar.gz"
__abin="$_USB/adguardhome-bin"
__aconf="$_USB/AdGuardHome/config"
__adata="$_USB/AdGuardHome/data"
mkdir -p "$__abin" "$__aconf" "$__adata"

# 验证缓存完整性
if [ -f "$__atgz" ] && ! tar -tzf "$__atgz" >/dev/null 2>&1; then
    rm -f "$__atgz"
fi
if [ ! -f "$__atgz" ]; then
    _download "$_AGH_URL" "$__atgz" "AdGuardHome" || { _AGH_FAIL=1; rm -f "$__atgz"; }
fi

if [ "$_AGH_FAIL" -eq 0 ] && [ -f "$__atgz" ]; then
    # tar 解压后结构：AdGuardHome/AdGuardHome（二进制）
    # 目标：$__abin/AdGuardHome（直接可执行文件）
    tar -xzf "$__atgz" -C "$__abin" --strip-components=2 \
        AdGuardHome/AdGuardHome 2>/dev/null
    if [ ! -f "$__abin/AdGuardHome" ]; then
        # 兼容旧版 tar 不支持 --strip+路径，回退方案
        tar -xzf "$__atgz" -C "$__abin" 2>/dev/null
        __found=$(find "$__abin" -name "AdGuardHome" -type f 2>/dev/null | head -1)
        if [ -n "$__found" ] && [ "$__found" != "$__abin/AdGuardHome" ]; then
            mv "$__found" "$__abin/AdGuardHome"
            rm -rf "$__abin/AdGuardHome" 2>/dev/null   # 清理可能残留的同名目录
        fi
    fi
    if [ ! -f "$__abin/AdGuardHome" ]; then
        log "AGH 二进制提取失败"
        rm -f "$__atgz"; _AGH_FAIL=1
    else
        chmod +x "$__abin/AdGuardHome"
        ln -sf "$__abin/AdGuardHome" /usr/bin/AdGuardHome 2>/dev/null
    fi
fi

if [ "$_AGH_FAIL" -eq 0 ]; then
    /etc/init.d/adguardhome stop 2>/dev/null || true

    # 迁移旧配置
    [ ! -f "$__aconf/AdGuardHome.yaml" ] && [ -f "/etc/adguardhome/AdGuardHome.yaml" ] && \
        cp -a /etc/adguardhome/. "$__aconf/" 2>/dev/null && log "AGH 配置已迁移"
    [ -z "$(ls -A "$__adata" 2>/dev/null)" ] && [ -d "/var/lib/adguardhome" ] && \
        cp -a /var/lib/adguardhome/. "$__adata/" 2>/dev/null && log "AGH 数据已迁移"

    cat > /etc/init.d/adguardhome << 'AINITEOF'
#!/bin/sh /etc/rc.common
START=98; STOP=10; USE_PROCD=1
start_service() {
    [ -f /etc/install-usb-done ] || return 0
    _mp=$(cat /etc/install-usb-mount 2>/dev/null)
    [ -f "$_mp/adguardhome-bin/AdGuardHome" ] || return 1
    _config="$_mp/AdGuardHome/config/AdGuardHome.yaml"
    if [ -f "$_config" ]; then
        uci set dhcp.@dnsmasq[0].port='0' 2>/dev/null
        uci commit dhcp 2>/dev/null
        /etc/init.d/dnsmasq reload >/dev/null 2>&1
    fi
    procd_open_instance
    procd_set_param command "$_mp/adguardhome-bin/AdGuardHome" \
        ${_config:+--config "$_config"} \
        --work-dir "$_mp/AdGuardHome/data" \
        --no-check-update
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param respawn 3600 5 0
    procd_close_instance
}
stop_service() {
    pkill AdGuardHome 2>/dev/null || true
    uci set dhcp.@dnsmasq[0].port='53' 2>/dev/null
    uci commit dhcp 2>/dev/null
    /etc/init.d/dnsmasq reload >/dev/null 2>&1
}
AINITEOF
    chmod +x /etc/init.d/adguardhome
    /etc/init.d/adguardhome enable  2>/dev/null
    /etc/init.d/adguardhome restart 2>/dev/null
    sleep 2
    pgrep -x AdGuardHome >/dev/null 2>&1 \
        && log "AdGuardHome 已启动" \
        || log "AdGuardHome 启动超时"

    [ "$__skip_luci" -eq 0 ] && \
        apk add --no-cache luci-app-adguardhome 2>/dev/null && \
        log "luci-app-adguardhome 安装完成"
fi

# 收尾
rm -f /tmp/luci-indexcache* 2>/dev/null
/etc/init.d/rpcd reload 2>/dev/null || true

if [ "$_DOCKER_FAIL" -eq 0 ] || [ "$_AGH_FAIL" -eq 0 ]; then
    date '+%Y-%m-%d %H:%M:%S' > "$_DONE"
    rm -f "$_SD/phase2-failures"
    log "重型应用完成 [Docker:$([ "$_DOCKER_FAIL" -eq 0 ] && echo OK || echo FAIL) AGH:$([ "$_AGH_FAIL" -eq 0 ] && echo OK || echo FAIL)]"
    exit 0
else
    echo $((__fail + 1)) > "$_SD/phase2-failures"
    log "均失败，重试计数 $((__fail + 1))/3"
    exit 1
fi
USBEOF
chmod +x /usr/lib/install-extras/install-usb.sh

# ====================================================================
# 模块 B：run.sh（Phase 1）
# ====================================================================
cat > /usr/lib/install-extras/run.sh << 'RUNEOF'
#!/bin/sh
_LT="install-main"
_DONE="/etc/install-extras-done"
_USB_DONE="/etc/install-usb-done"
_LOCK="/tmp/install-main.lock"
_SD="/etc/install-state"

log() { __lm="[$(date '+%H:%M:%S')] $1"; echo "$__lm"; echo "$__lm" | logger -t "$_LT"; }
_is_mounted() { grep -q "^[^ ]* $1 " /proc/mounts 2>/dev/null; }

mkdir -p "$_SD"
[ -f "$_DONE" ] && { log "基础环境已完成，跳过"; exit 0; }

__dns_old=$(cat /etc/resolv.conf 2>/dev/null)
[ -z "$__dns_old" ] && __dns_old="nameserver 127.0.0.1"
_dns_restore() {
    rm -f "$_LOCK"
    printf '%s' "$__dns_old" > /etc/resolv.conf
    /etc/init.d/dnsmasq reload >/dev/null 2>&1 || true
}
trap '_dns_restore' EXIT INT TERM

if [ -f "$_LOCK" ]; then
    __lp=$(cat "$_LOCK" 2>/dev/null)
    kill -0 "$__lp" 2>/dev/null && { log "运行中 (pid=$__lp)，跳过"; exit 0; }
    rm -f "$_LOCK"
fi
echo $$ > "$_LOCK"

__fail=$(cat "$_SD/phase1-failures" 2>/dev/null || echo 0)
[ "${__fail:-0}" -ge 3 ] && { log "失败次数过多"; exit 1; }

log "v1 基础环境启动"

# 清理无效源（去除含 /video/ 的行）
for _f in /etc/apk/repositories.d/*.list; do
    [ -f "$_f" ] && sed -i '/\/video\//d' "$_f" 2>/dev/null
done

# 等待网络（最多 3 分钟）
sleep 10
__ok=0; __i=1
while [ "$__i" -le 36 ]; do
    ping -c1 -W2 223.5.5.5 >/dev/null 2>&1 && { __ok=1; break; }
    ping -c1 -W2 8.8.8.8   >/dev/null 2>&1 && { __ok=1; break; }
    sleep 5; __i=$((__i + 1))
done
[ "$__ok" -eq 0 ] && {
    log "网络不可达"
    echo $((__fail + 1)) > "$_SD/phase1-failures"
    exit 1
}
log "网络已就绪"

printf 'nameserver 223.5.5.5\nnameserver 8.8.8.8\n' > /etc/resolv.conf

# Flash 检查（一次性读取，后续复用）
__flash=$(df /overlay 2>/dev/null | awk 'NR==2{print $4}')
[ "${__flash:-0}" -lt 20480 ] && {
    log "Flash 不足 20MB（当前 ${__flash}KB）"
    echo $((__fail + 1)) > "$_SD/phase1-failures"
    exit 1
}
__skip_luci=0
[ "${__flash:-0}" -lt 25000 ] && __skip_luci=1 && log "Flash <25MB，跳过 LuCI 插件"

# apk update（以退出码判断，降级 https→http 作为备用）
apk update >/dev/null 2>&1 || {
    log "apk update 失败，尝试降级为 http..."
    for _f in /etc/apk/repositories.d/*.list; do
        [ -f "$_f" ] && sed -i 's|https://|http://|g' "$_f" 2>/dev/null
    done
    apk update >/dev/null 2>&1 || {
        log "apk update 彻底失败"
        echo $((__fail + 1)) > "$_SD/phase1-failures"
        exit 1
    }
}
log "apk update 成功"

# 安装函数
__inst_fail=0
__inst() {
    apk add --no-cache "$@" >/dev/null 2>&1 \
        && log "已安装: $*" \
        || { log "安装失败: $*"; __inst_fail=$((__inst_fail + 1)); }
}

# 基础工具
for __p in bash htop lsblk smartmontools fdisk; do __inst "$__p"; done

# Samba（Flash 足够时安装）
if [ "${__flash:-0}" -ge 25000 ]; then
    __inst samba4-server
    [ "$__skip_luci" -eq 0 ] && __inst luci-app-samba4 luci-i18n-samba4-zh-cn
fi

# dbus/avahi 重载
/etc/init.d/avahi-daemon stop 2>/dev/null || true
/etc/init.d/dbus stop  2>/dev/null || true
/etc/init.d/dbus start 2>/dev/null || true
sleep 2
/etc/init.d/avahi-daemon start 2>/dev/null || true

# 清理 apk 缓存
apk cache clean 2>/dev/null || true

# zram（静默处理，失败不影响流程）
if ! grep -q zram /proc/swaps 2>/dev/null; then
    modprobe zram num_devices=1 2>/dev/null || true
    if [ -e /sys/block/zram0/disksize ]; then
        echo "134217728" > /sys/block/zram0/disksize 2>/dev/null
        mkswap /dev/zram0 >/dev/null 2>&1 && swapon /dev/zram0 2>/dev/null \
            && log "zram 128MB 已激活"
    fi
fi

rm -f /tmp/luci-indexcache* 2>/dev/null
/etc/init.d/rpcd reload 2>/dev/null || true

if [ "$__inst_fail" -eq 0 ]; then
    date '+%Y-%m-%d %H:%M:%S' > "$_DONE"
    rm -f "$_SD/phase1-failures"
    log "基础环境完成"
else
    echo $((__fail + 1)) > "$_SD/phase1-failures"
    log "$__inst_fail 项安装失败，重试计数 $((__fail + 1))/3"
    exit 1
fi

# 触发 Phase 2（不传 --force，热插拔场景保留失败计数保护）
if [ ! -f "$_USB_DONE" ]; then
    __ump=""
    for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        _is_mounted "$_mp" && { __ump="$_mp"; break; }
    done
    if [ -n "$__ump" ]; then
        log "检测到 U 盘: $__ump，触发 Phase 2"
        /usr/lib/install-extras/install-usb.sh "$__ump" &
    else
        log "未检测到 U 盘，等待热插拔"
    fi
fi
RUNEOF
chmod +x /usr/lib/install-extras/run.sh

# ====================================================================
# 模块 C：WAN hotplug
# ====================================================================
cat > /etc/hotplug.d/iface/96-install-extras << 'IFACEEOF'
#!/bin/sh
[ "${ACTION:-}" = "ifup" ] || exit 0
case "${INTERFACE:-}" in wan|wan6|pppoe-wan) ;; *) exit 0 ;; esac
[ -f /etc/install-extras-done ] && exit 0
/usr/lib/install-extras/run.sh &
IFACEEOF
chmod +x /etc/hotplug.d/iface/96-install-extras

# ====================================================================
# 模块 D：U 盘 hotplug
# ====================================================================
cat > /etc/hotplug.d/block/96-install-usb << 'BLOCKEOF'
#!/bin/sh
case "$DEVNAME" in sd[a-z]*|mmcblk[0-9]*) ;; *) exit 0 ;; esac
[ "${ACTION:-}" = "add" ] || exit 0
[ -f /etc/install-usb-done ]   && exit 0
[ -f /etc/install-extras-done ] || exit 0

# 等待内核完成挂载（慢速设备给 8 秒）
sleep 8
_mp=""
for _m in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
    grep -q "^[^ ]* $_m " /proc/mounts 2>/dev/null && { _mp="$_m"; break; }
done
[ -z "$_mp" ] && { logger -t "hotplug" "挂载点未就绪，跳过"; exit 1; }
/usr/lib/install-extras/install-usb.sh "$_mp" &
BLOCKEOF
chmod +x /etc/hotplug.d/block/96-install-usb

# ====================================================================
# 模块 E：360v6-health
# ====================================================================
cat > /usr/bin/360v6-health << 'HEALTHEOF'
#!/bin/sh
_is_mounted() { grep -q "^[^ ]* $1 " /proc/mounts 2>/dev/null; }
__fix=0
for _a in "$@"; do [ "$_a" = "--fix" ] && __fix=1; done
__status=0

if [ -f /etc/install-usb-done ]; then
    __mp=$(cat /etc/install-usb-mount 2>/dev/null)
    [ -n "$__mp" ] && ! _is_mounted "$__mp" && {
        echo "⚠ U 盘未挂载: $__mp"
        __status=1
    }
    docker info >/dev/null 2>&1 || {
        echo "⚠ Docker 未运行"
        [ "$__fix" -eq 1 ] && /etc/init.d/dockerd restart
        __status=1
    }
    pgrep -x AdGuardHome >/dev/null 2>&1 || {
        echo "⚠ AdGuardHome 未运行"
        [ "$__fix" -eq 1 ] && /etc/init.d/adguardhome restart
        __status=1
    }
fi

__flash=$(df /overlay 2>/dev/null | awk 'NR==2{print $5}' | tr -d '%')
[ "${__flash:-0}" -gt 90 ] && echo "⚠ Flash 使用率过高: ${__flash}%"

[ "$__status" -eq 0 ] && echo "✓ 健康检查通过"
exit "$__status"
HEALTHEOF
chmod +x /usr/bin/360v6-health

# ====================================================================
# 模块 F：cron 自愈
# ====================================================================
if ! grep -q "install-usb.sh --self-heal" /etc/crontabs/root 2>/dev/null; then
    echo "*/5 * * * * /usr/lib/install-extras/install-usb.sh --self-heal 2>&1 | logger -t self-heal" \
        >> /etc/crontabs/root
fi
/etc/init.d/cron reload 2>/dev/null || true

# ====================================================================
# 模块 G：U 盘拔出保护
# ====================================================================
cat > /etc/hotplug.d/block/97-usb-protect << 'PROTECTEOF'
#!/bin/sh
case "$DEVNAME" in sd[a-z]*|mmcblk[0-9]*) ;; *) exit 0 ;; esac
[ "${ACTION:-}" = "remove" ] || exit 0
[ -f /etc/install-usb-done ] || exit 0
__mp=$(cat /etc/install-usb-mount 2>/dev/null)
# 如果挂载点还在说明是其他分区触发，忽略
grep -q "^[^ ]* $__mp " /proc/mounts 2>/dev/null && exit 0
/etc/init.d/dockerd     stop 2>/dev/null || true
/etc/init.d/adguardhome stop 2>/dev/null || true
logger -t "usb-protect" "U 盘已拔出，Docker/AGH 已停止"
PROTECTEOF
chmod +x /etc/hotplug.d/block/97-usb-protect

# ====================================================================
# 模块 H：卸载脚本
# ====================================================================
cat > /usr/bin/360v6-uninstall << 'UNINSTALLEOF'
#!/bin/sh
echo "=== 360 V6 卸载 ==="
printf "确认卸载？[y/N] "; read -r _c
[ "$_c" = "y" ] || [ "$_c" = "Y" ] || { echo "已取消"; exit 0; }

/etc/init.d/dockerd     stop 2>/dev/null || true
/etc/init.d/adguardhome stop 2>/dev/null || true

# 恢复 dnsmasq 端口
uci set dhcp.@dnsmasq[0].port='53' 2>/dev/null
uci commit dhcp 2>/dev/null
/etc/init.d/dnsmasq restart 2>/dev/null || true

# 移除 init.d 服务
for _s in dockerd adguardhome; do
    /etc/init.d/$_s disable 2>/dev/null || true
    rm -f "/etc/init.d/$_s"
done

# 移除二进制链接
rm -f /usr/bin/docker /usr/bin/dockerd /usr/bin/containerd \
      /usr/bin/containerd-shim-runc-v2 /usr/bin/ctr /usr/bin/runc \
      /usr/bin/AdGuardHome

# 移除配置文件
rm -f /etc/docker/daemon.json
rm -f /etc/dbus-1/system.d/avahi-dbus.conf

# 清理 fstab swapfile 行
sed -i '/swapfile.*swap/d' /etc/fstab 2>/dev/null || true

# 移除状态文件与脚本
rm -f /etc/install-extras-done /etc/install-usb-done /etc/install-usb-mount
rm -rf /etc/install-state /usr/lib/install-extras

# 移除工具脚本
rm -f /usr/bin/360v6-status /usr/bin/360v6-health

# 移除 hotplug
rm -f /etc/hotplug.d/iface/96-install-extras
rm -f /etc/hotplug.d/block/96-install-usb
rm -f /etc/hotplug.d/block/97-usb-protect

# 清理 cron
sed -i '/install-usb.sh/d' /etc/crontabs/root 2>/dev/null || true
/etc/init.d/cron reload 2>/dev/null || true

# 最后移除自身
rm -f /usr/bin/360v6-uninstall
echo "卸载完成"
UNINSTALLEOF
chmod +x /usr/bin/360v6-uninstall

# ====================================================================
# 完成
# ====================================================================
logger -t "install-extras" "v1 哨兵安装完成"
exit 0
