        log "AGH 状态已恢复"
    fi

    # 重建符号链接
    if [ -f "$_USB/docker-bin/dockerd" ]; then
        for _b in docker dockerd containerd containerd-shim-runc-v2 ctr runc docker-proxy docker-init; do
            [ -f "$_USB/docker-bin/$_b" ] && \
                ln -sf "$_USB/docker-bin/$_b" "/usr/bin/$_b" 2>/dev/null
        done
    fi
    [ -f "$_USB/adguardhome-bin/AdGuardHome" ] && \
        ln -sf "$_USB/adguardhome-bin/AdGuardHome" /usr/bin/AdGuardHome 2>/dev/null

    # 重建 rc.d 链接
    [ -x /etc/init.d/dockerd ] && /etc/init.d/dockerd enable 2>/dev/null
    [ -x /etc/init.d/adguardhome ] && /etc/init.d/adguardhome enable 2>/dev/null

    # 启动 swap
    if [ -f "$_USB/swapfile" ] && ! grep -q "$_USB/swapfile" /proc/swaps 2>/dev/null; then
        swapon "$_USB/swapfile" 2>/dev/null && log "swap 已激活"
    fi

    # 修复 #3：检查启动结果
    if [ -f "$_SD/docker-done" ] && [ -f "$_USB/docker-bin/dockerd" ]; then
        if ! docker info >/dev/null 2>&1; then
            /etc/init.d/dockerd start 2>/dev/null
            if _wait_docker; then
                log "Docker 已启动"
            else
                log "Docker 启动超时"
            fi
        fi
    fi

    if [ -f "$_USB/adguardhome-bin/AdGuardHome" ]; then
        if ! pgrep -f "AdGuardHome" >/dev/null 2>&1; then
            /etc/init.d/adguardhome start 2>/dev/null
            if _wait_agh; then
                log "AGH 已启动"
            else
                log "AGH 启动超时"
            fi
        fi
    fi

    touch "$_DONE" 2>/dev/null
    exit 0
fi

[ -f "$_DONE" ] && exit 0

__dns_backup=$(cat /etc/resolv.conf 2>/dev/null)
[ -z "$__dns_backup" ] && __dns_backup="nameserver 127.0.0.1"

_cleanup() {
    if [ ! -f "$_SD/agh-done" ]; then
        printf '%s\n' "$__dns_backup" > /etc/resolv.conf 2>/dev/null
    fi
    sync 2>/dev/null || true
}
trap '_cleanup; rmdir "$_LOCK_DIR" 2>/dev/null' EXIT
trap '_cleanup; exit 130' INT
trap '_cleanup; exit 143' TERM

mkdir -p "$_USB/.install-log" 2>/dev/null

_upstream_dns=$(uci get dhcp.@dnsmasq[0].server 2>/dev/null | head -1 | cut -d'/' -f3)
if [ -n "$_upstream_dns" ]; then
    echo "nameserver $_upstream_dns" > /etc/resolv.conf
else
    printf 'nameserver 223.5.5.5\nnameserver 8.8.8.8\n' > /etc/resolv.conf
fi
log "临时 DNS 已注入"

# ============================================================
# Swap（mv 优化）
# ============================================================
_swap_mb=256
_ram_mb=$(free -m 2>/dev/null | awk '/Mem:/{print $2}')
[ "${_ram_mb:-0}" -lt 256 ] && _swap_mb=512
__swapfile="$_USB/swapfile"

if ! grep -q "$__swapfile" /proc/swaps 2>/dev/null; then
    if _is_ext4 "$_USB"; then
        if [ ! -f "$__swapfile" ]; then
            log "创建 ${_swap_mb}MB swap..."
            if dd if=/dev/zero of="${__swapfile}.tmp" bs=1M count=$_swap_mb 2>/dev/null; then
                mv "${__swapfile}.tmp" "$__swapfile" 2>/dev/null
                chmod 600 "$__swapfile"
                mkswap "$__swapfile" >/dev/null 2>&1 || rm -f "$__swapfile"
            fi
        fi
        if [ -f "$__swapfile" ]; then
            swapon "$__swapfile" 2>/dev/null
            if grep -q "$__swapfile" /proc/swaps 2>/dev/null; then
                log "swap 已激活 (${_swap_mb}MB)"
                echo 10 > /proc/sys/vm/swappiness 2>/dev/null
            else
                log "swap swapon 失败"
            fi
        fi
    else
        log "U 盘不是 ext4，跳过 swap"
    fi
fi

__dl_dir="$_USB/.downloads"
mkdir -p "$__dl_dir"

_prefetch_downloads "$__dl_dir"

# ============================================================
# Docker 部署
# ============================================================
_DOCKER_FAIL=0
log "--- Docker 部署 ---"
__docker_fail_count=$(_read_failure_count "$_SD/docker-failures")

if [ -f "$_SD/docker-done" ]; then
    log "Docker 已完成，跳过"
elif [ "${__docker_fail_count:-0}" -ge 3 ]; then
    log "Docker 连续失败 ${__docker_fail_count} 次，跳过（2h 后自动重置或 --force）"
    _DOCKER_FAIL=1
else
    __dbin="$_USB/docker-bin"
    __ddata="$_USB/docker-data"
    mkdir -p "$__dbin" "$__ddata" /etc/docker

    __docker_ver=""
    for _dv in $_DOCKER_VERS; do
        __dtgz="$__dl_dir/docker-${_dv}.tgz"

        if [ ! -f "$__dtgz" ]; then
            log "Docker ${_dv} 包不存在，同步下载..."
            _wget_retry "$_DOCKER_BASE/docker-${_dv}.tgz" \
                "${__dtgz}.tmp" 62914560 || {
                log "Docker ${_dv} 下载失败，尝试下一版本"
                continue
            }
            cp "${__dtgz}.tmp" "$__dtgz" 2>/dev/null && rm -f "${__dtgz}.tmp"
        fi

        log "解压 Docker ${_dv}..."
        rm -rf "$__dbin"/* 2>/dev/null
        if _tar_extract "$__dtgz" "$__dbin" "docker" && [ -f "$__dbin/dockerd" ]; then
            __docker_ver="$_dv"
            break
        else
            log "Docker ${_dv} 解压失败，删除缓存"
            rm -f "$__dtgz"
        fi
    done

    if [ -n "$__docker_ver" ]; then
        echo "$__docker_ver" > "$__dbin/version.txt"
        for _b in docker dockerd containerd containerd-shim-runc-v2 ctr runc docker-proxy docker-init; do
            [ -f "$__dbin/$_b" ] && ln -sf "$__dbin/$_b" "/usr/bin/$_b" 2>/dev/null
        done

        __storage_driver="overlay2"
        if ! grep -q "^overlay$" /proc/filesystems 2>/dev/null; then
            log "overlay 模块不可用，降级为 vfs"
            __storage_driver="vfs"
        fi

        cat > /etc/docker/daemon.json << EOF
{
  "data-root": "$__ddata",
  "storage-driver": "$__storage_driver",
  "iptables": false,
  "bridge": "none",
  "log-driver": "json-file",
  "log-opts": {"max-size": "5m", "max-file": "2"},
  "registry-mirrors": ["https://docker.m.daocloud.io"],
  "userland-proxy": false
}
EOF

        /etc/init.d/dockerd enable 2>/dev/null
        /etc/init.d/dockerd start 2>/dev/null
        sleep 5

        if _timeout 15 docker info >/dev/null 2>&1; then
            log "Docker $__docker_ver 已启动并响应"
        else
            log "Docker $__docker_ver 已启动（守护进程仍在初始化中）"
        fi

        date '+%Y-%m-%d %H:%M:%S' > "$_SD/docker-done"
        rm -f "$_SD/docker-failures"
    else
        _DOCKER_FAIL=1
        _record_failure "$_SD/docker-failures" "$__docker_fail_count"
        log "Docker 部署失败（已尝试全部版本）"
    fi
fi

# ============================================================
# AGH 部署
# ============================================================
_AGH_FAIL=0
log "--- AdGuardHome 部署 ---"
__agh_fail_count=$(_read_failure_count "$_SD/agh-failures")

if [ -f "$_SD/agh-done" ]; then
    log "AGH 已完成，跳过"
elif [ "${__agh_fail_count:-0}" -ge 3 ]; then
    log "AGH 连续失败 ${__agh_fail_count} 次，跳过（2h 后自动重置或 --force）"
    _AGH_FAIL=1
else
    __abin="$_USB/adguardhome-bin"
    __adata="$_USB/AdGuardHome"
    mkdir -p "$__abin" "$__adata"

    if [ ! -f "$__abin/AdGuardHome" ]; then
        __atgz="$__dl_dir/AdGuardHome_linux_arm64.tar.gz"

        if [ ! -f "$__atgz" ]; then
            log "AGH 包不存在，同步下载..."
            if ! _wget_retry "$_AGH_URL" "${__atgz}.tmp" 15728640; then
                log "AGH 下载失败: $_AGH_URL"
                _AGH_FAIL=1
            else
                cp "${__atgz}.tmp" "$__atgz" 2>/dev/null && rm -f "${__atgz}.tmp"
            fi
        fi

        if [ "$_AGH_FAIL" -eq 0 ] && [ -f "$__atgz" ]; then
            log "解压 AdGuardHome..."
            if _tar_extract "$__atgz" "$__abin" "AdGuardHome" && \
               [ -f "$__abin/AdGuardHome" ]; then
                chmod +x "$__abin/AdGuardHome"
                _agh_ver=$("$__abin/AdGuardHome" --version 2>/dev/null | head -1 | grep -oE 'v[0-9.]+')
                echo "${_agh_ver#v}" > "$__adata/version.txt" 2>/dev/null
                log "AGH ${_agh_ver#v} 解压完成"
            else
                log "AGH 解压失败，删除缓存"
                rm -f "$__atgz"
                _AGH_FAIL=1
            fi
        fi
    fi

    if [ "$_AGH_FAIL" -eq 0 ] && [ -f "$__abin/AdGuardHome" ]; then
        ln -sf "$__abin/AdGuardHome" /usr/bin/AdGuardHome 2>/dev/null
        _pkg_install luci-app-adguardhome 2>/dev/null && log "LuCI AGH 插件已安装"

        /etc/init.d/adguardhome enable 2>/dev/null
        /etc/init.d/adguardhome restart 2>/dev/null

        log "等待 AGH 启动（探测 :3000）..."
        if _wait_agh; then
            for _proc in dockerd containerd AdGuardHome; do
                _pid=$(pgrep -f "$_proc" 2>/dev/null | head -1)
                [ -n "$_pid" ] && printf '%s\n' '-500' > "/proc/$_pid/oom_score_adj" 2>/dev/null
            done
            log "AGH 已启动 + OOM 保护已设置"
            log ">>> 访问 http://192.168.2.1:3000 完成向导 <<<"
            log ">>> 完成后执行: AGH_USER=xxx AGH_PASS=xxx agh-finalize <<<"
            rm -f "$_SD/agh-failures"
        else
            log "AGH 未在 30s 内启动"
            _AGH_FAIL=1
        fi
    else
        _AGH_FAIL=1
    fi

    [ "$_AGH_FAIL" -eq 1 ] && \
        _record_failure "$_SD/agh-failures" "$__agh_fail_count"
fi

# ============================================================
# 完成
# ============================================================
rm -f /tmp/luci-indexcache* 2>/dev/null
/etc/init.d/rpcd reload 2>/dev/null || true

if [ "$_DOCKER_FAIL" -eq 0 ] && [ "$_AGH_FAIL" -eq 0 ]; then
    date '+%Y-%m-%d %H:%M:%S' > "$_DONE"
    echo "done" > "$_USB/.install-done" 2>/dev/null
    log "部署完成 [Docker:OK AGH:OK]"
    exit 0
elif [ "$_DOCKER_FAIL" -eq 0 ] || [ "$_AGH_FAIL" -eq 0 ]; then
    log "部分完成 [Docker:$([ $_DOCKER_FAIL -eq 0 ] && echo OK || echo FAIL) AGH:$([ $_AGH_FAIL -eq 0 ] && echo OK || echo FAIL)]"
    exit 2
else
    log "部署失败 [Docker:FAIL AGH:FAIL]"
    exit 1
fi
USBEOF
chmod +x /usr/lib/install-extras/install-usb.sh

# ============================================================
# run.sh
# ============================================================
cat > /usr/lib/install-extras/run.sh << 'RUNEOF'
#!/bin/sh
_LT="install-main"
_DONE="/etc/install-extras-done"
_LOCK_DIR="/tmp/install-main.lock"
_SD="/etc/install-state"
_WAN_COOLDOWN="/tmp/wan-cooldown"

log() { echo "[$(date '+%H:%M:%S')] $1" | logger -t "$_LT"; }

_get_uptime_sec() {
    awk '{print int($1)}' /proc/uptime 2>/dev/null || echo 0
}

_get_usb_mount() {
    for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        grep -q "^[^ ]* $_mp " /proc/mounts 2>/dev/null && { echo "$_mp"; return 0; }
    done
    return 1
}

_is_in_cooldown() {
    [ -f "$_WAN_COOLDOWN" ] || return 1
    _last=$(cat "$_WAN_COOLDOWN" 2>/dev/null || echo 0)
    _now=$(_get_uptime_sec)
    _elapsed=$((_now - _last))
    [ "$_elapsed" -lt 60 ] && return 0
    return 1
}

mkdir -p "$_SD"
[ -f "$_DONE" ] && exit 0

if _is_in_cooldown; then
    log "WAN 事件冷却中，跳过"
    exit 0
fi

if ! mkdir "$_LOCK_DIR" 2>/dev/null; then
    log "另一个实例正在运行"
    exit 0
fi

trap 'rmdir "$_LOCK_DIR" 2>/dev/null' EXIT
trap 'exit 130' INT
trap 'exit 143' TERM

_get_uptime_sec > "$_WAN_COOLDOWN" 2>/dev/null

__fail=$(cat "$_SD/phase1-failures" 2>/dev/null || echo 0)
[ "${__fail:-0}" -ge 3 ] && exit 1

log "基础环境启动"
sleep 10

__ok=0
_i=1
while [ "$_i" -le 10 ]; do
    ping -c1 -W2 223.5.5.5 >/dev/null 2>&1 && { __ok=1; break; }
    sleep 3; _i=$((_i + 1))
done
if [ "$__ok" -eq 0 ]; then
    echo $((__fail + 1)) > "$_SD/phase1-failures"
    log "网络超时，退出"
    exit 1
fi

if command -v apk >/dev/null 2>&1; then
    for __p in bash htop curl; do
        apk add --no-cache "$__p" >/dev/null 2>&1 && log "已安装: $__p"
    done
elif command -v opkg >/dev/null 2>&1; then
    opkg update >/dev/null 2>&1
    for __p in bash htop curl; do
        opkg install "$__p" >/dev/null 2>&1 && log "已安装: $__p"
    done
fi

date '+%Y-%m-%d %H:%M:%S' > "$_DONE"
rm -f "$_SD/phase1-failures"
log "基础环境完成"

if [ ! -f /etc/install-usb-done ]; then
    _mp=$(_get_usb_mount)
    if [ -n "$_mp" ]; then
        log "检测到 U 盘: $_mp，启动部署"
        /usr/lib/install-extras/install-usb.sh "$_mp" &
    fi
fi
RUNEOF
chmod +x /usr/lib/install-extras/run.sh

