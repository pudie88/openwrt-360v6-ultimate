#!/bin/sh
# 96-install-extras [V4.0]
# 适用：360 V6 / 小米 CR660x / IPQ6000 (128M Flash / ImmortalWrt / busybox ash)
#
# 变更记录 V4.0：
#   1. 部署完成标记改写到 U 盘 (.install-done)，刷机后走恢复模式
#   2. 恢复模式：跳过下载，直接按顺序启动 swap→Docker→AGH
#   3. init.d 只依赖 U 盘文件，不依赖 Flash 标记
#   4. 持久化日志写到 U 盘 (.install-log/)，保留 7 天
#   5. Docker/AGH 版本号写 version.txt 到 U 盘
#   6. nc -z 替换为兼容写法
#   7. swap 先检测文件系统类型
#   8. iptables/nftables 自动检测
#   9. agh-finalize 加 trap 恢复终端回显
#  10. DNS 恢复时机修复
#  11. --force 同时清理 U 盘标记
#  12. WAN 抖动防并发（hotplug 冷却 60s）
#  13. 新增 360v6-upgrade 命令
#  14. 360v6-status 大幅完善
#  15. 360v6-uninstall 修复 swap 路径

[ -n "$DEBUG" ] && set -x

_SD="/etc/install-state"
mkdir -p "$_SD" /usr/lib/install-extras /usr/bin \
         /etc/hotplug.d/iface /etc/hotplug.d/block \
         /etc/dbus-1 /etc/dbus-1/system.d

__log_buf=""
__log_count=0
__log_tag="install-main"

log() {
    __msg="[$(date '+%H:%M:%S')] $1"
    [ -n "$DEBUG" ] && echo "$__msg" >&2
    __log_buf="${__log_buf}${__msg}
"
    __log_count=$((__log_count + 1))
    [ "$__log_count" -ge 10 ] && __flush_logs
}

__flush_logs() {
    [ -n "$__log_buf" ] && printf "%s" "$__log_buf" | logger -t "$__log_tag"
    __log_buf=""
    __log_count=0
}

trap '__flush_logs' EXIT INT TERM

echo "1048576" > /proc/sys/net/core/rmem_max 2>/dev/null
echo "1048576" > /proc/sys/net/core/wmem_max 2>/dev/null
echo "32768"   > /proc/sys/net/nf_conntrack_max 2>/dev/null

_get_usb_mount() {
    for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        if grep -q "^[^ ]* $_mp " /proc/mounts 2>/dev/null; then
            echo "$_mp"
            return 0
        fi
    done
    return 1
}

_timeout() {
    __tt="$1"; shift
    if command -v timeout >/dev/null 2>&1; then
        timeout "$__tt" "$@" 2>/dev/null
        return $?
    fi
    "$@" &
    __pid=$!
    __cnt=0
    while [ "$__cnt" -lt "$__tt" ]; do
        kill -0 "$__pid" 2>/dev/null || { wait "$__pid"; return $?; }
        sleep 1
        __cnt=$((__cnt + 1))
    done
    kill -9 "$__pid" 2>/dev/null
    wait "$__pid" 2>/dev/null
    return 124
}

_sha256() {
    if command -v sha256sum >/dev/null 2>&1; then
        sha256sum "$1" 2>/dev/null | cut -d' ' -f1
    elif command -v openssl >/dev/null 2>&1; then
        openssl dgst -sha256 "$1" 2>/dev/null | cut -d' ' -f2
    else
        echo ""
    fi
}

# 端口探测（兼容 busybox nc 不支持 -z）
_wait_port() {
    __host="$1"; __port="$2"; __max="$3"
    __wi=0
    while [ "$__wi" -lt "$__max" ]; do
        # 优先用 wget 探测，比 nc -z 更兼容
        if wget -q --timeout=2 --tries=1 \
            -O /dev/null "http://${__host}:${__port}/" 2>/dev/null; then
            return 0
        fi
        # 备用：直接读 /proc/net/tcp6 或 tcp
        if grep -qE "$(printf '%04X' "$__port")" \
            /proc/net/tcp6 /proc/net/tcp 2>/dev/null; then
            return 0
        fi
        sleep 1
        __wi=$((__wi + 1))
    done
    return 1
}

# ══════════════════════════════════════════════════════════════
# 360v6-status（V4.0 完善版）
# ══════════════════════════════════════════════════════════════
cat > /usr/bin/360v6-status << 'STATUSEOF'
#!/bin/sh
_SD="/etc/install-state"

_get_usb_mount() {
    for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        grep -q "^[^ ]* $_mp " /proc/mounts 2>/dev/null && { echo "$_mp"; return 0; }
    done
    return 1
}

if [ -t 1 ]; then
    _G="\033[32m"; _R="\033[31m"; _Y="\033[33m"; _B="\033[36m"
    _W="\033[37m"; _N="\033[0m";  _BOLD="\033[1m"
else
    _G=""; _R=""; _Y=""; _B=""; _W=""; _N=""; _BOLD=""
fi

_ok()    { printf "${_G}[OK]${_N}  %s\n" "$1"; }
_warn()  { printf "${_Y}[!!]${_N}  %s\n" "$1"; }
_err()   { printf "${_R}[ERR]${_N} %s\n" "$1"; }
_info()  { printf "      ${_B}%s${_N}\n" "$1"; }
_hint()  { printf "      ${_Y}提示: %s${_N}\n" "$1"; }

_USB=$(_get_usb_mount)
_USB_DONE="${_USB}/.install-done"

printf "${_BOLD}=== 360 V6 状态 @ $(date '+%Y-%m-%d %H:%M:%S') ===${_N}\n"
echo "版本  : V4.0"
echo ""

# ── 基础环境 ──────────────────────────────────
printf "${_BOLD}[ 基础环境 ]${_N}\n"
if [ -f /etc/install-extras-done ]; then
    _ok "基础工具已安装"
    for _t in bash curl htop; do
        command -v "$_t" >/dev/null 2>&1 && _info "$_t: 已就绪" || _warn "$_t: 未找到"
    done
else
    _warn "基础环境：待触发（等待 WAN 上线）"
fi
echo ""

# ── 网络状态 ──────────────────────────────────
printf "${_BOLD}[ 网络 ]${_N}\n"
_wan_ip=$(ip -4 addr show dev wan 2>/dev/null | \
    awk '/inet /{gsub(/\/.*/,"",$2); print $2; exit}')
_wan6_ip=$(ip -6 addr show dev wan 2>/dev/null | \
    grep -v "fe80" | awk '/inet6 /{gsub(/\/.*/,"",$2); print $2; exit}')
_gw=$(ip route show default 2>/dev/null | awk '{print $3; exit}')

if [ -n "$_wan_ip" ]; then
    _ok "WAN IPv4: $_wan_ip（网关: ${_gw:-未知}）"
else
    _err "WAN IPv4: 未获取到地址"
fi
[ -n "$_wan6_ip" ] && _info "WAN IPv6: $_wan6_ip" || _info "WAN IPv6: 未启用"

_lan_ip=$(ip -4 addr show dev br-lan 2>/dev/null | \
    awk '/inet /{gsub(/\/.*/,"",$2); print $2; exit}')
[ -n "$_lan_ip" ] && _info "LAN IP  : $_lan_ip" || _info "LAN IP  : 未知"

# SSH 空密码警告
if grep -q "^root:[!*:]*:" /etc/shadow 2>/dev/null || \
   grep -q "^root::" /etc/shadow 2>/dev/null; then
    _warn "SSH root 密码为空，建议执行: passwd root"
fi
echo ""

# ── Wi-Fi 状态 ────────────────────────────────
printf "${_BOLD}[ Wi-Fi ]${_N}\n"
_wifi_found=0
for _phy in /sys/class/ieee80211/phy*; do
    [ -d "$_phy" ] || continue
    _wifi_found=1
    _phyname="${_phy##*/}"
    _band=$(iw phy "$_phyname" info 2>/dev/null | \
        awk '/MHz/{if($1>5000) {b="5GHz"; break} else b="2.4GHz"} END{print b}')
    [ -z "$_band" ] && _band="未知频段"

    _iface=$(iw dev 2>/dev/null | awk -v p="$_phyname" \
        '$0~"phy#"substr(p,4){found=1} found && /Interface/{print $2; exit}')
    if [ -n "$_iface" ]; then
        _ssid=$(iwinfo "$_iface" info 2>/dev/null | \
            awk -F'"' '/ESSID/{print $2}')
        _chan=$(iwinfo "$_iface" info 2>/dev/null | \
            awk '/Channel/{print $4}')
        _clients=$(iw dev "$_iface" station dump 2>/dev/null | \
            grep -c "^Station")
        _ok "${_band} (${_iface}): SSID=${_ssid:-未知} 频道=${_chan:-?} 客户端=${_clients:-0}"
    else
        _warn "${_band} (${_phyname}): 未启用"
    fi
done
[ "$_wifi_found" -eq 0 ] && _warn "未检测到无线网卡"
echo ""

# ── 系统资源 ──────────────────────────────────
printf "${_BOLD}[ 系统资源 ]${_N}\n"

# Flash
_flash_used=$(df -h /overlay 2>/dev/null | awk 'NR==2{print $3}')
_flash_total=$(df -h /overlay 2>/dev/null | awk 'NR==2{print $2}')
_flash_pct=$(df /overlay 2>/dev/null | awk 'NR==2{gsub(/%/,"",$5); print $5}')
if [ -n "$_flash_pct" ]; then
    if [ "$_flash_pct" -ge 90 ]; then
        _err "Flash : ${_flash_used} / ${_flash_total} (${_flash_pct}%) — 空间严重不足"
    elif [ "$_flash_pct" -ge 75 ]; then
        _warn "Flash : ${_flash_used} / ${_flash_total} (${_flash_pct}%)"
    else
        _ok "Flash : ${_flash_used} / ${_flash_total} (${_flash_pct}%)"
    fi
fi

# 内存
_mem_used=$(free -m 2>/dev/null | awk '/Mem:/{print $3}')
_mem_total=$(free -m 2>/dev/null | awk '/Mem:/{print $2}')
_mem_pct=0
[ "${_mem_total:-0}" -gt 0 ] && \
    _mem_pct=$(( _mem_used * 100 / _mem_total ))
if [ "$_mem_pct" -ge 85 ]; then
    _warn "内存  : ${_mem_used}MB / ${_mem_total}MB (${_mem_pct}%)"
else
    _ok "内存  : ${_mem_used}MB / ${_mem_total}MB (${_mem_pct}%)"
fi

# Swap
_swaptotal=$(awk '/SwapTotal/{print $2}' /proc/meminfo 2>/dev/null)
_swapfree=$(awk '/SwapFree/{print $2}' /proc/meminfo 2>/dev/null)
if [ "${_swaptotal:-0}" -gt 0 ]; then
    _swapused=$(( (_swaptotal - _swapfree) / 1024 ))
    _swaptotalm=$(( _swaptotal / 1024 ))
    _ok "Swap  : ${_swapused}MB / ${_swaptotalm}MB"
else
    _warn "Swap  : 未激活"
fi

# 负载
_load=$(awk '{print $1" "$2" "$3}' /proc/loadavg 2>/dev/null)
_ncpu=$(grep -c "^processor" /proc/cpuinfo 2>/dev/null || echo 1)
_load1=$(echo "$_load" | awk '{print $1}' | cut -d. -f1)
if [ "${_load1:-0}" -gt "$_ncpu" ]; then
    _warn "负载  : $_load（超过 CPU 数 ${_ncpu}）"
else
    _ok "负载  : $_load（${_ncpu} 核）"
fi

# 开机时间
_uptime_s=$(awk '{printf "%d", $1}' /proc/uptime 2>/dev/null)
if [ -n "$_uptime_s" ]; then
    _uph=$(( _uptime_s / 3600 ))
    _upm=$(( (_uptime_s % 3600) / 60 ))
    _info "运行  : ${_uph} 时 ${_upm} 分"
fi

# CPU 温度
_temp=$(cat /sys/class/thermal/thermal_zone0/temp 2>/dev/null)
if [ -n "$_temp" ]; then
    _tc=$(( _temp / 1000 ))
    if [ "$_temp" -gt 75000 ]; then
        _err "CPU温度: ${_tc}°C（过高！）"
        _hint "执行 360v6-tune --mode=powersave 降温"
    elif [ "$_temp" -gt 65000 ]; then
        _warn "CPU温度: ${_tc}°C（偏高）"
        _hint "执行 360v6-tune --mode=powersave 降温"
    else
        _ok "CPU温度: ${_tc}°C"
    fi
fi
echo ""

# ── USB & 重型应用 ────────────────────────────
printf "${_BOLD}[ USB & 应用 ]${_N}\n"
if [ -n "$_USB" ]; then
    _usbdev=$(awk -v mp="$_USB " '$0~mp{print $1; exit}' /proc/mounts 2>/dev/null)
    _usbfs=$(awk -v mp="$_USB " '$0~mp{print $3; exit}' /proc/mounts 2>/dev/null)
    _usbfree=$(df -h "$_USB" 2>/dev/null | awk 'NR==2{print $4}')
    _usbused=$(df -h "$_USB" 2>/dev/null | awk 'NR==2{print $3}')
    _usbtotal=$(df -h "$_USB" 2>/dev/null | awk 'NR==2{print $2}')
    _ok "USB   : $_USB (${_usbdev:-?}) 文件系统: ${_usbfs:-?}"
    _info "容量  : 已用 ${_usbused:-?} / ${_usbtotal:-?}，剩余 ${_usbfree:-?}"

    # FAT32/exFAT 警告
    case "${_usbfs:-}" in
        vfat|exfat|fat*)
            _warn "文件系统 ${_usbfs} 不支持 swap 和文件权限，建议格式化为 ext4"
            ;;
    esac

    if [ -f "$_USB_DONE" ]; then
        _ok "部署标记: 已完成（$(cat "$_USB_DONE" 2>/dev/null)）"
    else
        _warn "部署标记: 不存在（首次部署或 U 盘已格式化）"
    fi
else
    _err "USB   : 未检测到已挂载的 U 盘"
fi
echo ""

# ── Docker ────────────────────────────────────
printf "${_BOLD}[ Docker ]${_N}\n"
if [ -n "$_USB" ] && [ -f "$_USB/docker-bin/dockerd" ]; then
    _dver=$(cat "$_USB/docker-bin/version.txt" 2>/dev/null || echo "未知")
    if docker info >/dev/null 2>&1; then
        _crun=$(docker ps -q 2>/dev/null | wc -l | tr -d ' ')
        _call=$(docker ps -aq 2>/dev/null | wc -l | tr -d ' ')
        _driver=$(docker info 2>/dev/null | awk '/Storage Driver/{print $3}')
        _ok "Docker ${_dver}: 运行中"
        _info "容器  : 运行 ${_crun} / 总计 ${_call}"
        if [ "${_driver:-}" = "vfs" ]; then
            _warn "存储驱动: vfs（性能较差，overlay2 内核模块不可用）"
        else
            _info "存储驱动: ${_driver:-未知}"
        fi
    else
        _warn "Docker ${_dver}: 已安装但未运行"
        _hint "执行 /etc/init.d/dockerd start 或 360v6-health --fix"
    fi
else
    if [ -n "$_USB" ]; then
        _warn "Docker : 未安装"
    else
        _warn "Docker : 需要 U 盘"
    fi
fi
echo ""

# ── AdGuardHome ───────────────────────────────
printf "${_BOLD}[ AdGuardHome ]${_N}\n"
if [ -n "$_USB" ] && [ -f "$_USB/adguardhome-bin/AdGuardHome" ]; then
    _aver=$(cat "$_USB/adguardhome-bin/version.txt" 2>/dev/null || \
        "$_USB/adguardhome-bin/AdGuardHome" --version 2>/dev/null | \
        grep -o 'v[0-9.]*' | head -1 || echo "未知")

    if pgrep -f "AdGuardHome" >/dev/null 2>&1; then
        _ok "AGH ${_aver}: 运行中"

        # agh-done 检测
        if [ ! -f "$_SD/agh-done" ] && [ ! -f "${_USB}/.agh-finalized" ]; then
            _warn "AGH 尚未完成初始化向导"
            _hint "1. 浏览器访问 http://192.168.2.1:3000 完成向导"
            _hint "2. 执行 AGH_USER=xxx AGH_PASS=xxx agh-finalize"
        fi

        # DNS 统计
        _web_port=3000
        if [ -f "$_USB/AdGuardHome/AdGuardHome.yaml" ]; then
            _web_port_yaml=$(grep -m1 "^  port:" \
                "$_USB/AdGuardHome/AdGuardHome.yaml" 2>/dev/null | \
                awk '{print $2}')
            [ -n "$_web_port_yaml" ] && _web_port="$_web_port_yaml"
        fi

        if command -v curl >/dev/null 2>&1 && \
           [ -f "${_USB}/.agh-finalized" ]; then
            _agh_user=$(cat "${_USB}/.agh-user" 2>/dev/null)
            _agh_pass=$(cat "${_USB}/.agh-pass" 2>/dev/null)
            _stats=$(curl -s --max-time 3 \
                ${_agh_user:+--user "${_agh_user}:${_agh_pass}"} \
                "http://127.0.0.1:${_web_port}/control/stats" 2>/dev/null)
            if [ -n "$_stats" ]; then
                _total=$(echo "$_stats" | \
                    grep -o '"num_dns_queries":[0-9]*' | cut -d: -f2)
                _blocked=$(echo "$_stats" | \
                    grep -o '"num_blocked_filtering":[0-9]*' | cut -d: -f2)
                _blocked_pct=0
                [ "${_total:-0}" -gt 0 ] && \
                    _blocked_pct=$(( _blocked * 100 / _total ))
                _info "DNS统计: 今日查询 ${_total:-0} / 拦截 ${_blocked:-0} (${_blocked_pct}%)"
            fi

            # 上游 DNS
            if [ -f "$_USB/AdGuardHome/AdGuardHome.yaml" ]; then
                _upstream=$(grep -A5 "^upstream_dns:" \
                    "$_USB/AdGuardHome/AdGuardHome.yaml" 2>/dev/null | \
                    grep "^ *-" | head -3 | sed 's/^ *- //' | \
                    tr '\n' ' ')
                [ -n "$_upstream" ] && _info "上游DNS : ${_upstream}"
            fi
        fi
        _info "管理界面: http://192.168.2.1:${_web_port}"
    else
        _err "AGH ${_aver}: 未运行"
        _hint "执行 360v6-health --fix 或 /etc/init.d/adguardhome start"
    fi
else
    if [ -n "$_USB" ]; then
        _warn "AGH   : 未安装"
    else
        _warn "AGH   : 需要 U 盘"
    fi
fi
echo ""

# ── 快捷命令 ──────────────────────────────────
printf "${_BOLD}[ 命令参考 ]${_N}\n"
echo "  360v6-health [--fix]                 健康检查 / 自动修复"
echo "  360v6-tune --mode=performance|balanced|powersave  性能调节"
echo "  360v6-upgrade --docker|--agh         升级组件"
echo "  agh-finalize                         AGH 向导完成后执行"
echo "  360v6-uninstall [--yes]              卸载所有组件"
STATUSEOF
chmod +x /usr/bin/360v6-status

# ══════════════════════════════════════════════════════════════
# 360v6-health（V4.0）
# ══════════════════════════════════════════════════════════════
cat > /usr/bin/360v6-health << 'HEALTHEOF'
#!/bin/sh
_SD="/etc/install-state"
_fix=0
[ "$1" = "--fix" ] && _fix=1

_ok()   { echo "[OK]  $1"; }
_warn() { echo "[!!]  $1"; }
_err()  { echo "[ERR] $1"; }

_get_usb_mount() {
    for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        grep -q "^[^ ]* $_mp " /proc/mounts 2>/dev/null && { echo "$_mp"; return 0; }
    done
    return 1
}

_fix_action() {
    [ "$_fix" -eq 1 ] || { echo "  → 修复: $1（加 --fix 自动执行）"; return; }
    echo "  → 执行修复: $1"
    eval "$2"
}

echo "=== 360 V6 健康检查 @ $(date '+%Y-%m-%d %H:%M:%S') ==="
echo ""

_errs=0
_USB=$(_get_usb_mount)

# CPU 温度
_temp=$(cat /sys/class/thermal/thermal_zone0/temp 2>/dev/null)
if [ -n "$_temp" ]; then
    _tc=$(( _temp / 1000 ))
    if [ "$_temp" -gt 75000 ]; then
        _err "CPU 温度过高 (${_tc}°C)"
        _fix_action "切换 CPU 为 powersave" \
            "for g in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do
                [ -f \"\$g\" ] && echo powersave > \"\$g\" 2>/dev/null; done"
        _errs=$((_errs + 1))
    else
        _ok "CPU 温度: ${_tc}°C"
    fi
fi

# Flash 使用率
_flash_pct=$(df /overlay 2>/dev/null | \
    awk 'NR==2{gsub(/%/,"",$5); print $5}')
if [ -z "$_flash_pct" ]; then
    _warn "无法读取 Flash 使用率"
elif [ "$_flash_pct" -ge 90 ]; then
    _err "Flash 使用率 ${_flash_pct}%（严重不足）"
    _fix_action "清理缓存" \
        "rm -rf /tmp/opkg-lists /var/cache/apk 2>/dev/null"
    _errs=$((_errs + 1))
else
    _ok "Flash 使用率 ${_flash_pct}%"
fi

# Swap
grep -q swapfile /proc/swaps 2>/dev/null && \
    _ok "Swap 已激活" || _warn "Swap 未激活（重启后会自动恢复）"

# Docker
if [ -n "$_USB" ] && [ -f "$_USB/docker-bin/dockerd" ]; then
    if docker info >/dev/null 2>&1; then
        _ok "Docker 运行中"
    else
        _err "Docker 未运行"
        _fix_action "启动 dockerd" "/etc/init.d/dockerd start"
        _errs=$((_errs + 1))
    fi
fi

# AGH
if [ -n "$_USB" ] && [ -f "$_USB/adguardhome-bin/AdGuardHome" ]; then
    if pgrep -f "AdGuardHome" >/dev/null 2>&1; then
        _ok "AdGuardHome 运行中"

        # DNS 冲突检测
        _dnsmasq_53=$(ss -lnup 2>/dev/null | \
            awk '$5~/:53$/ && /dnsmasq/{print 1; exit}')
        [ -z "$_dnsmasq_53" ] && _dnsmasq_53=$(netstat -lnup 2>/dev/null | \
            awk '$4~/:53$/ && $NF~/dnsmasq/{print 1; exit}')
        if [ "${_dnsmasq_53}" = "1" ]; then
            _err "DNS 冲突：dnsmasq 仍监听 53 端口"
            _fix_action "禁用 dnsmasq DNS" \
                "uci set dhcp.@dnsmasq[0].port='0';
                 uci commit dhcp;
                 /etc/init.d/dnsmasq reload"
            _errs=$((_errs + 1))
        else
            _ok "DNS 分配正常（无冲突）"
        fi
    else
        _err "AdGuardHome 未运行"
        _fix_action "启动 AGH" "/etc/init.d/adguardhome start"
        _errs=$((_errs + 1))
    fi
fi

# SSH 空密码
if grep -q "^root::" /etc/shadow 2>/dev/null; then
    _err "SSH root 密码为空（安全风险）"
    _errs=$((_errs + 1))
    echo "  → 修复: 执行 passwd root 设置密码"
fi

# WAN 连通性
if ping -c1 -W3 223.5.5.5 >/dev/null 2>&1; then
