#!/bin/sh
# ============================================================
# 96-install-extras [V1.2]
# 适用：360 V6 / 小米 CR660x / IPQ6000
#       128M Flash / ImmortalWrt / busybox ash
#
# 功能：自动部署 Docker + AdGuardHome 到 USB 存储
# 依赖：USB 设备挂载于 /mnt/sdX1，支持 ext4/btrfs/xfs/f2fs
#
# AGH 下载源：ghfast.top / ghproxy / 直连 GitHub（多源轮询）
#
# 修复记录 V1.2：
#   - _wget_retry 改为断点续传 + 5次重试 + 更长间隔
#   - _download_agh 多源轮询（ghfast/ghproxy/直连），支持跨源续传
#   - swap 激活后增加写入验证，检测坏块自动禁用
#   - Docker 就绪检测改为循环等待（最多20s），消除误报"初始化中"
#   - 继承 V1.1 所有修复
# ============================================================

[ -n "$DEBUG" ] && set -x

_VERSION="1.2"
_SD="/etc/install-state"
_USB_MOUNT_FILE="/etc/install-usb-mount"
mkdir -p "$_SD" /usr/lib/install-extras /usr/bin \
         /etc/hotplug.d/iface /etc/hotplug.d/block

echo "1048576" > /proc/sys/net/core/rmem_max 2>/dev/null
echo "1048576" > /proc/sys/net/core/wmem_max 2>/dev/null
echo "32768"   > /proc/sys/net/nf_conntrack_max 2>/dev/null

# ============================================================
# 1/16  共享函数库 lib.sh
# ============================================================
cat > /usr/lib/install-extras/lib.sh << 'LIBEOF'
#!/bin/sh

_is_mounted() {
    awk -v mp="$1" '$2==mp{f=1;exit} END{exit !f}' /proc/mounts 2>/dev/null
}

_get_usb_mount() {
    if [ -f /etc/install-usb-mount ]; then
        _cached=$(cat /etc/install-usb-mount 2>/dev/null)
        [ -n "$_cached" ] && _is_mounted "$_cached" && { echo "$_cached"; return 0; }
    fi
    while IFS= read -r _line; do
        _dev=$(echo "$_line" | awk '{print $1}')
        _mp=$(echo "$_line" | awk '{print $2}')
        case "$_dev" in
            /dev/sd[a-z][0-9]*|/dev/mmcblk[0-9]*p[0-9]*)
                [ -d "$_mp" ] && { echo "$_mp"; return 0; } ;;
        esac
    done < /proc/mounts
    return 1
}

_is_usb_dev() {
    case "$1" in /dev/sd[a-z][0-9]*|/dev/mmcblk[0-9]*p[0-9]*) return 0 ;; *) return 1 ;; esac
}

_acquire_lock() {
    _alf="$1"
    _ald="${_alf}.d"
    if mkdir "$_ald" 2>/dev/null; then
        echo $$ > "$_alf"
        return 0
    fi
    _pid=$(cat "$_alf" 2>/dev/null)
    if [ -n "$_pid" ] && kill -0 "$_pid" 2>/dev/null; then
        return 1
    fi
    rm -rf "$_ald" "$_alf" 2>/dev/null
    if mkdir "$_ald" 2>/dev/null; then
        echo $$ > "$_alf"
        return 0
    fi
    return 1
}

_release_lock() {
    _alf="$1"
    _ald="${_alf}.d"
    [ "$(cat "$_alf" 2>/dev/null)" = "$$" ] && rm -rf "$_ald" "$_alf" 2>/dev/null
}

_is_swap_active() {
    awk -v sf="$1" 'NR>1 && $1==sf{exit 0} END{exit 1}' /proc/swaps 2>/dev/null
}

_cleanup_stale_swap() {
    while IFS= read -r _sl; do
        _sd=$(echo "$_sl" | awk '{print $1}')
        [ "$_sd" = "Filename" ] && continue; [ -z "$_sd" ] && continue
        case "$_sd" in
            */swapfile)
                _smp=$(dirname "$_sd")
                # 挂载点不存在，或文件本身不存在，都 swapoff
                if ! _is_mounted "$_smp" || [ ! -f "$_sd" ]; then
                    swapoff "$_sd" 2>/dev/null
                    logger -t "install-extras" "清理残留 swap: $_sd"
                fi ;;
        esac
    done < /proc/swaps
}

_LT="${_LT:-install-extras}"

_log() {
    __msg="[$(date '+%H:%M:%S')] $1"
    [ -n "$DEBUG" ] && echo "$__msg" >&2
    printf '%s\n' "$__msg" | logger -t "${_LT:-install-extras}"
}

_flush_logs() { :; }

# BusyBox 兼容的 tar 解压（不使用 --strip-components）
# 用法: _tar_extract <tgz> <dst> [subdir]
_tar_extract() {
    __tgz="$1"; __dst="$2"; __sub="$3"
    __tmp="${__dst}.xtmp$$"
    rm -rf "$__tmp"; mkdir -p "$__tmp" "$__dst" || return 1
    tar xzf "$__tgz" -C "$__tmp" 2>/dev/null || { rm -rf "$__tmp"; return 1; }
    if [ -n "$__sub" ]; then
        [ -d "$__tmp/$__sub" ] && __src="$__tmp/$__sub" || { rm -rf "$__tmp"; return 1; }
    else
        __src="$__tmp"
    fi
    __n=0
    for __f in "$__src/"*; do
        [ -e "$__f" ] || continue
        rm -rf "$__dst/${__f##*/}"
        mv "$__f" "$__dst/" 2>/dev/null || { rm -rf "$__tmp"; return 1; }
        __n=$((__n+1))
    done
    rm -rf "$__tmp"; [ "$__n" -gt 0 ]
}

# FIX V1.2: 支持断点续传，5次重试，更长退避间隔
# 用法: _wget_retry <url> <out> [min_size]
_wget_retry() {
    __url="$1"; __out="$2"; __min="${3:-0}"
    __r=0; __max_r=5

    while [ "$__r" -lt "$__max_r" ]; do
        # 已有部分文件 >1MB 则续传，否则重新下载
        __existing=0
        [ -f "$__out" ] && __existing=$(wc -c < "$__out" 2>/dev/null || echo 0)

        if [ "${__existing:-0}" -gt 1048576 ]; then
            _log "续传下载 (已有 $(( __existing / 1048576 ))MB, 第$((__r+1))次)..."
            wget -4 -q --timeout=300 --tries=1 -c -O "$__out" "$__url" 2>/dev/null
        else
            rm -f "$__out" 2>/dev/null
            wget -4 -q --timeout=300 --tries=1 -O "$__out" "$__url" 2>/dev/null
        fi

        if [ -f "$__out" ]; then
            __sz=$(wc -c < "$__out" 2>/dev/null || echo 0)
            if [ "${__sz:-0}" -ge "$__min" ] && [ "${__sz:-0}" -gt 0 ]; then
                return 0
            fi
            _log "下载不完整: ${__sz:-0} bytes (期望 >=${__min})"
        else
            _log "wget 无输出文件 (第$((__r+1))次)"
        fi

        __r=$((__r+1))
        case "$__r" in
            1) sleep 5  ;;
            2) sleep 15 ;;
            3) sleep 30 ;;
            4) sleep 60 ;;
        esac
    done

    rm -f "$__out" 2>/dev/null
    return 1
}

_get_upstream_dns() {
    _up=$(uci get dhcp.@dnsmasq[0].server 2>/dev/null | \
        grep -oE '([0-9]{1,3}\.){3}[0-9]{1,3}' | \
        grep -v '^127\.' | grep -v '^0\.0\.0\.0' | head -1)
    [ -z "$_up" ] && _up=$(awk '/^nameserver/{
        if ($2 !~ /^127\./ && $2 != "::1" && $2 != "0.0.0.0") {print $2; exit}
    }' /etc/resolv.conf 2>/dev/null)
    [ -z "$_up" ] && _up=$(ip route show default 2>/dev/null | awk '{print $3; exit}')
    [ -z "$_up" ] && _up="223.5.5.5"
    echo "$_up"
}

_restore_dns_safe() {
    _bak="$1"; _usb="${2:-}"
    [ -n "$_bak" ] && [ ! -f "${_usb}/.agh-finalized" ] && \
        printf '%s\n' "$_bak" > /etc/resolv.conf 2>/dev/null
}

_pkg_install() {
    command -v apk  >/dev/null 2>&1 && { apk add --no-cache "$@" >/dev/null 2>&1; return; }
    command -v opkg >/dev/null 2>&1 && { opkg install "$@" >/dev/null 2>&1; return; }
    return 1
}

_sha256() {
    command -v sha256sum >/dev/null 2>&1 && { sha256sum "$1" 2>/dev/null | cut -d' ' -f1; return; }
    command -v openssl  >/dev/null 2>&1 && { openssl dgst -sha256 "$1" 2>/dev/null | cut -d' ' -f2; return; }
    echo ""
}

_verify_checksum() {
    __file="$1"; __expected="$2"; __name="$3"
    [ -z "$__expected" ] && return 0
    __actual=$(_sha256 "$__file"); [ -z "$__actual" ] && return 0
    [ "$__actual" = "$__expected" ] && { _log "$__name 校验通过"; return 0; }
    _log "警告: $__name 校验和不匹配"
    [ "${_STRICT_CHECKSUM:-0}" = "1" ] && return 1; return 0
}

_timeout() {
    __tt="$1"; shift
    command -v timeout >/dev/null 2>&1 && { timeout "$__tt" "$@" 2>/dev/null; return $?; }
    "$@" &
    __pid=$!; __cnt=0
    while [ "$__cnt" -lt "$__tt" ]; do
        kill -0 "$__pid" 2>/dev/null || { wait "$__pid"; return $?; }
        sleep 1; __cnt=$((__cnt+1))
    done
    kill -9 "$__pid" 2>/dev/null; wait "$__pid" 2>/dev/null; return 124
}

# FIX V1.2: 多源轮询下载 AGH，支持跨源断点续传
_download_agh() {
    __usb="$1"; __dl="$__usb/.downloads"
    __atgz="$__dl/AdGuardHome_linux_arm64.tar.gz"
    __atmp="${__atgz}.tmp"
    __ab="$__usb/adguardhome-bin"
    __agh_file="AdGuardHome_linux_arm64.tar.gz"
    __agh_path="AdguardTeam/AdGuardHome/releases/latest/download/${__agh_file}"

    __agh_urls="\
https://ghfast.top/https://github.com/${__agh_path}
https://mirror.ghproxy.com/https://github.com/${__agh_path}
https://github.com/${__agh_path}"

    mkdir -p "$__dl" "$__ab"

    # 检查已有二进制是否可用
    if [ -f "$__ab/AdGuardHome" ]; then
        if _timeout 5 "$__ab/AdGuardHome" --version >/dev/null 2>&1; then
            return 0
        fi
        _log "AGH 二进制损坏，重新下载..."
        rm -f "$__ab/AdGuardHome"
    fi

    # 检查已有完整 tgz（只用 gzip -t 验证）
    __need_download=1
    if [ -f "$__atgz" ]; then
        __sz=$(wc -c < "$__atgz" 2>/dev/null || echo 0)
        if [ "${__sz:-0}" -gt 1048576 ] && gzip -t "$__atgz" 2>/dev/null; then
            _log "复用已有 AGH 压缩包 ($(( __sz / 1048576 ))MB)"
            __need_download=0
        else
            _log "已有压缩包不完整(${__sz}B)，续传/重下"
            [ -f "$__atgz" ] && mv "$__atgz" "$__atmp" 2>/dev/null
        fi
    fi

    if [ "$__need_download" -eq 1 ]; then
        __dl_ok=0
        __src_idx=0

        for __url in $__agh_urls; do
            [ -z "$__url" ] && continue
            __src_idx=$((__src_idx + 1))
            __src_label=$(echo "$__url" | sed 's|https://||;s|/.*||')
            _log "下载源 ${__src_idx}: ${__src_label}"

            __existing=0
            [ -f "$__atmp" ] && __existing=$(wc -c < "$__atmp" 2>/dev/null || echo 0)

            if [ "${__existing:-0}" -gt 1048576 ]; then
                _log "续传 (已有 $(( __existing / 1048576 ))MB)..."
                wget -4 -q --timeout=300 --tries=1 -c -O "$__atmp" "$__url" 2>/dev/null
            else
                rm -f "$__atmp" 2>/dev/null
                wget -4 -q --timeout=300 --tries=1 -O "$__atmp" "$__url" 2>/dev/null
            fi

            if [ -f "$__atmp" ]; then
                __sz=$(wc -c < "$__atmp" 2>/dev/null || echo 0)
                _log "已下载: $(( ${__sz:-0} / 1048576 ))MB"

                # 主判断：gzip -t 验证完整性，大小 >1MB 防空文件
                if [ "${__sz:-0}" -gt 1048576 ] && gzip -t "$__atmp" 2>/dev/null; then
                    mv "$__atmp" "$__atgz"
                    __dl_ok=1
                    _log "AGH 下载完成 ($(( __sz / 1048576 ))MB)"
                    break
                elif [ "${__sz:-0}" -gt 1048576 ]; then
                    # 有内容但 gzip 验证失败 → 下载中断，换源续传
                    _log "压缩包不完整($(( __sz / 1048576 ))MB)，换源续传..."
                    sleep 5
                    continue
                else
                    _log "下载过少(${__sz}B)，清除重试"
                    rm -f "$__atmp" 2>/dev/null
                    sleep 10
                fi
            else
                _log "wget 无输出，换源..."
                sleep 5
            fi
        done

        # 救援：tmp 可能已完整
        if [ "$__dl_ok" -eq 0 ] && [ -f "$__atmp" ]; then
            __sz=$(wc -c < "$__atmp" 2>/dev/null || echo 0)
            if [ "${__sz:-0}" -gt 1048576 ] && gzip -t "$__atmp" 2>/dev/null; then
                _log "救援: tmp 文件完整，使用"
                mv "$__atmp" "$__atgz"
                __dl_ok=1
            else
                _log "救援失败: tmp 大小=${__sz}B，gzip 验证未通过"
                rm -f "$__atmp" 2>/dev/null
            fi
        fi

        if [ "$__dl_ok" -eq 0 ]; then
            _log "[ERR] AGH 所有下载源均失败"
            return 1
        fi
    fi

    # 解压
    _log "解压 AGH..."
    __xtmp="$__dl/agh-xtmp$$"
    rm -rf "$__xtmp"; mkdir -p "$__xtmp"

    tar xzf "$__atgz" -C "$__xtmp" 2>/dev/null || {
        _log "[ERR] AGH 解压失败，压缩包损坏"
        rm -rf "$__xtmp"; rm -f "$__atgz" 2>/dev/null
        return 1
    }

    if [ ! -f "$__xtmp/AdGuardHome/AdGuardHome" ]; then
        _log "[ERR] AGH 解压后二进制不存在，包结构异常"
        rm -rf "$__xtmp"; rm -f "$__atgz" 2>/dev/null
        return 1
    fi

    cp "$__xtmp/AdGuardHome/AdGuardHome" "$__ab/AdGuardHome" || {
        _log "[ERR] AGH 二进制复制失败（磁盘空间不足？）"
        rm -rf "$__xtmp"
        return 1
    }
    rm -rf "$__xtmp"
    chmod +x "$__ab/AdGuardHome"

    if ! _timeout 5 "$__ab/AdGuardHome" --version >/dev/null 2>&1; then
        _log "[ERR] AGH 二进制无法执行（架构不匹配？）"
        rm -f "$__ab/AdGuardHome" "$__atgz" 2>/dev/null
        return 1
    fi

    _av=$("$__ab/AdGuardHome" --version 2>/dev/null | grep -oE 'v[0-9]+\.[0-9]+\.[0-9]+' | head -1 || echo "?")
    echo "$_av" > "$__ab/version.txt"
    _log "AGH 就绪 ($_av)"
    return 0
}
LIBEOF
chmod +x /usr/lib/install-extras/lib.sh

# ============================================================
# 2/16  install-usb.sh
# ============================================================
cat > /usr/lib/install-extras/install-usb.sh << 'USBEOF'
#!/bin/sh
_LT="usb-extras"
. /usr/lib/install-extras/lib.sh

_LOCK="/tmp/install-usb.lock"
_SD="/etc/install-state"
_MF="/etc/install-usb-mount"
_DOCKER_VERS="28.1.0 27.5.1 26.1.4"
_DOCKER_BASE="https://download.docker.com/linux/static/stable/aarch64"
_DOCKER_EXPECTED_SHA256="${DOCKER_SHA256:-}"
_STRICT_CHECKSUM="${STRICT_CHECKSUM:-0}"
_USB=""

_log() {
    __msg="[$(date '+%H:%M:%S')] $1"
    [ -n "$DEBUG" ] && echo "$__msg" >&2
    printf '%s\n' "$__msg" | logger -t "usb-extras"
    [ -n "${_USB:-}" ] && {
        __ld="$_USB/.install-log"; mkdir -p "$__ld" 2>/dev/null
        echo "$__msg" >> "$__ld/$(date '+%Y-%m-%d').log" 2>/dev/null
        find "$__ld" -name "*.log" -mtime +7 -delete 2>/dev/null
    }
}

_check_and_format_usb() {
    __mp="$1"
    __dev=$(awk -v mp="$__mp" '$2==mp{print $1; exit}' /proc/mounts 2>/dev/null)
    __fs=$(awk -v mp="$__mp" '$2==mp{print $3; exit}' /proc/mounts 2>/dev/null)
    case "${__fs:-}" in
        ext2|ext3|ext4|btrfs|xfs|f2fs)
            _log "U 盘文件系统: ${__fs}（支持 swap）"; return 0 ;;
        vfat|exfat|fat|fat32|ntfs|ntfs3|fuseblk|lowntfs-3g|hfsplus|msdos)
            _log "U 盘文件系统: ${__fs}，自动格式化为 ext4" ;;
        *)
            # 未知文件系统也格式化，不再静默跳过
            _log "U 盘文件系统: ${__fs:-未知}，尝试格式化为 ext4" ;;
    esac
    # 后续格式化流程...
    if ! command -v mkfs.ext4 >/dev/null 2>&1; then
        _log "安装 e2fsprogs..."; _pkg_install e2fsprogs 2>/dev/null
        command -v mkfs.ext4 >/dev/null 2>&1 || { _log "mkfs.ext4 不可用，跳过"; return 0; }
    fi
    _log "停止服务..."
    /etc/init.d/adguardhome stop 2>/dev/null; /etc/init.d/dockerd stop 2>/dev/null
    pkill -f "AdGuardHome" 2>/dev/null; pkill dockerd 2>/dev/null; sleep 2
    rm -f "$__mp/.install-done" "$__mp/.agh-finalized" 2>/dev/null
    rm -f "$_SD/docker-failures" "$_SD/agh-failures" 2>/dev/null
    rm -f "$_SD/docker-done" "$_SD/agh-done" 2>/dev/null
    _is_swap_active "$__mp/swapfile" && swapoff "$__mp/swapfile" 2>/dev/null
    _log "卸载 $__mp..."; umount "$__mp" 2>/dev/null
    _is_mounted "$__mp" && umount -l "$__mp" 2>/dev/null
    _log "格式化 $__dev → ext4..."
    mkfs.ext4 -L "OPENWRT-USB" -F "$__dev" >/dev/null 2>&1
    if [ $? -ne 0 ]; then
        _log "[ERR] 格式化失败"; mount "$__dev" "$__mp" 2>/dev/null; return 0
    fi
    mkdir -p "$__mp"
    mount -t ext4 "$__dev" "$__mp" 2>/dev/null || mount "$__dev" "$__mp" 2>/dev/null
    if _is_mounted "$__mp"; then
        _log "挂载成功: $__mp (ext4)"; return 2
    else
        _log "[ERR] 挂载失败"; return 1
    fi
}

__self_heal=0; __force=0; __mp_arg=""
for _a in "$@"; do
    case "$_a" in --self-heal) __self_heal=1 ;; --force) __force=1 ;; *) [ -z "$__mp_arg" ] && __mp_arg="$_a" ;; esac
done

if [ "$__self_heal" -eq 1 ]; then
    [ -f /etc/install-extras-done ] || exit 0
    _USB=$(_get_usb_mount); [ -z "$_USB" ] && exit 0
    [ -f "${_USB}/.install-done" ] || exit 0
    __last=$(cat "$_SD/last-self-heal" 2>/dev/null || echo 0)
    __now=$(awk '{printf "%d",$1}' /proc/uptime 2>/dev/null || echo 0)
    [ "$((__now - __last))" -lt 300 ] && exit 0
    echo "$__now" > "$_SD/last-self-heal"
    exec /usr/lib/install-extras/install-usb.sh "$_USB"
fi

[ -n "$__mp_arg" ] && _is_mounted "$__mp_arg" && _USB="$__mp_arg"
[ -z "$_USB" ] && _USB=$(_get_usb_mount)
[ -z "$_USB" ] && { echo "未找到已挂载的 U 盘"; exit 1; }
__dev=$(awk -v mp="$_USB" '$2==mp{print $1; exit}' /proc/mounts 2>/dev/null)
_is_usb_dev "$__dev" || { _log "设备 ${__dev:-未知} 不是 USB，跳过"; exit 0; }

_USB_DONE="${_USB}/.install-done"
_check_and_format_usb "$_USB"; __fmt_rc=$?
[ "$__fmt_rc" -eq 1 ] && { _log "格式化失败，终止"; exit 1; }
[ "$__force" -eq 0 ] && [ -f "$_USB_DONE" ] && {
    _log "检测到部署标记，转入恢复"; exec /usr/lib/install-extras/restore.sh "$_USB"
}
[ "$__force" -eq 1 ] && {
    rm -f "$_USB_DONE" "$_SD/docker-done" "$_SD/agh-done"
    rm -f "$_SD/docker-failures" "$_SD/agh-failures" "$_USB/.agh-finalized"
    rm -f "$_USB/.agh-download-fails" 2>/dev/null
    _log "--force: 状态已清零"
}

_acquire_lock "$_LOCK" || { _log "另一个实例在运行"; exit 0; }

echo "$_USB" > "$_MF"
__dns_bak=$(cat /etc/resolv.conf 2>/dev/null)

_cleanup() {
    _release_lock "$_LOCK"
    _restore_dns_safe "$__dns_bak" "$_USB"
    sync 2>/dev/null || true
}
trap '_cleanup' EXIT INT TERM

_log "全新部署 | $_USB ($__dev)"

if [ ! -f "${_USB}/.agh-finalized" ]; then
    _up=$(_get_upstream_dns)
    echo "nameserver $_up" > /etc/resolv.conf
    echo "nameserver 223.5.5.5" >> /etc/resolv.conf
    _log "临时 DNS 已注入 ($_up)"
fi

__free=$(df -k "$_USB" 2>/dev/null | awk 'NR==2{print $4}')
[ "${__free:-0}" -lt 1048576 ] && { _log "空间不足 <1GB"; exit 1; }
__dl="$_USB/.downloads"; mkdir -p "$__dl"

# ── Swap ─────────────────────────────────────────────────────
_swap_mb=256
_ram=$(awk '/MemTotal/{printf "%d",$2/1024}' /proc/meminfo 2>/dev/null)
[ "${_ram:-0}" -lt 256 ] && _swap_mb=512
__sf="$_USB/swapfile"
if ! _is_swap_active "$__sf"; then
    __cur_fs=$(awk -v mp="$_USB" '$2==mp{print $3; exit}' /proc/mounts 2>/dev/null)
    case "${__cur_fs:-}" in
        ext2|ext3|ext4|btrfs|xfs|f2fs)
            if [ ! -f "$__sf" ]; then
                _log "创建 ${_swap_mb}MB swap..."
                dd if=/dev/zero of="${__sf}.tmp" bs=1M count=$_swap_mb 2>/dev/null
                sync 2>/dev/null
                __sw_written=$(wc -c < "${__sf}.tmp" 2>/dev/null || echo 0)
                __sw_expected=$(( _swap_mb * 1048576 ))
                if [ "${__sw_written:-0}" -ge "$__sw_expected" ]; then
                    mv "${__sf}.tmp" "$__sf" && chmod 600 "$__sf" && \
                        mkswap "$__sf" >/dev/null 2>&1 || { rm -f "$__sf" 2>/dev/null; _log "swap mkswap 失败"; }
                else
                    _log "swap 创建失败（dd 写入 ${__sw_written:-0} bytes，期望 ${__sw_expected} bytes）"
                    rm -f "${__sf}.tmp" 2>/dev/null
                fi
            fi
            # FIX V1.2: swapon 后验证写入，检测坏块
            if [ -f "$__sf" ]; then
                swapon -p 0 "$__sf" 2>/dev/null
                sleep 1
