    _resp=$(curl -s --max-time 3 --user "${_user}:${_pass}" "http://127.0.0.1:${_p}/control/status" 2>/dev/null)
    if echo "$_resp" | grep -q '"dns_addresses"'; then
        _agh_port="$_p"; break
    fi
