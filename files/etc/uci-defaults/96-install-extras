#!/bin/sh
[ "${ACTION:-}" = "ifup" ] || exit 0
case "${INTERFACE:-}" in wan|wan6|pppoe-wan) ;; *) exit 0 ;; esac
[ -f /etc/install-extras-done ] && exit 0

_WAN_COOLDOWN="/tmp/wan-cooldown"
_get_uptime_sec() {
    awk '{print int($1)}' /proc/uptime 2>/dev/null || echo 0
}
if [ -f "$_WAN_COOLDOWN" ]; then
    _last=$(cat "$_WAN_COOLDOWN" 2>/dev/null || echo 0)
    _now=$(_get_uptime_sec)
    _elapsed=$((_now - _last))
    [ "$_elapsed" -lt 60 ] && exit 0
fi

/usr/lib/install-extras/run.sh &
IFACEEOF
chmod +x /etc/hotplug.d/iface/96-install-extras

cat > /etc/hotplug.d/block/96-install-usb << 'BLOCKEOF'
#!/bin/sh
case "${DEVNAME:-}" in sd[a-z]*|mmcblk[0-9]*) ;; *) exit 0 ;; esac

if [ "${ACTION:-}" = "remove" ]; then
    if [ -f /etc/install-usb-done ]; then
        logger -t "usb-extras" "U 盘移除，暂停依赖服务"
        /etc/init.d/dockerd stop 2>/dev/null
        /etc/init.d/adguardhome stop 2>/dev/null
    fi
    exit 0
fi

[ "${ACTION:-}" = "add" ] || exit 0
[ -f /etc/install-usb-done ]    && exit 0
[ -f /etc/install-extras-done ] || exit 0

_mp=""
_i=1
while [ "$_i" -le 12 ]; do
    for _m in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        grep -q "^[^ ]* $_m " /proc/mounts 2>/dev/null && { _mp="$_m"; break 2; }
    done
    sleep 2; _i=$((_i + 1))
done

[ -n "$_mp" ] && /usr/lib/install-extras/install-usb.sh "$_mp" &
BLOCKEOF
chmod +x /etc/hotplug.d/block/96-install-usb

