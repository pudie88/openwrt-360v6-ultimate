chmod +x /etc/hotplug.d/block/96-install-usb

# ══════════════════════════════════════════════════════════════
# 模块 E：360v6-health 健康检查
# ══════════════════════════════════════════════════════════════
cat > /usr/bin/360v6-health << 'HEALTHEOF'
#!/bin/sh
# 用法：360v6-health [--fix]
_is_mounted() { grep -q "^[^ ]* $1 " /proc/mounts 2>/dev/null; }
log() {
    __hm="[$(date '+%Y-%m-%d %H:%M:%S')] $1"
    echo "$__hm"
    echo "$__hm" | logger -t "health-check"
}

__fix=0
for _a in "$@"; do [ "$_a" = "--fix" ] && __fix=1; done

__status=0
__failed=""

# 检查：U 盘挂载（仅在部署完成后检查）
if [ -f /etc/install-usb-done ]; then
    __usb_mp=$(cat /etc/install-usb-mount 2>/dev/null)
    # 文件存在但路径为空：跳过（可能是旧版部署）
    if [ -n "$__usb_mp" ] && ! _is_mounted "$__usb_mp"; then
        log "严重：部署 U 盘 ($__usb_mp) 未挂载"
        __status=1; __failed="$__failed usb-mount"
    fi
fi

# 检查：Docker
if [ -f /etc/install-usb-done ]; then
    if ! docker info >/dev/null 2>&1; then
        log "Docker 未运行"
        if [ "$__fix" -eq 1 ]; then
            /etc/init.d/dockerd restart 2>/dev/null; sleep 5
            docker info >/dev/null 2>&1 \
                && log "Docker 已恢复" \
                || { log "Docker 重启失败"; __status=1; __failed="$__failed docker"; }
        else
            __status=1; __failed="$__failed docker"
        fi
    fi
fi

# 检查：AdGuardHome
if [ -f /etc/install-usb-done ]; then
    if ! pgrep -x AdGuardHome >/dev/null 2>&1; then
        log "AdGuardHome 未运行"
        if [ "$__fix" -eq 1 ]; then
            /etc/init.d/adguardhome restart 2>/dev/null; sleep 3
            pgrep -x AdGuardHome >/dev/null 2>&1 \
                && log "AdGuardHome 已恢复" \
                || { log "AdGuardHome 重启失败"; __status=1; __failed="$__failed adguardhome"; }
        else
            __status=1; __failed="$__failed adguardhome"
        fi
    fi
fi

# 检查：Phase 2 安装失败（即使 usb-done 不存在也要报告）
if [ ! -f /etc/install-usb-done ]; then
    __p2f=$(cat /etc/install-state/phase2-failures 2>/dev/null || echo 0)
    __usb_mp2=$(cat /etc/install-usb-mount 2>/dev/null)
    if [ "${__p2f:-0}" -gt 0 ] && [ -n "$__usb_mp2" ]; then
        log "重型应用安装失败（$__p2f/3 次）- U 盘已就绪但部署未完成"
        # 提示用户检查缓存损坏
        if [ -d "$__usb_mp2/.downloads" ]; then
            for _cf in "$__usb_mp2/.downloads"/*.tgz "$__usb_mp2/.downloads"/*.tar.gz; do
                [ -f "$_cf" ] || continue
                tar -tzf "$_cf" >/dev/null 2>&1 \
                    || log "  损坏缓存: $(basename $_cf)"
            done
        fi
        if [ "$__fix" -eq 1 ]; then
            log "--fix: 清理失败计数并触发重试..."
            rm -f /etc/install-state/phase2-failures
            /usr/lib/install-extras/install-usb.sh "$__usb_mp2" --force &
            log "Phase 2 重试已在后台启动"
        else
            __status=1; __failed="$__failed phase2-install"
        fi
    elif [ -n "$__usb_mp2" ]; then
        log "重型应用：U 盘已就绪，等待首次触发"
    fi
fi

# 检查：Swap
if [ -f /etc/install-usb-done ]; then
    if ! grep -q swapfile /proc/swaps 2>/dev/null; then
        log "Swap 未激活"
        if [ "$__fix" -eq 1 ]; then
            __usb_mp=$(cat /etc/install-usb-mount 2>/dev/null)
            [ -n "$__usb_mp" ] && [ -f "$__usb_mp/swapfile" ] \
                && swapon "$__usb_mp/swapfile" 2>/dev/null \
                && log "Swap 已恢复" \
                || { log "Swap 恢复失败"; __status=1; __failed="$__failed swap"; }
        else
            __status=1; __failed="$__failed swap"
        fi
    fi
fi

# 检查：Flash 使用率
__flash_pct=$(df /overlay 2>/dev/null | awk 'NR==2{print $5}' | tr -d '%')
if [ "${__flash_pct:-0}" -gt 90 ]; then
    log "Flash 使用率过高（${__flash_pct}%），建议: apk cache clean"
    __status=1; __failed="$__failed flash-space"
fi

if [ "$__status" -eq 0 ]; then
    log "健康检查通过"
else
    log "健康检查异常:$__failed"
    [ "$__fix" -eq 0 ] && log "使用 '360v6-health --fix' 尝试自动修复"
fi
exit "$__status"
HEALTHEOF
chmod +x /usr/bin/360v6-health

# ══════════════════════════════════════════════════════════════
# 模块 F：cron 自愈（每 5 分钟，仅在 Phase 1 完成后生效）
# ══════════════════════════════════════════════════════════════
if ! grep -q "install-usb.sh --self-heal" /etc/crontabs/root 2>/dev/null; then
    mkdir -p /etc/crontabs
    echo "*/5 * * * * PATH=/usr/bin:/bin:/usr/sbin:/sbin /usr/lib/install-extras/install-usb.sh --self-heal 2>&1 | logger -t self-heal" \
        >> /etc/crontabs/root
