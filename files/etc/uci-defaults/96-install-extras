_timeout() {
    __tt="$1"; shift
    if command -v timeout >/dev/null 2>&1; then
        timeout "$__tt" "$@" 2>/dev/null; return $?
    fi
    "$@" &
    __pid=$!; __cnt=0
    while [ "$__cnt" -lt "$__tt" ]; do
        kill -0 "$__pid" 2>/dev/null || { wait "$__pid"; return $?; }
        sleep 1; __cnt=$((__cnt + 1))
    done
    kill -9 "$__pid" 2>/dev/null
    wait "$__pid" 2>/dev/null
    return 124
}

_tar_extract() {
    __tgz="$1"; __dst="$2"; __subdir="$3"
    __tmp="${__dst}.xtmp$$"
    rm -rf "$__tmp"
    mkdir -p "$__tmp" "$__dst" || return 1
    tar xzf "$__tgz" -C "$__tmp" 2>/dev/null || { rm -rf "$__tmp"; return 1; }
    if [ -n "$__subdir" ] && [ -d "$__tmp/$__subdir" ]; then
        __src="$__tmp/$__subdir"
    else
        __src="$__tmp"
    fi
    __moved=0
    for __f in "$__src/"*; do
        [ -e "$__f" ] || continue
        rm -rf "$__dst/${__f##*/}"
        mv "$__f" "$__dst/" 2>/dev/null || { rm -rf "$__tmp"; return 1; }
        __moved=$((__moved + 1))
    done
    rm -rf "$__tmp"
    [ "$__moved" -gt 0 ]
}

_wget_retry() {
    __url="$1"; __out="$2"; __min_size="${3:-0}"
    __r=0
    while [ "$__r" -lt 3 ]; do
        wget -q --timeout=120 --tries=1 -O "$__out" "$__url" 2>/dev/null
        if [ -f "$__out" ]; then
            __sz=$(wc -c < "$__out" 2>/dev/null || echo 0)
            if [ "${__sz:-0}" -ge "$__min_size" ] && [ "${__sz:-0}" -gt 0 ]; then
                return 0
            fi
        fi
        rm -f "$__out"
        __r=$((__r + 1))
        [ "$__r" -lt 3 ] && { log "下载失败 (${__r}/3)，重试..."; sleep 3; }
    done
    return 1
}

_sha256() {
    if command -v sha256sum >/dev/null 2>&1; then
        sha256sum "$1" 2>/dev/null | cut -d' ' -f1
    elif command -v openssl >/dev/null 2>&1; then
        openssl dgst -sha256 "$1" 2>/dev/null | cut -d' ' -f2
    else
        echo ""
    fi
}

_verify_checksum() {
    __file="$1"; __expected="$2"; __name="$3"
    [ -z "$__expected" ] && return 0
    __actual=$(_sha256 "$__file")
    [ -z "$__actual" ] && return 0
    if [ "$__actual" = "$__expected" ]; then
        log "$__name 校验通过"
        return 0
    fi
    log "错误: $__name 校验和不匹配"
    [ "$_STRICT_CHECKSUM" = "1" ] && return 1
    return 0
}

_pkg_install() {
    if command -v apk >/dev/null 2>&1; then
        apk add --no-cache "$@" >/dev/null 2>&1
    elif command -v opkg >/dev/null 2>&1; then
        opkg install "$@" >/dev/null 2>&1
    else
        return 1
