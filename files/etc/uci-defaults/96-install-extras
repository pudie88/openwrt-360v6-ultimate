}

if [ -f "$_LOCK" ]; then
    __lp=$(cat "$_LOCK" 2>/dev/null)
    kill -0 "$__lp" 2>/dev/null && exit 0
    rm -f "$_LOCK"
fi
echo $$ > "$_LOCK"

__fail=$(cat "$_SD/phase1-failures" 2>/dev/null || echo 0)
[ "${__fail:-0}" -ge 3 ] && { rm -f "$_LOCK"; exit 1; }

log "基础环境启动"
sleep 10

# 等网络（最多 60s）
__ok=0
for _i in $(seq 1 12); do
    ping -c1 -W2 223.5.5.5 >/dev/null 2>&1 && { __ok=1; break; }
    sleep 5
done
if [ "$__ok" -eq 0 ]; then
    echo $((__fail + 1)) > "$_SD/phase1-failures"
