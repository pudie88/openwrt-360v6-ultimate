    fi
    if pgrep -f "AdGuardHome" >/dev/null 2>&1; then
        _ok "AGH ${_aver}: 运行中（Web:${_wp}）"
        [ ! -f "$_USB/.agh-finalized" ] && { _warn "AGH 待完成向导"; _hint "访问 http://192.168.2.1:${_wp} 然后执行 agh-finalize"; }
        if command -v curl >/dev/null 2>&1 && [ -f "$_USB/.agh-finalized" ]; then
            _au=$(cat "$_USB/.agh-user" 2>/dev/null)
            _ap=$(cat "$_USB/.agh-pass" 2>/dev/null)
            if [ -n "$_au" ]; then
                _stats=$(curl -s --max-time 3 --user "${_au}:${_ap}" "http://127.0.0.1:${_wp}/control/stats" 2>/dev/null)
            else
                _stats=$(curl -s --max-time 3 "http://127.0.0.1:${_wp}/control/stats" 2>/dev/null)
            fi
            if echo "$_stats" | grep -q '"num_dns_queries"'; then
                _total=$(echo "$_stats" | grep -o '"num_dns_queries":[0-9]*' | cut -d: -f2)
                _blocked=$(echo "$_stats" | grep -o '"num_blocked_filtering":[0-9]*' | cut -d: -f2)
                _bpct=0; [ "${_total:-0}" -gt 0 ] && _bpct=$(( _blocked * 100 / _total ))
