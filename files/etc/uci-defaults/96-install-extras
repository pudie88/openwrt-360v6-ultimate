#!/bin/sh
# 96-install-extras [v2]
# 适用：360 V6 / 小米 CR660x / IPQ6000 (128M Flash / ImmortalWrt / busybox ash)
#
# v2 修复清单（相对 v1）：
#   1. [关键] Docker/AGH if/else/fi 嵌套修复：去除悬空 fi，补全 already-done 跳过块的正确闭合
#   2. [关键] Docker 解压验证：tar --strip-components=1 后检测 dockerd 存在再落盘缓存；
#             失败时不缓存 tgz，避免下次命中损坏缓存
#   3. [关键] AGH 启动检测时序修正：sleep 改为轮询（最多 15s），写 agh-done 前确认进程存活
#   4. [中等] self-heal 无限循环修复：Docker:FAIL + AGH:OK 时正确写 _DONE（改为仅 Docker 失败
#             时保留 self-heal cron 且以 phase2-failures 计数保护），AGH:OK 后不再被触发
#   5. [中等] AGH 端口检测移除：start_service 中不再检测 53 端口，改为纯进程存活判断
#   6. [中等] 360v6-status 新增组件级完成状态（docker-done / agh-done）
#   7. [小]   卸载脚本补全 docker-done / agh-done / phase1-failures / phase2-failures 清理
#   8. [小]   _is_usb_dev 与 awk fallback 保持一致（裸盘 sda 允许通过 fallback 但 _is_usb_dev 拒绝）
#             修复：awk fallback 也加分区号过滤，与 _is_usb_dev 逻辑统一

_STATE_DIR="/etc/install-state"
mkdir -p "$_STATE_DIR" /usr/lib/install-extras /usr/bin \
         /etc/hotplug.d/iface /etc/hotplug.d/block \
         /etc/dbus-1 /etc/dbus-1/system.d /etc/crontabs

# ====================================================================
# 预置系统级修复（nlbwmon 缓冲区）
# ====================================================================
echo "1048576" > /proc/sys/net/core/rmem_max 2>/dev/null
echo "1048576" > /proc/sys/net/core/wmem_max 2>/dev/null

# ====================================================================
# 模块 0：360v6-status
# ====================================================================
cat > /usr/bin/360v6-status << 'STATUSEOF'
#!/bin/sh
_SD="/etc/install-state"
_is_mounted() { grep -q "^[^ ]* $1 " /proc/mounts 2>/dev/null; }

echo "=== 360 V6 状态 @ $(date '+%Y-%m-%d %H:%M:%S') ==="
echo ""

if [ -f /etc/install-extras-done ]; then
    echo "[OK] 基础环境：已完成 ($(cat /etc/install-extras-done 2>/dev/null))"
else
    echo "[..] 基础环境：待触发"
    _p1=$(cat "$_SD/phase1-failures" 2>/dev/null || echo 0)
    [ "$_p1" -gt 0 ] && echo "     失败次数: $_p1/3"
fi

# 组件级状态（v2 新增）
_docker_done=0; _agh_done=0
[ -f "$_SD/docker-done" ] && _docker_done=1
[ -f "$_SD/agh-done"    ] && _agh_done=1

if [ -f /etc/install-usb-done ]; then
    echo "[OK] 重型应用：已完成 ($(cat /etc/install-usb-done 2>/dev/null))"
    echo "     Docker : $([ "$_docker_done" -eq 1 ] && echo "OK ($(cat "$_SD/docker-done" 2>/dev/null))" || echo "未完成")"
    echo "     AGH    : $([ "$_agh_done"    -eq 1 ] && echo "OK ($(cat "$_SD/agh-done"    2>/dev/null))" || echo "未完成")"
else
    echo "[..] 重型应用：待 U 盘"
    _p2=$(cat "$_SD/phase2-failures" 2>/dev/null || echo 0)
    [ "$_p2" -gt 0 ] && echo "     失败次数: $_p2/3"
    if [ "$_docker_done" -eq 1 ] || [ "$_agh_done" -eq 1 ]; then
        echo "     已完成组件："
        [ "$_docker_done" -eq 1 ] && echo "       Docker : OK ($(cat "$_SD/docker-done" 2>/dev/null))"
        [ "$_agh_done"    -eq 1 ] && echo "       AGH    : OK ($(cat "$_SD/agh-done"    2>/dev/null))"
    fi
fi

echo ""
df -h /overlay 2>/dev/null | awk 'NR==2{print "Flash : "$3" / "$2" ("$5")"}'
free 2>/dev/null | awk '/Mem:/{printf "Mem   : %dMB used / %dMB total\n",$3/1024,$2/1024}'
echo ""

_USB=""
for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
    _is_mounted "$_mp" && { echo "USB   : $_mp (已挂载)"; _USB="$_mp"; break; }
done
[ -z "$_USB" ] && echo "USB   : 未检测到"
[ -f /etc/install-usb-mount ] && echo "PATH  : $(cat /etc/install-usb-mount)"
grep -q swapfile /proc/swaps 2>/dev/null && echo "Swap  : swapfile 已激活"
grep -q zram     /proc/swaps 2>/dev/null && echo "Swap  : zram 已激活"
echo ""

if docker info >/dev/null 2>&1; then
    _dv=$(docker version --format '{{.Server.Version}}' 2>/dev/null)
    echo "[OK] Docker      : ${_dv:-运行中}"
else
    echo "[--] Docker      : 未启动"
fi

if pgrep -x AdGuardHome >/dev/null 2>&1; then
    _av=$(AdGuardHome --version 2>&1 | grep -oE 'v[0-9.]+' | head -1)
    echo "[OK] AdGuardHome : ${_av:-运行中}"
else
    echo "[--] AdGuardHome : 未启动"
fi

echo ""
echo "重跑基础: rm -f /etc/install-extras-done $_SD/phase1-failures && /usr/lib/install-extras/run.sh"
echo "重跑重型: rm -f /etc/install-usb-done && /usr/lib/install-extras/install-usb.sh --force"
echo "健康检查: 360v6-health [--fix]"
echo "卸载    : 360v6-uninstall"
STATUSEOF
chmod +x /usr/bin/360v6-status

# ====================================================================
# 模块 A：install-usb.sh（Phase 2）
# ====================================================================
cat > /usr/lib/install-extras/install-usb.sh << 'USBEOF'
#!/bin/sh
_LT="usb-extras"
_DONE="/etc/install-usb-done"
_LOCK="/tmp/install-usb.lock"
_SD="/etc/install-state"
_MF="/etc/install-usb-mount"

_DOCKER_VERS="28.1.0 28.0.4 27.5.1 26.1.4 25.0.5 24.0.7"
_DOCKER_BASE="https://download.docker.com/linux/static/stable/aarch64"
_AGH_URL="https://static.adguard.com/adguardhome/release/AdGuardHome_linux_arm64.tar.gz"

log() { __lm="[$(date '+%H:%M:%S')] $1"; echo "$__lm"; echo "$__lm" | logger -t "$_LT"; }
_is_mounted() { grep -q "^[^ ]* $1 " /proc/mounts 2>/dev/null; }
_is_usb_dev() {
    # 只匹配有分区号的设备（sda1、sdb2、mmcblk0p1），拒绝裸盘（sda、mmcblk0）
    case "$1" in
        /dev/sd[a-z][0-9]*|/dev/mmcblk[0-9]*p[0-9]*) return 0 ;;
        *) return 1 ;;
    esac
}

mkdir -p "$_SD"
__self_heal=0; __force=0; __mp_arg=""
for _a in "$@"; do
    case "$_a" in
        --self-heal) __self_heal=1 ;;
        --force)     __force=1 ;;
        --*)         ;;
        *)           [ -z "$__mp_arg" ] && __mp_arg="$_a" ;;
    esac
done

# 自愈模式
if [ "$__self_heal" -eq 1 ]; then
    [ -f /etc/install-extras-done ] || exit 0
    [ -f "$_DONE" ] && exit 0
    __sf=$(cat "$_SD/phase2-failures" 2>/dev/null || echo 0)
    [ "${__sf:-0}" -ge 3 ] && exit 0
    if [ -f "$_LOCK" ]; then
        __lp=$(cat "$_LOCK" 2>/dev/null)
        kill -0 "$__lp" 2>/dev/null && exit 0
        rm -f "$_LOCK"
    fi
    for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        _is_mounted "$_mp" && { log "自愈触发: $_mp"; exec /usr/lib/install-extras/install-usb.sh "$_mp"; }
    done
    exit 0
fi

[ -f "$_DONE" ] && { log "已完成，跳过"; exit 0; }

__dns_old=$(cat /etc/resolv.conf 2>/dev/null)
[ -z "$__dns_old" ] && __dns_old="nameserver 127.0.0.1"
_dns_restore() {
    printf '%s\n' "$__dns_old" > /etc/resolv.conf
    sync 2>/dev/null || true
    /etc/init.d/dnsmasq reload >/dev/null 2>&1 || true
}
trap 'rm -f "$_LOCK"; _dns_restore' EXIT INT TERM

if [ -f "$_LOCK" ]; then
    __lp=$(cat "$_LOCK" 2>/dev/null)
    kill -0 "$__lp" 2>/dev/null && { log "运行中 (pid=$__lp)，跳过"; exit 0; }
    rm -f "$_LOCK"
fi
echo $$ > "$_LOCK"

if [ "$__force" -eq 1 ]; then
    rm -f "$_SD/phase2-failures" "$_SD/docker-done" "$_SD/agh-done"
    __fail=0
    log "--force：失败计数及组件标记已清零"
else
    __fail=$(cat "$_SD/phase2-failures" 2>/dev/null || echo 0)
    [ "${__fail:-0}" -ge 3 ] && {
        log "失败次数过多（$__fail/3），停止自动重试"
        log "手动修复: rm -f /etc/install-usb-done $_SD/phase2-failures $_SD/docker-done $_SD/agh-done && $0 --force"
        exit 1
    }
fi

# 挂载点检测
_USB=""
[ -n "$__mp_arg" ] && _is_mounted "$__mp_arg" && _USB="$__mp_arg"
if [ -z "$_USB" ]; then
    for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        _is_mounted "$_mp" && { _USB="$_mp"; break; }
    done
fi
# [修复8] awk fallback 也过滤分区号，与 _is_usb_dev 保持一致
[ -z "$_USB" ] && \
    _USB=$(awk '/^\/dev\/(sd[a-z][0-9]+|mmcblk[0-9]+p[0-9]+) /{print $2; exit}' /proc/mounts 2>/dev/null)

if [ -z "$_USB" ]; then
    log "未找到 U 盘挂载点"
    echo $((__fail + 1)) > "$_SD/phase2-failures"
    exit 1
fi

__dev=$(awk -v mp="$_USB " '$0 ~ mp {print $1; exit}' /proc/mounts 2>/dev/null)
if ! _is_usb_dev "$__dev"; then
    log "设备 $__dev 不是 USB/SD，跳过"
    exit 0
fi

echo "$_USB" > "$_MF"
log "重型应用部署 | U 盘: $_USB ($__dev)"

__usb_free=$(df -k "$_USB" 2>/dev/null | awk 'NR==2{print $4}')
if [ "${__usb_free:-0}" -lt 1048576 ]; then
    log "U 盘空间不足（${__usb_free}KB < 1GB）"
    echo $((__fail + 1)) > "$_SD/phase2-failures"
    exit 1
fi

__wtest="$_USB/.write-test-$$"
if ! echo "ok" > "$__wtest" 2>/dev/null; then
    log "U 盘写入失败（只读？）"
    echo $((__fail + 1)) > "$_SD/phase2-failures"
    exit 1
fi
rm -f "$__wtest"

printf 'nameserver 223.5.5.5\nnameserver 8.8.8.8\n' > /etc/resolv.conf
log "临时 DNS 已注入"

__udev=$(echo "$__dev" | sed 's|/dev/||;s|[0-9]*$||')
__sched="/sys/block/${__udev}/queue/scheduler"
if [ -f "$__sched" ]; then
    grep -q "mq-deadline" "$__sched" 2>/dev/null \
        && echo "mq-deadline" > "$__sched" 2>/dev/null \
        || echo "deadline"    > "$__sched" 2>/dev/null
    log "I/O 调度器: $(grep -oE '\[[^]]+\]' "$__sched" 2>/dev/null | tr -d '[]')"
fi
echo "10"    > /proc/sys/vm/swappiness       2>/dev/null
echo "16384" > /proc/sys/vm/min_free_kbytes  2>/dev/null

__flash_free=$(df /overlay 2>/dev/null | awk 'NR==2{print $4}')
__skip_luci=0
[ "${__flash_free:-99999}" -lt 25000 ] && __skip_luci=1 && log "Flash <25MB，跳过 LuCI 插件"

__dl_dir="$_USB/.downloads"; mkdir -p "$__dl_dir"

_download() {
    __url="$1"; __out="$2"; __desc="$3"
    __i=1
    while [ "$__i" -le 3 ]; do
        log "下载 $__desc（$__i/3）..."
        wget -q --timeout=120 --tries=1 -O "${__out}.tmp" "$__url" 2>/dev/null \
            && mv "${__out}.tmp" "$__out" \
            && { log "下载完成: $__desc"; return 0; }
        rm -f "${__out}.tmp"
        log "下载失败: $__desc ($__i/3)"
        __i=$((__i + 1)); sleep 5
    done
    log "下载彻底失败: $__desc"
    return 1
}

# ========== Swap ==========
__swapfile="$_USB/swapfile"
if ! grep -q swapfile /proc/swaps 2>/dev/null; then
    if [ ! -f "$__swapfile" ]; then
        log "创建 256MB swapfile..."
        if dd if=/dev/zero of="${__swapfile}.tmp" bs=1M count=256 2>/dev/null; then
            mv "${__swapfile}.tmp" "$__swapfile"
            sync; chmod 600 "$__swapfile"
            mkswap "$__swapfile" >/dev/null 2>&1
        else
            rm -f "${__swapfile}.tmp"
            log "swapfile 创建失败"
        fi
    fi
    if [ -f "$__swapfile" ]; then
        swapon "$__swapfile" 2>/dev/null && log "swapfile 已激活"
        grep -qF "$__swapfile" /etc/fstab 2>/dev/null \
            || echo "$__swapfile none swap sw 0 0" >> /etc/fstab
    fi
fi

# ========== Docker ==========
_DOCKER_FAIL=0
log "--- Docker 部署 ---"

if [ -f "$_SD/docker-done" ]; then
    log "Docker 已完成（跳过）"
else
    # [修复1] 正确的 if/else/fi 结构——不再有悬空 fi

    __fs_type=$(awk -v mp="$_USB" '$2==mp {print $3; exit}' /proc/mounts 2>/dev/null)
    case "$__fs_type" in
        ext4) ;;
        *)
            if [ "$__force" -eq 1 ]; then
                log "⚠ 文件系统 ${__fs_type:-未知} 不支持 overlay2，自动格式化 $__dev 为 ext4..."
                umount "$_USB" 2>/dev/null
                if mkfs.ext4 -F "$__dev" >/dev/null 2>&1 && mount "$__dev" "$_USB"; then
                    log "格式化并重新挂载完成"
                    mkdir -p "$__dl_dir"
                    __fs_type="ext4"
                else
                    log "格式化或重挂载失败"
                    _DOCKER_FAIL=1
                fi
            else
                log "Docker 需要 ext4（当前: ${__fs_type:-未知}），使用 --force 自动格式化"
                _DOCKER_FAIL=1
            fi
            ;;
    esac

    __dbin="$_USB/docker-bin"; __ddata="$_USB/docker-data"

    if [ "$_DOCKER_FAIL" -eq 0 ]; then
        mkdir -p "$__dbin" "$__ddata" /etc/docker
        __docker_ver=""
        for _dv in $_DOCKER_VERS; do
            __dtgz_try="$__dl_dir/docker-${_dv}.tgz"
            # [修复2] 验证缓存：必须能解压出 dockerd 才算有效缓存
            if [ -f "$__dtgz_try" ]; then
                if tar -tzf "$__dtgz_try" 2>/dev/null | grep -q '/dockerd$\|^dockerd$'; then
                    log "使用缓存: docker-${_dv}.tgz"
                else
                    log "缓存损坏，删除: docker-${_dv}.tgz"
                    rm -f "$__dtgz_try"
                fi
            fi
            if [ ! -f "$__dtgz_try" ]; then
                log "尝试 Docker ${_dv}..."
                wget -q --timeout=120 -O "${__dtgz_try}.tmp" \
                        "$_DOCKER_BASE/docker-${_dv}.tgz" 2>/dev/null \
                    && mv "${__dtgz_try}.tmp" "$__dtgz_try" \
                    || { rm -f "${__dtgz_try}.tmp"; continue; }
                # 下载后立即验证包含 dockerd，不含则丢弃
                if ! tar -tzf "$__dtgz_try" 2>/dev/null | grep -q '/dockerd$\|^dockerd$'; then
                    log "Docker ${_dv} 包结构异常（无 dockerd），丢弃"
                    rm -f "$__dtgz_try"; continue
                fi
            fi
            # 解压：先试 --strip-components=1，失败则试扁平结构
            rm -rf "$__dbin"/* 2>/dev/null
            tar -xzf "$__dtgz_try" -C "$__dbin" --strip-components=1 2>/dev/null
            if [ ! -f "$__dbin/dockerd" ]; then
                rm -rf "$__dbin"/* 2>/dev/null
                tar -xzf "$__dtgz_try" -C "$__dbin" 2>/dev/null
            fi
            if [ -f "$__dbin/dockerd" ]; then
                log "Docker ${_dv} 就绪"
                __docker_ver="$_dv"; break
            else
                log "Docker ${_dv} 解压后无 dockerd，删除缓存，尝试下一版本"
                rm -f "$__dtgz_try"
            fi
        done
        [ -z "$__docker_ver" ] && { log "所有 Docker 版本均失败"; _DOCKER_FAIL=1; }
    fi

    if [ "$_DOCKER_FAIL" -eq 0 ]; then
        for _b in docker dockerd containerd containerd-shim-runc-v2 ctr runc; do
            [ -f "$__dbin/$_b" ] && ln -sf "$__dbin/$_b" "/usr/bin/$_b" 2>/dev/null
        done

        cat > /etc/docker/daemon.json << DOCKEREOF
{
  "data-root": "$__ddata",
  "storage-driver": "overlay2",
  "log-driver": "json-file",
  "log-opts": {"max-size": "5m", "max-file": "2"}
}
DOCKEREOF

        cat > /etc/init.d/dockerd << 'DINITEOF'
#!/bin/sh /etc/rc.common
START=99; STOP=10; USE_PROCD=1
start_service() {
    [ -f /etc/install-usb-done ] || return 0
    _mp=$(cat /etc/install-usb-mount 2>/dev/null)
    [ -n "$_mp" ] && [ -f "$_mp/docker-bin/dockerd" ] || return 1
    grep -q "^[^ ]* /sys/fs/cgroup " /proc/mounts 2>/dev/null \
        || mount -t cgroup2 none /sys/fs/cgroup 2>/dev/null || true
    procd_open_instance
    procd_set_param command "$_mp/docker-bin/dockerd" --config-file /etc/docker/daemon.json
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param respawn 3600 5 0
    procd_close_instance
}
stop_service() {
    pkill dockerd     2>/dev/null || true
    pkill containerd  2>/dev/null || true
}
DINITEOF
        chmod +x /etc/init.d/dockerd
        /etc/init.d/dockerd enable 2>/dev/null
        /etc/init.d/dockerd start  2>/dev/null
        sleep 3
        docker info >/dev/null 2>&1 \
            && log "Docker $__docker_ver 已启动" \
            || log "Docker 启动超时（后台可能仍在初始化）"

        [ "$__skip_luci" -eq 0 ] && \
            apk add --no-cache luci-app-dockerman luci-i18n-dockerman-zh-cn 2>/dev/null && \
            log "luci-app-dockerman 安装完成"
    fi
    # [修复1] docker-done 标记在 already-done 跳过块之外正确写入
    [ "$_DOCKER_FAIL" -eq 0 ] && date '+%Y-%m-%d %H:%M:%S' > "$_SD/docker-done"
fi  # end: if [ -f docker-done ] ... else ... fi

# ========== AdGuardHome ==========
_AGH_FAIL=0
log "--- AdGuardHome 部署 ---"

if [ -f "$_SD/agh-done" ]; then
    log "AdGuardHome 已完成（跳过）"
else
    __atgz="$__dl_dir/AdGuardHome_linux_arm64.tar.gz"
    __abin="$_USB/adguardhome-bin"
    __aconf="$_USB/AdGuardHome/config"
    __adata="$_USB/AdGuardHome/data"
    mkdir -p "$__abin" "$__aconf" "$__adata"

    if [ -f "$__atgz" ] && ! tar -tzf "$__atgz" >/dev/null 2>&1; then
        rm -f "$__atgz"
    fi
    if [ ! -f "$__atgz" ]; then
        _download "$_AGH_URL" "$__atgz" "AdGuardHome" || { _AGH_FAIL=1; rm -f "$__atgz"; }
    fi

    if [ "$_AGH_FAIL" -eq 0 ] && [ -f "$__atgz" ]; then
        tar -xzf "$__atgz" -C "$__abin" --strip-components=2 \
            AdGuardHome/AdGuardHome 2>/dev/null
        if [ ! -f "$__abin/AdGuardHome" ]; then
            __atmp="$__abin/.extract-$$"
            mkdir -p "$__atmp"
            tar -xzf "$__atgz" -C "$__atmp" 2>/dev/null
            __found=$(find "$__atmp" -name "AdGuardHome" -type f 2>/dev/null | head -1)
            if [ -n "$__found" ]; then
                mv "$__found" "$__abin/AdGuardHome"
            fi
            rm -rf "$__atmp"
        fi
        if [ ! -f "$__abin/AdGuardHome" ]; then
            log "AGH 二进制提取失败"
            rm -f "$__atgz"; _AGH_FAIL=1
        else
            chmod +x "$__abin/AdGuardHome"
            ln -sf "$__abin/AdGuardHome" /usr/bin/AdGuardHome 2>/dev/null
        fi
    fi

    if [ "$_AGH_FAIL" -eq 0 ]; then
        /etc/init.d/adguardhome stop 2>/dev/null || true

        [ ! -f "$__aconf/AdGuardHome.yaml" ] && [ -f "/etc/adguardhome/AdGuardHome.yaml" ] && \
            cp -a /etc/adguardhome/. "$__aconf/" 2>/dev/null && log "AGH 配置已迁移"
        [ -z "$(ls -A "$__adata" 2>/dev/null)" ] && [ -d "/var/lib/adguardhome" ] && \
            cp -a /var/lib/adguardhome/. "$__adata/" 2>/dev/null && log "AGH 数据已迁移"

        # [修复5] AGH init.d：移除端口检测，改为纯进程存活判断禁用 dnsmasq
        cat > /etc/init.d/adguardhome << 'AINITEOF'
#!/bin/sh /etc/rc.common
START=98; STOP=10; USE_PROCD=1

_agh_dns_disable() {
    uci set dhcp.@dnsmasq[0].port='0' 2>/dev/null
    uci commit dhcp 2>/dev/null
    /etc/init.d/dnsmasq reload >/dev/null 2>&1
}
_agh_dns_restore() {
    uci set dhcp.@dnsmasq[0].port='53' 2>/dev/null
    uci commit dhcp 2>/dev/null
    /etc/init.d/dnsmasq reload >/dev/null 2>&1
}

start_service() {
    [ -f /etc/install-usb-done ] || return 0
    _mp=$(cat /etc/install-usb-mount 2>/dev/null)
    [ -f "$_mp/adguardhome-bin/AdGuardHome" ] || return 1
    _config="$_mp/AdGuardHome/config/AdGuardHome.yaml"
    procd_open_instance
    procd_set_param command "$_mp/adguardhome-bin/AdGuardHome" \
        ${_config:+--config "$_config"} \
        --work-dir "$_mp/AdGuardHome/data" \
        --no-check-update
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param respawn 3600 5 0
    procd_close_instance
