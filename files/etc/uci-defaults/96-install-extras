#!/bin/sh
# 96-install-extras [V1.1]
# 适用：360 V6 / 小米 CR660x / IPQ6000
# 基于 V1.0 + V4.5 优化合并
# 新增修复：
#   1. _tar_extract tmp 变量名简化
#   2. upgrade 中 rm -rf 引号修复
#   3. 恢复模式启动状态检查
#   4. 合并 DNS 冲突检测函数
#   5. 统一 _get_uptime_sec 调用

# ============================================================
# 全局变量
# ============================================================
_SD="/etc/install-state"
_USB_MOUNT_FILE="/etc/install-usb-mount"
_USB_DONE_FILE="/etc/install-usb-done"
_MAIN_DONE="/etc/install-extras-done"
_LOG_TAG="install-main"
_VERSION="1.1"
_WAN_COOLDOWN="/tmp/wan-cooldown"

# ============================================================
# 工具函数
# ============================================================
log() {
    _msg="[$(date '+%Y-%m-%d %H:%M:%S')] $1"
    echo "$_msg" | logger -t "$_LOG_TAG"
    _log_mp=$(cat "$_USB_MOUNT_FILE" 2>/dev/null)
    [ -n "$_log_mp" ] && [ -d "$_log_mp/.install-log" ] 2>/dev/null && \
        echo "$_msg" >> "$_log_mp/.install-log/$(date '+%Y%m%d').log" 2>/dev/null
}

_get_usb_mount() {
    for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        grep -q "^[^ ]* $_mp " /proc/mounts 2>/dev/null && { echo "$_mp"; return 0; }
    done
    return 1
}

_is_ext4() {
    _dev=$(awk -v mp="$1 " '$0 ~ mp {print $1; exit}' /proc/mounts 2>/dev/null)
    [ -z "$_dev" ] && return 1
    _fstype=$(blkid "$_dev" 2>/dev/null | grep -o 'TYPE="[^"]*"' | cut -d'"' -f2)
    [ "$_fstype" = "ext4" ] && return 0
    return 1
}

_tcp_port_open() {
    _host="$1"; _port="$2"; _timeout="${3:-3}"
    if command -v nc >/dev/null 2>&1; then
        nc -z -w "$_timeout" "$_host" "$_port" 2>/dev/null && return 0
    fi
    if command -v wget >/dev/null 2>&1; then
        wget -q --timeout="$_timeout" --tries=1 -O /dev/null \
            "http://$_host:$_port" 2>/dev/null && return 0
    fi
    return 1
}

_wait_agh() {
    _i=0; _max=30
    while [ "$_i" -lt "$_max" ]; do
        for _port in 3000 8080 5354; do
            _tcp_port_open 127.0.0.1 "$_port" 1 && return 0
        done
        sleep 1; _i=$((_i + 1))
    done
    return 1
}

_wait_docker() {
    _i=0; _max=15
    while [ "$_i" -lt "$_max" ]; do
        docker info >/dev/null 2>&1 && return 0
        sleep 1; _i=$((_i + 1))
    done
    return 1
}

_timeout() {
    _tt="$1"; shift
    if command -v timeout >/dev/null 2>&1; then
        timeout "$_tt" "$@" 2>/dev/null
        return $?
    fi
    "$@" &
    _pid=$!; _cnt=0
    while [ "$_cnt" -lt "$_tt" ]; do
        kill -0 "$_pid" 2>/dev/null || { wait "$_pid"; return $?; }
        sleep 1; _cnt=$((_cnt + 1))
    done
    kill "$_pid" 2>/dev/null; wait "$_pid" 2>/dev/null
    return 124
}

_sha256() {
    if command -v sha256sum >/dev/null 2>&1; then
        sha256sum "$1" 2>/dev/null | cut -d' ' -f1
    elif command -v openssl >/dev/null 2>&1; then
        openssl dgst -sha256 "$1" 2>/dev/null | cut -d' ' -f2
    else
        echo ""
    fi
}

_wget_retry() {
    _url="$1"; _out="$2"; _min_size="${3:-0}"; _r=0
    while [ "$_r" -lt 3 ]; do
        wget -q --timeout=120 --tries=1 -O "$_out" "$_url" 2>/dev/null
        if [ -f "$_out" ]; then
            _sz=$(wc -c < "$_out" 2>/dev/null || echo 0)
            [ "${_sz:-0}" -ge "$_min_size" ] && [ "${_sz:-0}" -gt 0 ] && return 0
        fi
        rm -f "$_out"; _r=$((_r + 1))
        [ "$_r" -lt 3 ] && sleep 3
    done
    return 1
}

# 修复 #1：tmp 变量名简化（原 $$ 已足够随机）
_tar_extract() {
    _tgz="$1"; _dst="$2"; _subdir="$3"
    _tmp="${_dst}.xtmp$$"
    rm -rf "$_tmp"; mkdir -p "$_tmp" "$_dst" || return 1
    tar xzf "$_tgz" -C "$_tmp" 2>/dev/null || { rm -rf "$_tmp"; return 1; }

    if [ -n "$_subdir" ] && [ -d "$_tmp/$_subdir" ]; then
        _src="$_tmp/$_subdir"
    else
        _src="$_tmp"
    fi

    _moved=0
    for _f in "$_src/"*; do
        [ -e "$_f" ] || continue
        _bn="${_f##*/}"
        rm -rf "$_dst/$_bn"
        cp -r "$_f" "$_dst/" 2>/dev/null || { rm -rf "$_tmp"; return 1; }
        rm -rf "$_f" 2>/dev/null
        _moved=$((_moved + 1))
    done
    rm -rf "$_tmp"
    [ "$_moved" -gt 0 ]
}

_pkg_install() {
    if command -v apk >/dev/null 2>&1; then
        apk add --no-cache "$@" >/dev/null 2>&1
    elif command -v opkg >/dev/null 2>&1; then
        opkg install "$@" >/dev/null 2>&1
    else
        return 1
    fi
}

_get_uptime_sec() {
    awk '{print int($1)}' /proc/uptime 2>/dev/null || echo 0
}

# 带时间戳的失败计数（2小时自动重置）
_read_failure_count() {
    _file="$1"; _max_age=7200
    [ -f "$_file" ] || { echo 0; return; }
    _data=$(cat "$_file" 2>/dev/null)
    _fail_time=$(echo "$_data" | awk '{print int($1)}')
    _count=$(echo "$_data" | awk '{print int($2)}')
    _now=$(_get_uptime_sec)
    _elapsed=$((_now - _fail_time))
    if [ "$_elapsed" -gt "$_max_age" ] || [ "$_elapsed" -lt 0 ]; then
        rm -f "$_file"; echo 0
    else
        echo "$_count"
    fi
}

_record_failure() {
    _file="$1"; _count="$2"
    echo "$(_get_uptime_sec) $((_count + 1))" > "$_file"
}

# DNS 冲突检测（统一函数）
_check_dns_conflict() {
    _dnsmasq_port=$(uci get dhcp.@dnsmasq[0].port 2>/dev/null)
    if [ -n "$_dnsmasq_port" ] && [ "$_dnsmasq_port" != "0" ]; then
        return 0  # 冲突
    fi
    if command -v netstat >/dev/null 2>&1; then
        netstat -lnup 2>/dev/null | grep -q ':53 .*dnsmasq' && return 0
    fi
    return 1  # 无冲突
}

# ============================================================
# 360v6-status
# ============================================================
cat > /usr/bin/360v6-status << 'STATUSEOF'
#!/bin/sh
_SD="/etc/install-state"
_MP_FILE="/etc/install-usb-mount"
_COLOR=1
[ -t 1 ] || _COLOR=0

if [ "$_COLOR" -eq 1 ]; then
    _G="\033[32m"; _R="\033[31m"; _Y="\033[33m"; _B="\033[36m"; _C="\033[34m"; _N="\033[0m"
else
    _G=""; _R=""; _Y=""; _B=""; _C=""; _N=""
fi

_ok()   { printf "${_G}[OK]${_N}  %s\n" "$1"; }
_warn() { printf "${_Y}[..]${_N}  %s\n" "$1"; }
_err()  { printf "${_R}[!!]${_N}  %s\n" "$1"; }
_info() { printf "     ${_B}%s${_N}\n" "$1"; }
_title(){ printf "\n${_C}%s${_N}\n" "$1"; }

_get_usb_mount() {
    for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        grep -q "^[^ ]* $_mp " /proc/mounts 2>/dev/null && { echo "$_mp"; return 0; }
    done
    return 1
}

echo "================================"
echo "    360 V6 状态报告 V1.1"
echo "    时间: $(date '+%Y-%m-%d %H:%M:%S')"
echo "================================"

_title "【基础环境】"
if [ -f /etc/install-extras-done ]; then
    _ok "基础组件: 已部署"
else
    _warn "基础组件: 等待触发"
fi

_title "【网络状态】"
_wan_ip=$(ifconfig wan 2>/dev/null | grep 'inet addr' | cut -d: -f2 | awk '{print $1}')
[ -z "$_wan_ip" ] && _wan_ip=$(ip addr show wan 2>/dev/null | grep 'inet ' | awk '{print $2}' | cut -d/ -f1)
if [ -n "$_wan_ip" ]; then
    _ok "WAN IP: $_wan_ip"
else
    _wan_ip=$(ifconfig pppoe-wan 2>/dev/null | grep 'inet addr' | cut -d: -f2 | awk '{print $1}')
    [ -n "$_wan_ip" ] && _ok "WAN IP (PPPoE): $_wan_ip" || _warn "WAN: 未连接"
fi

_lan_ip=$(uci get network.lan.ipaddr 2>/dev/null)
[ -n "$_lan_ip" ] && _info "LAN IP: $_lan_ip"

if ping -c1 -W2 223.5.5.5 >/dev/null 2>&1; then
    _ok "互联网: 已连接"
else
    _warn "互联网: 无法连接"
fi

_title "【Wi-Fi 状态】"
for _idx in 0 1; do
    _disabled=$(uci get wireless.radio${_idx}.disabled 2>/dev/null)
    _ssid=$(uci get wireless.@wifi-iface[${_idx}].ssid 2>/dev/null)
    _freq=$([ "$_idx" -eq 0 ] && echo "2.4G" || echo "5G")
    if [ "$_disabled" = "0" ]; then
        _ok "${_freq}: ${_ssid:-无SSID} (已启用)"
    else
        _warn "${_freq}: ${_ssid:-未配置} (已禁用)"
    fi
done

_title "【重型应用】"
_USB=$(_get_usb_mount)
if [ -n "$_USB" ] && [ -f "$_USB/.install-done" ] 2>/dev/null; then
    _ok "U盘部署: 已完成 (恢复模式)"
elif [ -f /etc/install-usb-done ]; then
    _ok "U盘部署: 已完成"
elif [ -n "$_USB" ]; then
    _warn "U盘部署: 待完成"
else
    _warn "U盘部署: 未检测到U盘"
fi

if [ -f "$_SD/docker-done" ]; then
    if docker info >/dev/null 2>&1; then
        _crun=$(docker ps -q 2>/dev/null | wc -l | tr -d ' ')
        _call=$(docker ps -aq 2>/dev/null | wc -l | tr -d ' ')
        _ver=$(docker version --format '{{.Server.Version}}' 2>/dev/null)
        _storage=$(docker info 2>/dev/null | grep 'Storage Driver' | awk '{print $3}')
        _info "Docker: v${_ver:-未知} (运行中，容器 ${_crun}/${_call})"
        [ "$_storage" = "vfs" ] && _warn "存储驱动: vfs (性能较差)"
    else
        _warn "Docker: 已安装但未运行"
    fi
else
    _info "Docker: 未安装"
fi

_agh_running=0
pgrep -f "AdGuardHome" >/dev/null 2>&1 && _agh_running=1

if [ -n "$_USB" ] && [ -f "$_USB/AdGuardHome/version.txt" ] 2>/dev/null; then
    _agh_ver=$(cat "$_USB/AdGuardHome/version.txt" 2>/dev/null)
    [ -n "$_agh_ver" ] && _info "AGH: v${_agh_ver} (已安装)"
elif [ -f "$_SD/agh-done" ]; then
    _info "AGH: 已配置"
fi

if [ "$_agh_running" -eq 1 ]; then
    if command -v curl >/dev/null 2>&1; then
        _stats=$(curl -s --max-time 2 "http://127.0.0.1:3000/control/stats" 2>/dev/null)
        if echo "$_stats" | grep -q '"num_dns_queries"' 2>/dev/null; then
            _total=$(echo "$_stats" | grep -o '"num_dns_queries":[0-9]*' | cut -d: -f2)
            _blocked=$(echo "$_stats" | grep -o '"num_blocked_filtering":[0-9]*' | cut -d: -f2)
            _blocked_pct=0
            [ "${_total:-0}" -gt 0 ] && _blocked_pct=$(( _blocked * 100 / _total ))
            _info "AGH 统计: 查询 ${_total:-0} / 拦截 ${_blocked:-0} (${_blocked_pct}%)"
        fi
    fi
    _ok "AGH: 运行中 (DNS:53, Web:3000)"
elif [ -f "$_SD/agh-done" ]; then
    _warn "AGH: 已配置但未运行"
elif [ -n "$_USB" ] && [ -f "$_USB/adguardhome-bin/AdGuardHome" ]; then
    _warn "AGH: 二进制已就绪，等待配置"
fi

_title "【系统资源】"
df -h /overlay 2>/dev/null | awk 'NR==2{printf "Flash: %s / %s (%s使用)\n",$3,$2,$5}'
free -m 2>/dev/null | awk '/Mem:/{printf "内存: %dMB 已用 / %dMB 总计 (%.0f%%)\n",$3,$2,$3*100/$2}'

_swaptotal=$(grep SwapTotal /proc/meminfo 2>/dev/null | awk '{print $2}')
_swapfree=$(grep SwapFree /proc/meminfo 2>/dev/null | awk '{print $2}')
if [ "${_swaptotal:-0}" -gt 0 ]; then
    _swapused=$(( (_swaptotal - _swapfree) / 1024 ))
    _swaptotalm=$(( _swaptotal / 1024 ))
    printf "Swap: %dMB 已用 / %dMB 总计 (%.0f%%)\n" "$_swapused" "$_swaptotalm" \
        "$(( (_swaptotal - _swapfree) * 100 / _swaptotal ))"
else
    _warn "Swap: 未激活"
fi

_load=$(cat /proc/loadavg 2>/dev/null | cut -d' ' -f1-3)
[ -n "$_load" ] && echo "负载: $_load"

_uptime_s=$(awk '{printf "%d", $1}' /proc/uptime 2>/dev/null)
if [ -n "$_uptime_s" ]; then
    _uph=$(( _uptime_s / 3600 ))
    _upm=$(( (_uptime_s % 3600) / 60 ))
    printf "运行: %d 时 %d 分\n" "$_uph" "$_upm"
fi

__temp=$(cat /sys/class/thermal/thermal_zone0/temp 2>/dev/null)
if [ -n "$__temp" ]; then
    __tc=$((__temp / 1000))
    if [ "$__temp" -gt 75000 ]; then
        printf "${_R}CPU温度: %d°C (过高！建议 360v6-tune --mode=powersave)${_N}\n" "$__tc"
    elif [ "$__temp" -gt 65000 ]; then
        printf "${_Y}CPU温度: %d°C (偏高，可 360v6-tune --mode=powersave)${_N}\n" "$__tc"
    else
        printf "CPU温度: %d°C\n" "$__tc"
    fi
fi

_title "【USB 信息】"
if [ -n "$_USB" ]; then
    _usbfree=$(df -h "$_USB" 2>/dev/null | awk 'NR==2{print $4}')
    _dev=$(awk -v mp="$_USB " '$0 ~ mp {print $1; exit}' /proc/mounts 2>/dev/null)
    _fstype=$(blkid "$_dev" 2>/dev/null | grep -o 'TYPE="[^"]*"' | cut -d'"' -f2)
    echo "挂载点: $_USB"
    echo "设备: ${_dev:-未知}"
    echo "文件系统: ${_fstype:-未知}"
    echo "剩余空间: ${_usbfree:-?}"
    [ "$_fstype" != "ext4" ] && _warn "建议格式化为 ext4 以支持 swap"
else
    _err "未检测到 U 盘"
fi

_title "【安全提示】"
if grep -q "^root::" /etc/shadow 2>/dev/null; then
    _err "SSH 空密码！请立即设置: passwd root"
fi
if [ -n "$_USB" ] && [ -f "$_USB/adguardhome-bin/AdGuardHome" ] && [ ! -f "$_SD/agh-done" ]; then
    _warn "AGH 已部署，执行: AGH_USER=admin AGH_PASS=密码 agh-finalize"
fi

echo ""
echo "================================"
echo "命令: 360v6-health [--fix] | 360v6-tune --mode=..."
echo "升级: 360v6-upgrade [docker|agh]"
echo "卸载: 360v6-uninstall"
STATUSEOF
chmod +x /usr/bin/360v6-status

# ============================================================
# 360v6-health
# ============================================================
cat > /usr/bin/360v6-health << 'HEALTHEOF'
#!/bin/sh
_SD="/etc/install-state"
_MP_FILE="/etc/install-usb-mount"
_fix=0
[ "$1" = "--fix" ] && _fix=1

_ok()   { echo "[OK]   $1"; }
_warn() { echo "[WARN] $1"; }
_err()  { echo "[ERR]  $1"; }

_fix_cpu_powersave() {
    for _g in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do
        [ -f "$_g" ] && echo powersave > "$_g" 2>/dev/null
    done
}
_fix_clean_cache() { rm -rf /tmp/opkg-lists /var/cache/apk 2>/dev/null; }
_fix_start_dockerd() { /etc/init.d/dockerd start 2>/dev/null; }
_fix_start_agh() { /etc/init.d/adguardhome start 2>/dev/null; }
_fix_disable_dnsmasq() {
    uci set dhcp.@dnsmasq[0].port='0' 2>/dev/null
    uci commit dhcp 2>/dev/null
    /etc/init.d/dnsmasq reload 2>/dev/null
}
_fix_enable_swap() {
    _usb=$(cat "$_MP_FILE" 2>/dev/null)
    [ -n "$_usb" ] && [ -f "$_usb/swapfile" ] && swapon "$_usb/swapfile" 2>/dev/null
}

_fix_action() {
    [ "$_fix" -eq 1 ] || { echo "[HINT] 修复: $1"; return; }
    echo "[FIX]  $1"
    "$2"
}

echo "=== 360 V6 健康检查 @ $(date '+%Y-%m-%d %H:%M:%S') ==="
echo ""

_errs=0

__temp=$(cat /sys/class/thermal/thermal_zone0/temp 2>/dev/null)
if [ -n "$__temp" ]; then
    __temp_c=$((__temp / 1000))
    if [ "$__temp" -gt 75000 ]; then
        _err "CPU 温度过高 (${__temp_c}°C) > 75°C"
        _fix_action "切换 CPU 为 powersave" _fix_cpu_powersave
        _errs=$((_errs + 1))
    elif [ "$__temp" -gt 70000 ]; then
        _warn "CPU 温度偏高 (${__temp_c}°C)"
        _fix_action "切换 CPU 为 powersave" _fix_cpu_powersave
    else
        _ok "CPU 温度: ${__temp_c}°C"
    fi
fi

_flash_pct=$(df /overlay 2>/dev/null | awk 'NR==2{gsub(/%/,"",$5); print $5}')
if [ -z "$_flash_pct" ]; then
    _warn "无法读取 Flash 使用率"
elif [ "$_flash_pct" -ge 90 ]; then
    _err "Flash 使用率 ${_flash_pct}%"
    _fix_action "清理缓存" _fix_clean_cache
    _errs=$((_errs + 1))
elif [ "$_flash_pct" -ge 80 ]; then
    _warn "Flash 使用率 ${_flash_pct}%"
else
    _ok "Flash 使用率 ${_flash_pct}%"
fi

if grep -q swapfile /proc/swaps 2>/dev/null; then
    _ok "Swap 已激活"
else
    _warn "Swap 未激活"
    _fix_action "启用 swap" _fix_enable_swap
fi

if [ -f "$_SD/docker-done" ]; then
    if docker info >/dev/null 2>&1; then
        _ok "Docker 运行中"
    else
        _err "Docker 未运行"
        _fix_action "启动 dockerd" _fix_start_dockerd
        _errs=$((_errs + 1))
    fi
fi

if pgrep -f "AdGuardHome" >/dev/null 2>&1; then
    _ok "AdGuardHome 运行中"
else
    if [ -f "$_SD/agh-done" ] || [ -f /etc/install-usb-done ]; then
        _err "AdGuardHome 未运行"
        _fix_action "启动 AGH" _fix_start_agh
        _errs=$((_errs + 1))
    fi
fi

if [ -f "$_SD/agh-done" ]; then
    if _check_dns_conflict; then
        _err "DNS 冲突：dnsmasq 仍监听 53 端口"
        _fix_action "禁用 dnsmasq DNS" _fix_disable_dnsmasq
        _errs=$((_errs + 1))
    else
        _ok "DNS 分配正常"
    fi
fi

echo ""
[ "$_errs" -eq 0 ] && echo "健康检查完成，无异常" || \
    echo "发现 ${_errs} 个问题 (加上 --fix 自动修复)"
HEALTHEOF
chmod +x /usr/bin/360v6-health

# ============================================================
# 360v6-tune
# ============================================================
cat > /usr/bin/360v6-tune << 'TUNEOF'
#!/bin/sh
_MODE="${1#--mode=}"
[ -z "$_MODE" ] && {
    echo "用法: 360v6-tune --mode=performance|balanced|powersave"
    exit 1
}

_log() { echo "[OK] $1"; }

_set_governor() {
    for _gov_f in /sys/devices/system/cpu/cpu*/cpufreq/scaling_governor; do
        [ -f "$_gov_f" ] && echo "$1" > "$_gov_f" 2>/dev/null
    done
}

case "$_MODE" in
performance)
    _log "性能模式"
    _set_governor performance
    echo 65536 > /proc/sys/net/nf_conntrack_max 2>/dev/null
    ;;
balanced)
    _log "平衡模式"
    _set_governor schedutil 2>/dev/null || _set_governor ondemand
    echo 32768 > /proc/sys/net/nf_conntrack_max 2>/dev/null
    ;;
powersave)
    _log "省电模式"
    _set_governor powersave
    echo 16384 > /proc/sys/net/nf_conntrack_max 2>/dev/null
    ;;
*)
    echo "未知模式: $_MODE"; exit 1
    ;;
esac

mkdir -p /etc/install-state
echo "$_MODE" > /etc/install-state/perf-mode
TUNEOF
chmod +x /usr/bin/360v6-tune

# ============================================================
# 360v6-uninstall
# ============================================================
cat > /usr/bin/360v6-uninstall << 'UNINSTEOF'
#!/bin/sh
_SD="/etc/install-state"
_MP_FILE="/etc/install-usb-mount"

_confirm() {
    [ "$1" = "--yes" ] && return 0
    printf "卸载所有组件？[y/N] "
    read _uninstall_ans
    case "$_uninstall_ans" in y|Y) return 0 ;; *) echo "已取消"; exit 0 ;; esac
}
_confirm "$1"

echo "[1/9] 停止服务..."
/etc/init.d/adguardhome stop 2>/dev/null
/etc/init.d/dockerd stop 2>/dev/null
pkill -f AdGuardHome 2>/dev/null
pkill dockerd 2>/dev/null
sleep 2

echo "[2/9] 停用 swap..."
_usb_mount=$(cat "$_MP_FILE" 2>/dev/null)
if [ -n "$_usb_mount" ] && grep -q "$_usb_mount/swapfile" /proc/swaps 2>/dev/null; then
    swapoff "$_usb_mount/swapfile" 2>/dev/null && echo "     swap 已停用"
fi

echo "[3/9] 恢复 dnsmasq..."
_dnsmasq_port=$(uci get dhcp.@dnsmasq[0].port 2>/dev/null)
if [ "${_dnsmasq_port}" = "0" ]; then
    uci delete dhcp.@dnsmasq[0].port 2>/dev/null
    uci commit dhcp 2>/dev/null
    /etc/init.d/dnsmasq restart >/dev/null 2>&1
