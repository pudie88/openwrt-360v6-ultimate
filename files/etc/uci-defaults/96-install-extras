[ -n "$_mp" ] && /usr/lib/install-extras/install-usb.sh "$_mp" &
RUNEOF
chmod +x /usr/lib/install-extras/run.sh

# ══════════════════════════════════════════════════════════════
# Hotplug：iface（V4.0：冷却防并发）
# ══════════════════════════════════════════════════════════════
cat > /etc/hotplug.d/iface/96-install-extras << 'IFACEEOF'
#!/bin/sh
[ "${ACTION:-}" = "ifup" ] || exit 0
case "${INTERFACE:-}" in wan|wan6|pppoe-wan) ;; *) exit 0 ;; esac

# V4.0：WAN 抖动冷却（60s 内只触发一次）
_SD="/etc/install-state"
