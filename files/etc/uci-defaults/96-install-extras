#!/bin/sh
# 96-install-extras [v11 - Bug Fix]
# 适用：360 V6 / 小米 CR660x / IPQ6000 (128M Flash / ImmortalWrt / busybox ash)
#
# 架构：
#   Phase 1 (run.sh)        基础工具 + Samba + avahi 修复 + zram（装 Flash）
#   Phase 2 (install-usb)   Docker（wget 静态二进制）+ AGH（wget）+ LuCI 插件（apk）
#                           可执行文件全装 U 盘，Flash 只多几个 symlink
#
# 设计原则：
#   - 不用 set -u：hotplug 环境不保证完整
#   - 不用 local：busybox ash 不保证支持，改用 __ 前缀变量
#   - install_pkg 用 mktemp 捕获退出码，不用管道判断
#   - 锁文件写 PID，支持检测残留锁
#   - _is_mounted 用 /proc/mounts，不用 mountpoint（该命令可能不存在）
#   - DNS 恢复用 printf '%s'（无尾换行，精确还原原始内容）
#   - Docker/AGH 用 wget 静态二进制，不用 apk（apk 仓库无此包且会占用 Flash）
#   - LuCI 插件（luci-app-dockerman / luci-app-adguardhome）用 apk 装 Flash
#   - run.sh 后台调用 install-usb.sh，不阻塞 DNS trap
#   - block hotplug 等待挂载最长 60 秒（实测 30 秒不够）
#   - dockerd 用 procd 管理，respawn retry=0（无限重启）
#   - cron 自愈在 Phase 1 完成后才触发 Phase 2
#
# v10 修复（基于实测日志）：
#   1. 下载后用 tar -tzf 校验完整性，损坏文件立即删除强制重新下载
#   2. 自愈模式消除并发竞争：直接在当前进程调用而非后台 &
#   3. 360v6-status 在 phase2 失败时明确提示"下载失败"原因
#   4. 360v6-health 在 install-usb-done 不存在时也检查 phase2 失败状态

_STATE_DIR="/etc/install-state"
mkdir -p "$_STATE_DIR" /usr/lib/install-extras /usr/bin \
         /etc/hotplug.d/iface /etc/hotplug.d/block \
         /etc/dbus-1

# ══════════════════════════════════════════════════════════════
# 模块 0：360v6-status
# ══════════════════════════════════════════════════════════════
cat > /usr/bin/360v6-status << 'STATUSEOF'
#!/bin/sh
_SD="/etc/install-state"
_is_mounted() { grep -q "^[^ ]* $1 " /proc/mounts 2>/dev/null; }

echo "=== 360 V6 状态 @ $(date '+%Y-%m-%d %H:%M:%S') ==="
echo ""
[ -f /etc/install-extras-done ] \
    && echo "[OK] 基础环境：已完成" || echo "[..] 基础环境：待触发"
_p1=$(cat "$_SD/phase1-failures" 2>/dev/null || echo 0)
[ "$_p1" -gt 0 ] && echo "     失败次数: $_p1/3"

[ -f /etc/install-usb-done ] \
    && echo "[OK] 重型应用：已完成" || echo "[..] 重型应用：待 U 盘"
_p2=$(cat "$_SD/phase2-failures" 2>/dev/null || echo 0)
if [ "$_p2" -gt 0 ]; then
    echo "     失败次数: $_p2/3"
    # 检查下载缓存是否损坏
    _dldir=$(cat /etc/install-usb-mount 2>/dev/null)
    if [ -n "$_dldir" ] && [ -d "$_dldir/.downloads" ]; then
        for _f in "$_dldir/.downloads"/*.tgz "$_dldir/.downloads"/*.tar.gz; do
            [ -f "$_f" ] || continue
            tar -tzf "$_f" >/dev/null 2>&1 \
                || echo "     ⚠ 损坏缓存: $(basename $_f)（重跑时将自动清理）"
        done
    fi
fi

echo ""
df -h /overlay 2>/dev/null \
    | awk 'NR==2{print "Flash : "$3" / "$2" ("$5")"}'
free 2>/dev/null \
    | awk '/Mem:/{printf "Mem   : %dMB used / %dMB total\n",$3/1024,$2/1024}'
echo ""

_USB=""
for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
    _is_mounted "$_mp" && { echo "USB   : $_mp (已挂载)"; _USB="$_mp"; break; }
done
[ -z "$_USB" ] && echo "USB   : 未检测到"
[ -f /etc/install-usb-mount ] \
    && echo "PATH  : $(cat /etc/install-usb-mount)"
grep -q swapfile /proc/swaps 2>/dev/null && echo "Swap  : swapfile 已激活"
grep -q zram     /proc/swaps 2>/dev/null && echo "Swap  : zram 已激活"
echo ""
docker info >/dev/null 2>&1 \
    && echo "[OK] Docker      : 运行中" || echo "[--] Docker      : 未启动"
pgrep AdGuardHome >/dev/null 2>&1 \
    && echo "[OK] AdGuardHome : 运行中" || echo "[--] AdGuardHome : 未启动"
echo ""
echo "重跑基础: rm -f /etc/install-extras-done $_SD/phase1-failures && /usr/lib/install-extras/run.sh"
echo "重跑重型: rm -f /etc/install-usb-done && /usr/lib/install-extras/install-usb.sh --force"
echo "  （--force 会自动清零失败计数，无需手动删 phase2-failures）"
echo "健康检查: 360v6-health [--fix]"
STATUSEOF
chmod +x /usr/bin/360v6-status

# ══════════════════════════════════════════════════════════════
# 模块 A：install-usb.sh（Phase 2）
# ══════════════════════════════════════════════════════════════
cat > /usr/lib/install-extras/install-usb.sh << 'USBEOF'
#!/bin/sh
# Phase 2：Docker（wget 静态二进制）+ AGH（wget）+ LuCI（apk）
_LT="usb-extras"
_DONE="/etc/install-usb-done"
_LOCK="/tmp/install-usb.lock"
_SD="/etc/install-state"
_MF="/etc/install-usb-mount"

# Docker 版本候选（实测 aarch64 目录真实存在的版本，降序排列）
# 来源：https://download.docker.com/linux/static/stable/aarch64/
# 不用 --spider 探测：wget --spider 在部分网络返回 exit 8（协议错误）
# 改为直接按序尝试下载，成功即止
_DOCKER_VERS="28.0.4 28.0.3 27.5.1 27.5.0 27.4.1"
_DOCKER_BASE="https://download.docker.com/linux/static/stable/aarch64"
_AGH_URL="https://static.adguard.com/adguardhome/release/AdGuardHome_linux_arm64.tar.gz"

log() {
    __lm="[$(date '+%H:%M:%S')] $1"
    echo "$__lm"
    echo "$__lm" | logger -t "$_LT"
}
_is_mounted() { grep -q "^[^ ]* $1 " /proc/mounts 2>/dev/null; }

mkdir -p "$_SD"

# ── 参数解析 ──────────────────────────────────────────────
__self_heal=0; __force=0; __mp_arg=""
for _a in "$@"; do
    case "$_a" in
        --self-heal) __self_heal=1 ;;
        --force)     __force=1 ;;
        --*)         ;;
        *)           [ -z "$__mp_arg" ] && __mp_arg="$_a" ;;
    esac
done

# ── 自愈模式（仅在 Phase 1 完成后执行）──────────────────
if [ "$__self_heal" -eq 1 ]; then
    # Phase 1 未完成则不触发 Phase 2
    [ -f /etc/install-extras-done ] || exit 0
    [ -f "$_DONE" ] && exit 0
    __sf=$(cat "$_SD/phase2-failures" 2>/dev/null || echo 0)
    [ "${__sf:-0}" -ge 3 ] && exit 0
    # 检查主锁：若 install-usb.sh 正在运行则跳过
    if [ -f "$_LOCK" ]; then
        __lp=$(cat "$_LOCK" 2>/dev/null)
        if kill -0 "$__lp" 2>/dev/null; then
            # 真正在运行，跳过
            exit 0
        fi
        # 残留锁（进程已死），清理后继续
        log "清理残留锁 (旧pid=$__lp)"; rm -f "$_LOCK"
    fi
    for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        _is_mounted "$_mp" && {
            log "自愈触发: $_mp"
            # exec 替换当前进程：install-usb.sh 继承本进程 PID，
            # 它自己写锁（echo $$ > $_LOCK）时 $$ 就是本进程 PID，
            # 锁检查 kill -0 $$ 会成功（install-usb.sh 自身还活着），
            # 不存在 cron 父进程与子进程的 PID 混淆问题。
            # 自愈不传 --force：尊重失败计数，由用户手动 --force 重置
            exec /usr/lib/install-extras/install-usb.sh "$_mp"
        }
    done
    exit 0
fi

# ── 幂等保护 ──────────────────────────────────────────────
[ -f "$_DONE" ] && { log "已完成，跳过"; exit 0; }

# ── 锁（写 PID，支持残留检测）────────────────────────────
if [ -f "$_LOCK" ]; then
    __lp=$(cat "$_LOCK" 2>/dev/null)
    kill -0 "$__lp" 2>/dev/null && { log "运行中 (pid=$__lp)，跳过"; exit 0; }
    log "清理残留锁 (旧pid=$__lp)"; rm -f "$_LOCK"
fi
echo $$ > "$_LOCK"

# ── DNS 恢复函数（printf '%s' 精确还原，无多余换行）──────
__dns_old=$(cat /etc/resolv.conf 2>/dev/null)
[ -z "$__dns_old" ] && __dns_old="nameserver 127.0.0.1"
_dns_restore() {
    printf '%s' "$__dns_old" > /etc/resolv.conf
    # 重启 dnsmasq 使其重读 resolv.conf，与 run.sh 行为一致
    /etc/init.d/dnsmasq restart >/dev/null 2>&1 || true
}
trap 'rm -f "$_LOCK"; _dns_restore' EXIT INT TERM

# ── 失败计数 ──────────────────────────────────────────────
if [ "$__force" -eq 1 ]; then
    rm -f "$_SD/phase2-failures"; __fail=0
    log "--force 模式：失败计数已清零"
else
    __fail=$(cat "$_SD/phase2-failures" 2>/dev/null || echo 0)
    [ "${__fail:-0}" -ge 3 ] && {
        log "失败次数过多（$__fail/3），停止自动重试"
        log "手动修复: rm -f $_SD/phase2-failures && $0 --force"
        exit 1
    }
fi

# ── 挂载点检测 ────────────────────────────────────────────
_USB=""
[ -n "$__mp_arg" ] && _is_mounted "$__mp_arg" && _USB="$__mp_arg"
if [ -z "$_USB" ]; then
    for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        _is_mounted "$_mp" && { _USB="$_mp"; break; }
    done
fi
# 兜底：从 /proc/mounts 扫描任意 sd 设备
[ -z "$_USB" ] && \
    _USB=$(awk '/^\/dev\/sd[a-z][0-9]+ /{print $2; exit}' /proc/mounts 2>/dev/null)
if [ -z "$_USB" ]; then
    log "未找到 U 盘挂载点，退出"
    echo $((__fail + 1)) > "$_SD/phase2-failures"
    exit 1
fi
echo "$_USB" > "$_MF"
log "重型应用部署启动 | U 盘: $_USB"

# ── 空间预检（U 盘 >= 1GB）───────────────────────────────
__usb_free=$(df -k "$_USB" 2>/dev/null | awk 'NR==2{print $4}')
if [ "${__usb_free:-0}" -lt 1048576 ]; then
    log "U 盘可用空间不足（${__usb_free}KB < 1GB），退出"
    echo $((__fail + 1)) > "$_SD/phase2-failures"
    exit 1
fi

# ── DNS 注入 ──────────────────────────────────────────────
printf 'nameserver 223.5.5.5\nnameserver 8.8.8.8\n' > /etc/resolv.conf
log "临时 DNS 已注入"

# ── I/O 调度优化 ──────────────────────────────────────────
__udev=$(awk -v mp=" $_USB " '$0 ~ mp {print $1}' /proc/mounts \
    | sed 's|/dev/||;s|[0-9]*$||')
__sched="/sys/block/${__udev}/queue/scheduler"
if [ -n "$__udev" ] && [ -f "$__sched" ]; then
    if grep -q "mq-deadline" "$__sched" 2>/dev/null; then
        echo "mq-deadline" > "$__sched" 2>/dev/null
    else
        echo "deadline" > "$__sched" 2>/dev/null
    fi
    log "I/O 调度器: $(grep -oE '\[[^]]+\]' "$__sched" 2>/dev/null | tr -d '[]')"
fi
echo "10"    > /proc/sys/vm/swappiness      2>/dev/null
echo "16384" > /proc/sys/vm/min_free_kbytes 2>/dev/null
log "内存参数: swappiness=10 min_free_kbytes=16MB"

# ── Swap（原子写入 + fstab 持久化）───────────────────────
__swapfile="$_USB/swapfile"
if ! grep -q swapfile /proc/swaps 2>/dev/null; then
    if [ ! -f "$__swapfile" ]; then
        log "创建 256MB swapfile（原子写入）..."
        if dd if=/dev/zero of="${__swapfile}.tmp" bs=1M count=256 2>/dev/null; then
            mv "${__swapfile}.tmp" "$__swapfile"
            sync; chmod 600 "$__swapfile"
            mkswap "$__swapfile" >/dev/null 2>&1
            log "swapfile 已创建"
        else
            rm -f "${__swapfile}.tmp"
            log "swapfile 创建失败（空间不足？）"
        fi
    fi
    if [ -f "$__swapfile" ]; then
        swapon "$__swapfile" 2>/dev/null && log "swapfile 已激活"
        grep -qF "$__swapfile" /etc/fstab 2>/dev/null \
            || echo "$__swapfile none swap sw 0 0" >> /etc/fstab
    fi
fi

# ── 下载函数（3 次重试，每次 120s 超时）──────────────────
_download() {
    __dl_url="$1"; __dl_out="$2"; __dl_desc="$3"
    __dl_i=1
    while [ "$__dl_i" -le 3 ]; do
        log "下载 $__dl_desc（$__dl_i/3）..."
        wget -q --timeout=120 --tries=1 \
             -O "${__dl_out}.tmp" "$__dl_url" 2>/dev/null \
            && mv "${__dl_out}.tmp" "$__dl_out" \
            && { log "下载完成: $__dl_desc"; return 0; }
        rm -f "${__dl_out}.tmp"
        log "下载失败: $__dl_desc ($__dl_i/3)"
        __dl_i=$((__dl_i + 1))
        sleep 5
    done
    log "下载彻底失败: $__dl_desc"
    return 1
}

__flash_free=$(df /overlay 2>/dev/null | awk 'NR==2{print $4}')
__skip_luci=0
[ "${__flash_free:-99999}" -lt 25000 ] && __skip_luci=1 \
    && log "Flash <25MB，跳过 LuCI 插件"

__dl_dir="$_USB/.downloads"; mkdir -p "$__dl_dir"

# ══ Docker 部署 ════════════════════════════════════════════

_DOCKER_FAIL=0
log "--- Docker 部署开始 ---"

# 按序尝试下载各版本，成功即止（不用 --spider，在部分网络环境不可靠）
__docker_ver=""
__dtgz=""
__dbin="$_USB/docker-bin"
__ddata="$_USB/docker-data"
mkdir -p "$__dbin" "$__ddata" /etc/docker

for _dv in $_DOCKER_VERS; do
    __dtgz_try="$__dl_dir/docker-${_dv}.tgz"
    # 已有完整缓存则直接使用
    if [ -f "$__dtgz_try" ]; then
        if tar -tzf "$__dtgz_try" >/dev/null 2>&1; then
            log "使用缓存: docker-${_dv}.tgz"
            __docker_ver="$_dv"; __dtgz="$__dtgz_try"; break
        else
            log "缓存损坏，删除: docker-${_dv}.tgz"
            rm -f "$__dtgz_try"
        fi
    fi
    # 尝试下载
    log "尝试 Docker ${_dv}..."
    if wget -q --timeout=120 --tries=1 \
            -O "${__dtgz_try}.tmp" \
            "$_DOCKER_BASE/docker-${_dv}.tgz" 2>/dev/null \
        && mv "${__dtgz_try}.tmp" "$__dtgz_try" \
        && tar -tzf "$__dtgz_try" >/dev/null 2>&1; then
        log "下载成功: Docker ${_dv}"
        __docker_ver="$_dv"; __dtgz="$__dtgz_try"; break
    fi
    rm -f "${__dtgz_try}.tmp" "$__dtgz_try"
    log "Docker ${_dv} 不可用，尝试下一版本"
done

if [ -z "$__docker_ver" ]; then
    log "所有 Docker 版本均下载失败，跳过"
    _DOCKER_FAIL=1
fi

if [ "$_DOCKER_FAIL" -eq 0 ]; then
    log "解压 Docker $__docker_ver..."
    # docker tgz 结构：docker/<binaries>，一层目录，--strip-components=1 直接得到二进制
    tar -xzf "$__dtgz" -C "$__dbin" --strip-components=1 2>/dev/null
    if [ ! -f "$__dbin/dockerd" ]; then
        log "解压后未找到 dockerd，tgz 结构异常，删除缓存"
        rm -f "$__dtgz"
        _DOCKER_FAIL=1
    fi
fi

if [ "$_DOCKER_FAIL" -eq 0 ]; then
        # symlink 到系统路径（Flash 只多几个字节）
        for _b in docker dockerd containerd \
                  containerd-shim-runc-v2 ctr runc; do
            [ -f "$__dbin/$_b" ] \
                && ln -sf "$__dbin/$_b" "/usr/bin/$_b" 2>/dev/null \
                && log "symlink: /usr/bin/$_b"
        done

        # daemon.json（$__ddata 在运行时已确定，此处直接展开正确）
        mkdir -p /etc/docker
        cat > /etc/docker/daemon.json << DOCKEREOF
{
  "data-root": "$__ddata",
  "storage-driver": "overlay2",
  "log-driver": "json-file",
  "log-opts": {"max-size": "5m", "max-file": "2"}
}
DOCKEREOF
        log "daemon.json 已写入 | data-root=$__ddata"

        # procd init.d 脚本（通过 /etc/install-usb-mount 动态读取路径）
        cat > /etc/init.d/dockerd << 'DINITEOF'
#!/bin/sh /etc/rc.common
START=99; STOP=10; USE_PROCD=1
start_service() {
    [ -f /etc/install-usb-done ] || return 0
    _mp=$(cat /etc/install-usb-mount 2>/dev/null)
    [ -n "$_mp" ] && [ -f "$_mp/docker-bin/dockerd" ] || return 1
    grep -q "^[^ ]* /sys/fs/cgroup " /proc/mounts 2>/dev/null \
        || mount -t cgroup2 none /sys/fs/cgroup 2>/dev/null || true
    procd_open_instance
    procd_set_param command "$_mp/docker-bin/dockerd" \
        --config-file /etc/docker/daemon.json
    procd_set_param stdout 1
    procd_set_param stderr 1
    # retry=0 无限重启，避免 U 盘启动慢时消耗完重试次数
    procd_set_param respawn 3600 5 0
    procd_close_instance
}
stop_service() {
    docker stop $(docker ps -q 2>/dev/null) 2>/dev/null || true
    sleep 2
    pkill dockerd    2>/dev/null || true
    pkill containerd 2>/dev/null || true
}
DINITEOF
        chmod +x /etc/init.d/dockerd
        /etc/init.d/dockerd enable 2>/dev/null
        /etc/init.d/dockerd start  2>/dev/null

        # 等待 Docker 就绪（最长 30 秒）
        __di=1
        while [ "$__di" -le 15 ]; do
            docker info >/dev/null 2>&1 && break
            sleep 2; __di=$((__di + 1))
        done
        docker info >/dev/null 2>&1 \
            && log "Docker $__docker_ver 已启动 | bin=$__dbin data=$__ddata" \
            || log "Docker 启动超时（服务已注册，重启后可用）"

        # LuCI 插件（apk 仓库有，小包装 Flash）
        if [ "$__skip_luci" -eq 0 ]; then
            __lt=$(mktemp /tmp/apk.XXXXXX)
            apk add --no-cache \
                luci-app-dockerman luci-i18n-dockerman-zh-cn \
                > "$__lt" 2>&1
            cat "$__lt" | logger -t "$_LT"; rm -f "$__lt"
            log "luci-app-dockerman 安装完成"
        else
            log "Flash <25MB，跳过 dockerman LuCI"
        fi
    fi
fi

# ══ AdGuardHome 部署 ═══════════════════════════════════════

_AGH_FAIL=0
log "--- AdGuardHome 部署开始 ---"

__atgz="$__dl_dir/AdGuardHome_linux_arm64.tar.gz"
__abin="$_USB/adguardhome-bin"
__aconf="$_USB/AdGuardHome/config"
__adata="$_USB/AdGuardHome/data"
mkdir -p "$__abin" "$__aconf" "$__adata"

if [ -f "$__atgz" ]; then
    if ! tar -tzf "$__atgz" >/dev/null 2>&1; then
        log "AGH 缓存文件损坏，删除并重新下载"
        rm -f "$__atgz"
    fi
fi
if [ ! -f "$__atgz" ]; then
    _download "$_AGH_URL" "$__atgz" "AdGuardHome" \
        || { _AGH_FAIL=1; rm -f "$__atgz"; }
fi

if [ "$_AGH_FAIL" -eq 0 ] && [ -f "$__atgz" ]; then
    log "解压 AdGuardHome..."
    # 实际结构：AdGuardHome/AdGuardHome（两层）
    # --strip-components=1 解压后得到 $__abin/AdGuardHome（目录）
    # 再从目录中取二进制
    tar -xzf "$__atgz" -C "$__abin" --strip-components=1 2>/dev/null
    # 处理解压后的目录结构
    if [ -d "$__abin/AdGuardHome" ] && [ -f "$__abin/AdGuardHome/AdGuardHome" ]; then
        # 移出二进制，删除多余目录
        mv "$__abin/AdGuardHome/AdGuardHome" "$__abin/AdGuardHome_bin"
        rm -rf "$__abin/AdGuardHome"
        mv "$__abin/AdGuardHome_bin" "$__abin/AdGuardHome"
    fi
    if [ ! -f "$__abin/AdGuardHome" ]; then
        log "AdGuardHome 解压失败，未找到二进制，删除缓存后下次重试"
        rm -f "$__atgz"
        _AGH_FAIL=1
    else
        chmod +x "$__abin/AdGuardHome"
        ln -sf "$__abin/AdGuardHome" /usr/bin/AdGuardHome 2>/dev/null
        log "symlink: /usr/bin/AdGuardHome"
    fi
fi

if [ "$_AGH_FAIL" -eq 0 ]; then
    /etc/init.d/adguardhome stop 2>/dev/null || true

    # 配置迁移（仅首次，不覆盖已有配置）
    if [ ! -f "$__aconf/AdGuardHome.yaml" ] \
    && [ -f "/etc/adguardhome/AdGuardHome.yaml" ]; then
        cp -a /etc/adguardhome/. "$__aconf/" 2>/dev/null
        log "AGH 配置已迁移至 U 盘（首次）"
    else
        log "AGH 配置已存在或无源配置，不覆盖"
    fi
    # 数据迁移（仅首次）
    if [ -z "$(ls -A "$__adata" 2>/dev/null)" ] \
    && [ -d "/var/lib/adguardhome" ] \
    && [ -n "$(ls -A /var/lib/adguardhome 2>/dev/null)" ]; then
        cp -a /var/lib/adguardhome/. "$__adata/" 2>/dev/null
        log "AGH 数据已迁移至 U 盘（首次）"
    fi

    # procd init.d 脚本（通过 /etc/install-usb-mount 动态读取路径）
    cat > /etc/init.d/adguardhome << 'AINITEOF'
#!/bin/sh /etc/rc.common
START=98; STOP=10; USE_PROCD=1
start_service() {
    [ -f /etc/install-usb-done ] || return 0
    _mp=$(cat /etc/install-usb-mount 2>/dev/null)
    [ -n "$_mp" ] && [ -f "$_mp/adguardhome-bin/AdGuardHome" ] || return 1
    procd_open_instance
    procd_set_param command \
        "$_mp/adguardhome-bin/AdGuardHome" \
        --config "$_mp/AdGuardHome/config/AdGuardHome.yaml" \
        --work-dir "$_mp/AdGuardHome/data" \
        --no-check-update
    procd_set_param stdout 1
    procd_set_param stderr 1
    # retry=0 无限重启
    procd_set_param respawn 3600 5 0
    procd_close_instance
}
stop_service() { pkill AdGuardHome 2>/dev/null || true; }
AINITEOF
    chmod +x /etc/init.d/adguardhome
    /etc/init.d/adguardhome enable  2>/dev/null
    /etc/init.d/adguardhome restart 2>/dev/null
    sleep 3
    pgrep -x AdGuardHome >/dev/null 2>&1 \
        && log "AdGuardHome 已启动 | conf=$__aconf data=$__adata" \
        || log "AdGuardHome 启动超时（服务已注册，重启后可用）"

    # LuCI 插件（apk 仓库有）
    if [ "$__skip_luci" -eq 0 ]; then
        __lt=$(mktemp /tmp/apk.XXXXXX)
        apk add --no-cache luci-app-adguardhome \
            > "$__lt" 2>&1
        cat "$__lt" | logger -t "$_LT"; rm -f "$__lt"
        log "luci-app-adguardhome 安装完成"
    else
        log "Flash <25MB，跳过 adguardhome LuCI（可用 :3000 管理）"
    fi
fi

# ── 刷新 LuCI ─────────────────────────────────────────────
rm -f /tmp/luci-indexcache* 2>/dev/null
/etc/init.d/rpcd restart 2>/dev/null || true

# ── 收尾（两者均失败才递增失败计数）─────────────────────
if [ "$_DOCKER_FAIL" -eq 0 ] || [ "$_AGH_FAIL" -eq 0 ]; then
    touch "$_DONE"
    rm -f "$_SD/phase2-failures"
    log "重型应用完成 [Docker:$([ "$_DOCKER_FAIL" -eq 0 ] && echo OK || echo FAIL) AGH:$([ "$_AGH_FAIL" -eq 0 ] && echo OK || echo FAIL)]"
    exit 0
else
    echo $((__fail + 1)) > "$_SD/phase2-failures"
    log "Docker 和 AGH 均失败（重试 $((__fail + 1))/3）"
    log "手动重跑: rm -f /etc/install-usb-done $_SD/phase2-failures && $0 --force"
    exit 1
fi
USBEOF
chmod +x /usr/lib/install-extras/install-usb.sh

# ══════════════════════════════════════════════════════════════
# 模块 B：run.sh（Phase 1 基础环境）
# ══════════════════════════════════════════════════════════════
cat > /usr/lib/install-extras/run.sh << 'RUNEOF'
#!/bin/sh
_LT="install-main"
_DONE="/etc/install-extras-done"
_USB_DONE="/etc/install-usb-done"
_LOCK="/tmp/install-main.lock"
_SD="/etc/install-state"

log() {
    __lm="[$(date '+%H:%M:%S')] $1"
    echo "$__lm"
    echo "$__lm" | logger -t "$_LT"
}
_is_mounted() { grep -q "^[^ ]* $1 " /proc/mounts 2>/dev/null; }

mkdir -p "$_SD"
[ -f "$_DONE" ] && { log "基础环境已完成，跳过"; exit 0; }

# ── 锁（写 PID，支持残留检测）────────────────────────────
if [ -f "$_LOCK" ]; then
    __lp=$(cat "$_LOCK" 2>/dev/null)
    kill -0 "$__lp" 2>/dev/null && { log "运行中 (pid=$__lp)，跳过"; exit 0; }
    log "清理残留锁 (旧pid=$__lp)"; rm -f "$_LOCK"
fi
echo $$ > "$_LOCK"

# ── DNS 恢复（printf '%s' 精确还原）──────────────────────
__dns_old=$(cat /etc/resolv.conf 2>/dev/null)
[ -z "$__dns_old" ] && __dns_old="nameserver 127.0.0.1"
_dns_restore() {
    rm -f "$_LOCK"
    printf '%s' "$__dns_old" > /etc/resolv.conf
    /etc/init.d/dnsmasq restart >/dev/null 2>&1 || true
    log "resolv.conf 已恢复，DNS 交还 dnsmasq"
}
trap '_dns_restore' EXIT INT TERM

# ── 重试计数 ──────────────────────────────────────────────
__fail=$(cat "$_SD/phase1-failures" 2>/dev/null || echo 0)
if [ "${__fail:-0}" -ge 3 ]; then
    log "失败次数过多（$__fail/3），停止自动重试"
    log "手动修复: rm -f $_SD/phase1-failures $_LOCK && $0"
    exit 1
fi

log "v11 基础环境启动"

# ── 清理无效软件源 ────────────────────────────────────────
for _f in /etc/apk/repositories.d/*.list; do
    [ -f "$_f" ] || continue
    sed '/\/video\//d' "$_f" > "${_f}.tmp" && mv "${_f}.tmp" "$_f"
done 2>/dev/null

# ── 等待网络（最长 3 分钟）───────────────────────────────
sleep 10
__net_ok=0
__ni=1
while [ "$__ni" -le 36 ]; do
    ping -c1 -W2 223.5.5.5 >/dev/null 2>&1 && { __net_ok=1; break; }
    ping -c1 -W2 8.8.8.8   >/dev/null 2>&1 && { __net_ok=1; break; }
    sleep 5; __ni=$((__ni + 1))
done
if [ "$__net_ok" -eq 0 ]; then
    log "网络不可达，等待下次 WAN UP 重试"
    echo $((__fail + 1)) > "$_SD/phase1-failures"
    exit 1
fi
log "网络已就绪"

# ── DNS 注入 ──────────────────────────────────────────────
printf 'nameserver 223.5.5.5\nnameserver 8.8.8.8\n' > /etc/resolv.conf
log "临时 DNS 已注入"

# ── Flash 空间预检（< 20MB 中止防变砖）──────────────────
__flash=$(df /overlay 2>/dev/null | awk 'NR==2{print $4}')
__flash_pct=$(df /overlay 2>/dev/null | awk 'NR==2{print $5}' | tr -d '%')
log "Flash: 已用 ${__flash_pct:-?}% | 剩余 ${__flash:-?}KB"
if [ "${__flash:-0}" -lt 20480 ]; then
    log "Flash 剩余不足 20MB，中止防止变砖"
    echo $((__fail + 1)) > "$_SD/phase1-failures"
    exit 1
fi
__skip_luci=0
[ "${__flash:-99999}" -lt 25000 ] && __skip_luci=1 \
    && log "Flash <25MB，跳过可选 LuCI"

# ── apk update（HTTPS → HTTP 自动降级）───────────────────
__apk_update() {
    __au_t=$(mktemp /tmp/apk.XXXXXX)
    apk update > "$__au_t" 2>&1
    cat "$__au_t" | logger -t "$_LT"
    __au_n=$(grep -oE 'OK: [0-9]+ distinct' "$__au_t" \
        | grep -oE '[0-9]+' | head -1)
    rm -f "$__au_t"
    [ "${__au_n:-0}" -gt 800 ] && return 0

    log "HTTPS 源包数不足（${__au_n:-0}），切换 HTTP 重试..."
    for _f in /etc/apk/repositories.d/*.list; do
        [ -f "$_f" ] && sed 's|https://|http://|g' "$_f" \
            > "${_f}.tmp" && mv "${_f}.tmp" "$_f"
    done
    __au_t=$(mktemp /tmp/apk.XXXXXX)
    apk update > "$__au_t" 2>&1
    cat "$__au_t" | logger -t "$_LT"
    __au_n=$(grep -oE 'OK: [0-9]+ distinct' "$__au_t" \
        | grep -oE '[0-9]+' | head -1)
    rm -f "$__au_t"
    [ "${__au_n:-0}" -gt 800 ]
}
if ! __apk_update; then
    log "apk update 失败，等待下次重试"
    echo $((__fail + 1)) > "$_SD/phase1-failures"
    exit 1
fi
log "apk update 成功"

# ── 安装函数（mktemp 捕获退出码）─────────────────────────
__inst_fail=0
__inst() {
    __it=$(mktemp /tmp/apk.XXXXXX)
    log "安装: $*"
    apk add --no-cache "$@" > "$__it" 2>&1
    __ir=$?
    cat "$__it" | logger -t "$_LT"; rm -f "$__it"
    if [ "$__ir" -eq 0 ]; then
        log "完成: $*"
    else
        log "失败: $* (exit $__ir)"
        __inst_fail=$((__inst_fail + 1))
    fi
}

# ── 基础工具（逐包，单个失败不阻断）─────────────────────
__inst bash
__inst htop
__inst lsblk
__inst smartmontools
__inst fdisk

# ── Samba（两个独立阈值）────────────────────────────────
# samba4-server 本体：Flash >= 64MB（安装体积约 50MB）
# luci-app-samba4 等 LuCI 包：由 __skip_luci（Flash < 25MB）控制
# 重新读取 Flash（安装基础包后已减少）
__flash=$(df /overlay 2>/dev/null | awk 'NR==2{print $4}')
if [ "${__flash:-0}" -ge 65536 ]; then
    __inst samba4-server
    if [ "$__skip_luci" -eq 0 ]; then
        __inst luci-app-samba4 luci-i18n-samba4-zh-cn
    else
        log "跳过 luci-app-samba4（Flash 紧张）"
    fi
else
    log "Flash 不足 64MB（${__flash}KB），跳过 samba4"
fi

# ── 修复 avahi 崩溃循环 ──────────────────────────────────
# 实测：samba4 安装后 dbus post-install 报 /etc/dbus-1 不存在
#       导致 avahi 反复崩溃重启，stop dbus 再 start 可修复
mkdir -p /etc/dbus-1
/etc/init.d/avahi-daemon stop  2>/dev/null || true; sleep 1
/etc/init.d/dbus        stop   2>/dev/null || true; sleep 1
/etc/init.d/dbus        start  2>/dev/null || true; sleep 2
/etc/init.d/avahi-daemon start 2>/dev/null || true; sleep 1
log "dbus/avahi-daemon 已重载"

# ── zram 兜底（无 U 盘时补充内存）───────────────────────
if ! grep -q zram /proc/swaps 2>/dev/null; then
    if modprobe zram num_devices=1 2>/dev/null \
    && [ -e /sys/block/zram0/disksize ]; then
        echo "134217728" > /sys/block/zram0/disksize
        mkswap /dev/zram0 >/dev/null 2>&1
        swapon /dev/zram0 2>/dev/null \
            && log "zram 128MB 已激活" \
            || log "zram 激活失败"
    else
        log "内核不支持 zram（属正常）"
    fi
fi

# ── 刷新 LuCI ─────────────────────────────────────────────
rm -f /tmp/luci-indexcache* 2>/dev/null
/etc/init.d/rpcd restart 2>/dev/null || true

# ── Phase 1 收尾 ──────────────────────────────────────────
if [ "$__inst_fail" -eq 0 ]; then
    touch "$_DONE"
    rm -f "$_SD/phase1-failures"
    __flash_pct=$(df /overlay 2>/dev/null | awk 'NR==2{print $5}' | tr -d '%')
    log "基础环境完成！Flash 使用率: ${__flash_pct:-?}%"
    [ "${__flash_pct:-0}" -gt 85 ] && log "Flash >85%，建议: apk cache clean"
else
    echo $((__fail + 1)) > "$_SD/phase1-failures"
    log "$__inst_fail 项失败（重试 $((__fail + 1))/3）"
    exit 1
fi

# ── 检测 U 盘，后台触发 Phase 2（不阻塞 DNS trap）───────
if [ ! -f "$_USB_DONE" ]; then
    log "检测 U 盘（最长 60 秒）..."
    __ump=""
    __ui=1
    while [ "$__ui" -le 30 ]; do
        for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb \
                   /mnt/usb /mnt/mmcblk0p1; do
            _is_mounted "$_mp" && { __ump="$_mp"; break 2; }
        done
        sleep 2; __ui=$((__ui + 1))
    done
    # 兜底：从 /proc/mounts 扫描
    [ -z "$__ump" ] && \
        __ump=$(awk '/^\/dev\/sd[a-z][0-9]+ /{print $2; exit}' \
                /proc/mounts 2>/dev/null)

    if [ -n "$__ump" ]; then
        log "检测到 U 盘: $__ump，后台触发 Phase 2"
        # 后台调用：run.sh 的 trap 在退出时恢复 DNS，
        # 不能阻塞等待 install-usb.sh（后者自行管理 DNS）
        /usr/lib/install-extras/install-usb.sh "$__ump" &
    else
        log "未检测到 U 盘，等待热插拔触发"
    fi
fi

log "执行 '360v6-status' 查看完整状态"
RUNEOF
chmod +x /usr/lib/install-extras/run.sh

# ══════════════════════════════════════════════════════════════
