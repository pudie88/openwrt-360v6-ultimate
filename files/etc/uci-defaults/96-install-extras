        # 备用：读 /proc/net/tcp
        __hex_port=$(printf '%04X' "$__port")
        if grep -qi ":${__hex_port} " /proc/net/tcp6 2>/dev/null || \
           grep -qi ":${__hex_port} " /proc/net/tcp 2>/dev/null; then
            return 0
        fi
        sleep 1
        __wi=$((__wi + 1))
    done
    return 1
}

# 检测文件系统是否支持 swap
_fs_supports_swap() {
    __mp="$1"
    __fstype=$(awk -v mp="$__mp " '$0~mp{print $3; exit}' /proc/mounts 2>/dev/null)
    case "${__fstype:-}" in
        ext2|ext3|ext4|btrfs|xfs|f2fs) return 0 ;;
        vfat|exfat|fat*|ntfs|hfsplus)
            log "警告: 文件系统 ${__fstype} 不支持 swap，跳过"
            return 1
            ;;
        *)
            log "警告: 未知文件系统 ${__fstype}，尝试创建 swap"
            return 0
            ;;
    esac
}

mkdir -p "$_SD"

# ── 参数解析 ──────────────────────────────────
__self_heal=0; __force=0; __mp_arg=""
for _a in "$@"; do
    case "$_a" in
        --self-heal) __self_heal=1 ;;
        --force)     __force=1 ;;
        *)           [ -z "$__mp_arg" ] && __mp_arg="$_a" ;;
    esac
done

# ── 自愈模式 ──────────────────────────────────
if [ "$__self_heal" -eq 1 ]; then
    [ -f /etc/install-extras-done ] || exit 0
    _USB=$(_get_usb_mount)
    [ -z "$_USB" ] && exit 0
    [ -f "${_USB}/.install-done" ] || exit 0
    __last_heal=$(cat "$_SD/last-self-heal" 2>/dev/null || echo 0)
    __now=$(awk '{printf "%d", $1}' /proc/uptime 2>/dev/null || echo 0)
    __elapsed=$((__now - __last_heal))
    if [ "$__elapsed" -lt 300 ] && [ "$__elapsed" -gt 0 ]; then
        exit 0
    fi
    echo "$__now" > "$_SD/last-self-heal"
    exec /usr/lib/install-extras/install-usb.sh "$_USB"
    exit 0
fi

# ── 找到 U 盘 ─────────────────────────────────
_USB=""
[ -n "$__mp_arg" ] && _is_mounted "$__mp_arg" && _USB="$__mp_arg"
[ -z "$_USB" ] && _USB=$(_get_usb_mount)
[ -z "$_USB" ] && { echo "未找到已挂载的 U 盘"; exit 1; }

__dev=$(awk -v mp="$_USB " '$0 ~ mp {print $1; exit}' /proc/mounts 2>/dev/null)
_is_usb_dev "$__dev" || { log "设备 ${__dev:-未知} 不是 USB 分区，跳过"; exit 0; }

# ── U 盘标记（V4.0 核心）─────────────────────
_USB_DONE="${_USB}/.install-done"
_RESUME_MODE=0

if [ "$__force" -eq 1 ]; then
    rm -f "$_USB_DONE" "$_SD/docker-done" "$_SD/agh-done"
    rm -f "$_SD/docker-failures" "$_SD/agh-failures"
    rm -f "$_USB/.agh-finalized"
    log "--force：已清零所有状态（含 U 盘标记）"
elif [ -f "$_USB_DONE" ]; then
    _RESUME_MODE=1
    log "检测到 U 盘部署标记，进入恢复模式"
fi

# ── Lock ──────────────────────────────────────
if [ -f "$_LOCK" ]; then
    __lp=$(cat "$_LOCK" 2>/dev/null)
    kill -0 "$__lp" 2>/dev/null && exit 0
    rm -f "$_LOCK"
fi
echo $$ > "$_LOCK"

__dns_backup=$(cat /etc/resolv.conf 2>/dev/null)
[ -z "$__dns_backup" ] && __dns_backup="nameserver 127.0.0.1"

_cleanup() {
    rm -f "$_LOCK"
    # V4.0 修复：只有 AGH 未完成 finalize 时才恢复 DNS
    if [ ! -f "${_USB}/.agh-finalized" ]; then
        printf '%s\n' "$__dns_backup" > /etc/resolv.conf 2>/dev/null
    fi
    sync 2>/dev/null || true
}
trap '_cleanup' EXIT INT TERM

echo "$_USB" > "$_MF"
log "部署开始 | U 盘: $_USB ($__dev) | 模式: $([ "$_RESUME_MODE" -eq 1 ] && echo '恢复' || echo '全新')"

# ── 临时 DNS ──────────────────────────────────
if [ ! -f "${_USB}/.agh-finalized" ]; then
    _upstream_dns=$(uci get dhcp.@dnsmasq[0].server 2>/dev/null | \
        head -1 | cut -d'/' -f3)
    if [ -n "$_upstream_dns" ]; then
        echo "nameserver $_upstream_dns" > /etc/resolv.conf
    else
        printf 'nameserver 223.5.5.5\nnameserver 8.8.8.8\n' > /etc/resolv.conf
    fi
    log "临时 DNS 已注入"
fi

# ══════════════════════════════════════════════
# 恢复模式：直接启动已有服务
# ══════════════════════════════════════════════
if [ "$_RESUME_MODE" -eq 1 ]; then
    log "--- 恢复模式 ---"

    # 1. Swap
    __swapfile="$_USB/swapfile"
    if [ -f "$__swapfile" ] && ! grep -q "$__swapfile" /proc/swaps 2>/dev/null; then
        swapon "$__swapfile" 2>/dev/null && log "swap 已恢复" || log "swap 恢复失败"
    fi

    # 2. 符号链接
    for _b in docker dockerd containerd containerd-shim-runc-v2 ctr runc; do
        [ -f "$_USB/docker-bin/$_b" ] && \
            ln -sf "$_USB/docker-bin/$_b" "/usr/bin/$_b" 2>/dev/null
    done
    [ -f "$_USB/adguardhome-bin/AdGuardHome" ] && \
        ln -sf "$_USB/adguardhome-bin/AdGuardHome" /usr/bin/AdGuardHome 2>/dev/null

    # 3. Docker
    if [ -f "$_USB/docker-bin/dockerd" ]; then
        /etc/init.d/dockerd start 2>/dev/null
        sleep 5
        docker info >/dev/null 2>&1 && \
            log "Docker $(cat "$_USB/docker-bin/version.txt" 2>/dev/null) 已恢复" || \
            log "Docker 启动中（守护进程初始化）"
    fi

    # 4. AGH
    if [ -f "$_USB/adguardhome-bin/AdGuardHome" ]; then
        /etc/init.d/adguardhome start 2>/dev/null
        sleep 3
        pgrep -f "AdGuardHome" >/dev/null 2>&1 && \
            log "AGH $(cat "$_USB/adguardhome-bin/version.txt" 2>/dev/null) 已恢复" || \
            log "AGH 启动失败，请执行 360v6-health --fix"
    fi

    # 5. OOM 保护
    for _proc in dockerd containerd AdGuardHome; do
        _pid=$(pgrep -f "$_proc" 2>/dev/null | head -1)
        [ -n "$_pid" ] && echo -500 > "/proc/$_pid/oom_score_adj" 2>/dev/null
    done

    log "恢复完成"
    rm -f "$_LOCK"
    exit 0
fi

# ══════════════════════════════════════════════
# 全新部署模式
# ══════════════════════════════════════════════

__usb_free=$(df -k "$_USB" 2>/dev/null | awk 'NR==2{print $4}')
[ "${__usb_free:-0}" -lt 1048576 ] && { log "U 盘可用空间不足（< 1GB）"; exit 1; }

__dl_dir="$_USB/.downloads"
mkdir -p "$__dl_dir"

# ── Swap ──────────────────────────────────────
_swap_mb=256
_ram_mb=$(free -m 2>/dev/null | awk '/Mem:/{print $2}')
[ "${_ram_mb:-0}" -lt 256 ] && _swap_mb=512
__swapfile="$_USB/swapfile"

if ! grep -q "$__swapfile" /proc/swaps 2>/dev/null; then
    if _fs_supports_swap "$_USB"; then
        if [ ! -f "$__swapfile" ]; then
            log "创建 ${_swap_mb}MB swap..."
            if dd if=/dev/zero of="${__swapfile}.tmp" \
                bs=1M count=$_swap_mb 2>/dev/null; then
                mv "${__swapfile}.tmp" "$__swapfile" && \
                chmod 600 "$__swapfile" && \
                mkswap "$__swapfile" >/dev/null 2>&1 || {
                    rm -f "$__swapfile"
                    log "swap 格式化失败"
                }
            else
                rm -f "${__swapfile}.tmp"
                log "swap 创建失败（空间不足？）"
            fi
        fi
        if [ -f "$__swapfile" ]; then
            swapon "$__swapfile" 2>/dev/null
            grep -q "$__swapfile" /proc/swaps 2>/dev/null && {
                log "swap 已激活 (${_swap_mb}MB)"
                echo 10   > /proc/sys/vm/swappiness 2>/dev/null
                echo 8192 > /proc/sys/vm/min_free_kbytes 2>/dev/null
            } || log "swap swapon 失败"
        fi
    fi
fi

# ── Docker 部署 ───────────────────────────────
_DOCKER_FAIL=0
log "--- Docker 部署 ---"
__docker_fail_count=$(cat "$_SD/docker-failures" 2>/dev/null || echo 0)

if [ -f "$_SD/docker-done" ] && docker info >/dev/null 2>&1; then
    log "Docker 已运行，跳过"
elif [ "${__docker_fail_count:-0}" -ge 3 ]; then
    log "Docker 连续失败 ${__docker_fail_count} 次，跳过（--force 重置）"
    _DOCKER_FAIL=1
else
    __dbin="$_USB/docker-bin"
    __ddata="$_USB/docker-data"
    mkdir -p "$__dbin" "$__ddata" /etc/docker

    # 预下载（串行，避免并发文件冲突）
    for _dv in $_DOCKER_VERS; do
        __dtgz="$__dl_dir/docker-${_dv}.tgz"
        [ -f "$__dtgz" ] && break
        log "预下载 Docker ${_dv}..."
        _wget_retry "$_DOCKER_BASE/docker-${_dv}.tgz" \
            "${__dtgz}.tmp" 62914560 && \
            gzip -t "${__dtgz}.tmp" 2>/dev/null && \
            mv "${__dtgz}.tmp" "$__dtgz" || {
            rm -f "${__dtgz}.tmp"
            log "预下载 Docker ${_dv} 失败"
        }
        break  # 只预下载第一个
    done

    __docker_ver=""
    for _dv in $_DOCKER_VERS; do
        __dtgz="$__dl_dir/docker-${_dv}.tgz"
        if [ ! -f "$__dtgz" ]; then
            log "下载 Docker ${_dv}..."
            _wget_retry "$_DOCKER_BASE/docker-${_dv}.tgz" \
                "${__dtgz}.tmp" 62914560 || continue
            _verify_checksum "${__dtgz}.tmp" \
                "$_DOCKER_EXPECTED_SHA256" "Docker ${_dv}" || {
                rm -f "${__dtgz}.tmp"; continue
            }
            gzip -t "${__dtgz}.tmp" 2>/dev/null || {
                log "Docker ${_dv} 包损坏"
                rm -f "${__dtgz}.tmp"; continue
            }
            mv "${__dtgz}.tmp" "$__dtgz"
        fi

        log "解压 Docker ${_dv}..."
        rm -rf "$__dbin"/* 2>/dev/null
        if _tar_extract "$__dtgz" "$__dbin" "docker" && \
           [ -f "$__dbin/dockerd" ]; then
            __docker_ver="$_dv"
            break
        else
            log "解压失败，尝试下一版本"
            rm -f "$__dtgz"
        fi
    done

    if [ -n "$__docker_ver" ]; then
        # 写版本文件
        echo "$__docker_ver" > "$__dbin/version.txt"

        # 符号链接
        for _b in docker dockerd containerd containerd-shim-runc-v2 ctr runc; do
            [ -f "$__dbin/$_b" ] && \
                ln -sf "$__dbin/$_b" "/usr/bin/$_b" 2>/dev/null
        done

        # 存储驱动
        __storage_driver="overlay2"
        if ! grep -q "^overlay$" /proc/filesystems 2>/dev/null; then
            log "overlay 模块不可用，降级为 vfs"
            __storage_driver="vfs"
        fi

        # daemon.json（V4.0：iptables:false/bridge:none/userland-proxy:false）
        cat > /etc/docker/daemon.json << DOCKEREOF
{
  "data-root": "$__ddata",
  "storage-driver": "$__storage_driver",
  "iptables": false,
  "bridge": "none",
  "log-driver": "json-file",
  "log-opts": {"max-size": "5m", "max-file": "2"},
  "registry-mirrors": ["https://docker.m.daocloud.io"],
  "userland-proxy": false
}
DOCKEREOF
        log "daemon.json 已写入（storage: ${__storage_driver}）"

        # dockerd init.d（V4.0：补充 PATH）
        cat > /etc/init.d/dockerd << DINITEOF
#!/bin/sh /etc/rc.common
START=99; STOP=10; USE_PROCD=1

_get_usb_mount() {
    for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        grep -q "^[^ ]* \$_mp " /proc/mounts 2>/dev/null && { echo "\$_mp"; return 0; }
    done
    return 1
}

start_service() {
    _mp=\$(_get_usb_mount)
    [ -n "\$_mp" ] && [ -f "\$_mp/docker-bin/dockerd" ] || return 1

    grep -q "^[^ ]* /sys/fs/cgroup cgroup2" /proc/mounts 2>/dev/null || \
        mount -t cgroup2 none /sys/fs/cgroup 2>/dev/null || true

    procd_open_instance
    procd_set_param env PATH="/usr/sbin:/usr/bin:/sbin:/bin:\$_mp/docker-bin"
    procd_set_param command "\$_mp/docker-bin/dockerd" \
        --config-file /etc/docker/daemon.json
    procd_set_param stdout 1
    procd_set_param stderr 1
    procd_set_param respawn 3600 5 3
    procd_close_instance
}

stop_service() { pkill dockerd 2>/dev/null || true; }
DINITEOF
        chmod +x /etc/init.d/dockerd
        /etc/init.d/dockerd enable 2>/dev/null
        /etc/init.d/dockerd start 2>/dev/null
        sleep 5

        _timeout 15 docker info >/dev/null 2>&1 && \
            log "Docker $__docker_ver 已启动并响应" || \
            log "Docker $__docker_ver 已启动（初始化中）"

        date '+%Y-%m-%d %H:%M:%S' > "$_SD/docker-done"
        rm -f "$_SD/docker-failures"
    else
        _DOCKER_FAIL=1
        echo $((__docker_fail_count + 1)) > "$_SD/docker-failures"
        log "Docker 部署失败（已尝试全部版本）"
    fi
fi

# ── AGH 部署 ──────────────────────────────────
_AGH_FAIL=0
log "--- AdGuardHome 部署 ---"
__agh_fail_count=$(cat "$_SD/agh-failures" 2>/dev/null || echo 0)

if [ -f "$_SD/agh-done" ] && pgrep -f "AdGuardHome" >/dev/null 2>&1; then
    log "AGH 已运行，跳过"
elif [ "${__agh_fail_count:-0}" -ge 3 ]; then
    log "AGH 连续失败 ${__agh_fail_count} 次，跳过（--force 重置）"
    _AGH_FAIL=1
else
    __abin="$_USB/adguardhome-bin"
    __adata="$_USB/AdGuardHome"
    mkdir -p "$__abin" "$__adata"

    __atgz="$__dl_dir/AdGuardHome_linux_arm64.tar.gz"

    if [ ! -f "$__abin/AdGuardHome" ]; then
        if [ ! -f "$__atgz" ]; then
            log "下载 AdGuardHome..."
            if ! _wget_retry "$_AGH_URL" "${__atgz}.tmp" 15728640; then
                _AGH_FAIL=1
            else
                _verify_checksum "${__atgz}.tmp" \
                    "$_AGH_EXPECTED_SHA256" "AdGuardHome" || {
                    rm -f "${__atgz}.tmp"; _AGH_FAIL=1
                }
                [ "$_AGH_FAIL" -eq 0 ] && mv "${__atgz}.tmp" "$__atgz"
            fi
        fi

        if [ "$_AGH_FAIL" -eq 0 ] && [ -f "$__atgz" ]; then
            log "解压 AdGuardHome..."
            if _tar_extract "$__atgz" "$__abin" "AdGuardHome" && \
               [ -f "$__abin/AdGuardHome" ]; then
                chmod +x "$__abin/AdGuardHome"
                # 写版本文件
                _aver=$("$__abin/AdGuardHome" --version 2>/dev/null | \
                    grep -o 'v[0-9.]*' | head -1 || echo "未知")
                echo "$_aver" > "$__abin/version.txt"
                log "AGH 二进制就绪（${_aver}）"
            else
                log "AGH 解压失败"
                rm -f "$__atgz"
                _AGH_FAIL=1
            fi
        fi
    else
        # 已有二进制，补写版本文件
        if [ ! -f "$__abin/version.txt" ]; then
            _aver=$("$__abin/AdGuardHome" --version 2>/dev/null | \
                grep -o 'v[0-9.]*' | head -1 || echo "未知")
            echo "$_aver" > "$__abin/version.txt"
        fi
    fi

    if [ "$_AGH_FAIL" -eq 0 ] && [ -f "$__abin/AdGuardHome" ]; then
        ln -sf "$__abin/AdGuardHome" /usr/bin/AdGuardHome 2>/dev/null

        _pkg_install luci-app-adguardhome 2>/dev/null && \
            log "LuCI AGH 插件已安装" || \
            log "LuCI AGH 插件安装失败（可选）"

        /etc/init.d/adguardhome enable 2>/dev/null
        /etc/init.d/adguardhome restart 2>/dev/null

        # V4.0：等待 AGH 进程（不强要求端口，进程起来即算成功）
        log "等待 AGH 进程启动..."
        __awi=0
        while [ "$__awi" -lt 15 ]; do
            pgrep -f "AdGuardHome" >/dev/null 2>&1 && break
            sleep 1
            __awi=$((__awi + 1))
        done

        if pgrep -f "AdGuardHome" >/dev/null 2>&1; then
            # OOM 保护
            for _proc in dockerd containerd AdGuardHome; do
                _pid=$(pgrep -f "$_proc" 2>/dev/null | head -1)
                [ -n "$_pid" ] && \
                    echo -500 > "/proc/$_pid/oom_score_adj" 2>/dev/null
            done
            log "AGH 进程已启动，OOM 保护已设置"
            log ">>> 访问 http://192.168.2.1:3000 完成向导 <<<"
            log ">>> 完成后执行: AGH_USER=xxx AGH_PASS=xxx agh-finalize <<<"
            date '+%Y-%m-%d %H:%M:%S' > "$_SD/agh-done"
            rm -f "$_SD/agh-failures"
        else
            log "AGH 进程启动失败，请查看日志"
            _AGH_FAIL=1
        fi
    else
        _AGH_FAIL=1
    fi

    [ "$_AGH_FAIL" -eq 1 ] && \
        echo $((__agh_fail_count + 1)) > "$_SD/agh-failures"
fi

rm -f /tmp/luci-indexcache* 2>/dev/null
/etc/init.d/rpcd reload 2>/dev/null || true

# ── 写 U 盘完成标记 ───────────────────────────
if [ "$_DOCKER_FAIL" -eq 0 ] && [ "$_AGH_FAIL" -eq 0 ]; then
    date '+%Y-%m-%d %H:%M:%S' > "$_USB_DONE"
    log "部署完成 [Docker:OK AGH:OK]"
    log "U 盘标记已写入，下次启动将进入恢复模式"
    exit 0
elif [ "$_DOCKER_FAIL" -eq 0 ] || [ "$_AGH_FAIL" -eq 0 ]; then
    # 部分成功也写标记（避免重复下载已成功的部分）
    date '+%Y-%m-%d %H:%M:%S' > "$_USB_DONE"
    log "部分完成 [Docker:$([ $_DOCKER_FAIL -eq 0 ] && echo OK || echo FAIL) AGH:$([ $_AGH_FAIL -eq 0 ] && echo OK || echo FAIL)]"
    exit 2
else
    log "部署失败 [Docker:FAIL AGH:FAIL]"
    exit 1
fi
USBEOF
chmod +x /usr/lib/install-extras/install-usb.sh

# ══════════════════════════════════════════════════════════════
