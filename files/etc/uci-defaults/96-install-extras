_SD="/etc/install-state"

log() { echo "[$(date '+%H:%M:%S')] $1" | logger -t "$_LT"; }

_get_usb_mount() {
    for _mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        grep -q "^[^ ]* $_mp " /proc/mounts 2>/dev/null && { echo "$_mp"; return 0; }
    done
    return 1
}

mkdir -p "$_SD"
[ -f "$_DONE" ] && {
    # 基础环境已就绪，检查是否需要启动 USB 服务
    _mp=$(_get_usb_mount)
    if [ -n "$_mp" ] && [ -f "${_mp}/.install-done" ]; then
        # U 盘有标记，检查服务是否在跑
        pgrep -f "AdGuardHome" >/dev/null 2>&1 || \
            /usr/lib/install-extras/install-usb.sh "$_mp" &
    fi
