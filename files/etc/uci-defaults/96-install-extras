_restore_echo() { stty echo 2>/dev/null; }; trap '_restore_echo' EXIT INT TERM HUP

[ -z "$_user" ] && { printf "AGH 用户名: "; read -r _user; }
[ -z "$_user" ] && { echo "[ERR] 用户名为空"; exit 1; }
if [ -z "$_pass" ]; then
    if [ -t 0 ]; then printf "AGH 密码: "; stty -echo 2>/dev/null; read -r _pass; stty echo 2>/dev/null; echo ""
    else echo "[ERR] 非终端，用 AGH_PASS=xxx 传入"; exit 1; fi
fi
[ -z "$_pass" ] && { echo "[ERR] 密码为空"; exit 1; }
command -v curl >/dev/null 2>&1 || { echo "[ERR] 需要 curl"; exit 1; }
pgrep -f "AdGuardHome" >/dev/null 2>&1 || { echo "[ERR] AGH 未运行"; exit 1; }

_agh_port=""
