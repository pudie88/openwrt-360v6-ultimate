        -u "${_user}:${_pass}" "http://127.0.0.1:${_p}/control/status" 2>/dev/null)
    if [ "$_hc" = "200" ]; then
        _agh_port="$_p"
        break
    fi
done

if [ -z "$_agh_port" ]; then
    echo "[ERR] 无法连接到 AGH（尝试端口 3000/5354/8080），请确认向导已完成且凭据正确"
    exit 1
fi

