#!/bin/sh
# 96-install-extras [Final v4.4]
# 适用：360 V6 / 小米 CR660x / IPQ6000 (128M Flash)
# 修复：apk锁等待 / dockerd强制安装 / run.sh完成后主动检测U盘 / block hotplug竞态
# v4.4 修复：U盘已插但挂载慢导致轮询超时未检测到的问题

DONE_FLAG="/etc/install-extras-done"
USB_DONE="/etc/install-usb-done"

mkdir -p /usr/lib/install-extras /usr/bin /etc/hotplug.d/iface /etc/hotplug.d/block

# ══════════════════════════════════════════════════════════════
# 模块 0：状态查询工具 (360v6-status)
# ══════════════════════════════════════════════════════════════
cat > /usr/bin/360v6-status << 'STATUSEOF'
#!/bin/sh
echo "🔍 360 V6 部署状态 @ $(date '+%Y-%m-%d %H:%M:%S')"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
[ -f /etc/install-extras-done ] \
    && echo "✅ 基础环境: 已完成" \
    || echo "⏳ 基础环境: 待触发/安装中"
[ -f /etc/install-usb-done ] \
    && echo "✅ 重型应用: 已完成" \
    || echo "⏳ 重型应用: 待 U 盘/安装中"
echo ""
df -h /overlay 2>/dev/null \
    | awk 'NR==2 {print "📦 Flash: "$3" used / "$2" total ("$5")"}'
free -h 2>/dev/null \
    | awk '/Mem:/ {print "🧠 内存: 已用 "$3" / 总计 "$2}'
echo ""
docker info >/dev/null 2>&1 \
    && echo "🐳 Docker: 运行中" || echo "🐳 Docker: 未启动"
pgrep AdGuardHome >/dev/null 2>&1 \
    && echo "🛡️  AdGuardHome: 运行中" || echo "🛡️  AdGuardHome: 未启动"
grep -q zram     /proc/swaps 2>/dev/null && echo "💾 zram: 已激活"
grep -q swapfile /proc/swaps 2>/dev/null && echo "🔌 U盘 Swap: 已激活"
echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
echo "💡 手动重跑基础环境: rm -f /etc/install-extras-done && /usr/lib/install-extras/run.sh"
echo "💡 手动重跑重型应用: rm -f /etc/install-usb-done && /usr/lib/install-extras/install-usb.sh"
STATUSEOF
chmod +x /usr/bin/360v6-status

# ══════════════════════════════════════════════════════════════
# 模块 A：install-usb.sh（重型应用：Docker / AGH）
# ══════════════════════════════════════════════════════════════
cat > /usr/lib/install-extras/install-usb.sh << 'USBEOF'
#!/bin/sh
LOG_TAG="usb-extras"
USB_DONE="/etc/install-usb-done"
USB_LOCK="/tmp/install-usb.lock"

log() { echo "[$(date '+%H:%M:%S')] $1" | logger -t "$LOG_TAG"; }

[ -f "$USB_DONE" ] && { log "ℹ️  重型应用已安装，跳过"; exit 0; }
[ -f "$USB_LOCK" ] && { log "⚠️  实例运行中，跳过"; exit 0; }
touch "$USB_LOCK"

# ── U 盘挂载点解析 ──────────────────────────────────────────
USB_MOUNT="$1"
if [ -z "$USB_MOUNT" ]; then
    for mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        mountpoint -q "$mp" 2>/dev/null && { USB_MOUNT="$mp"; break; }
    done
fi
if [ -z "$USB_MOUNT" ]; then
    log "❌ 未检测到 U 盘挂载点，退出"
    rm -f "$USB_LOCK"; exit 1
fi
log "▶ 重型应用部署启动 | 目标: $USB_MOUNT"

# ── DNS 保护（仅在异常时注入，退出时精确恢复）──────────────
RESTORE_DNS=0
OLD_RESOLV=""
if ! nslookup baidu.com >/dev/null 2>&1; then
    log "⚠️  DNS 未就绪，注入临时 DNS"
    OLD_RESOLV=$(cat /etc/resolv.conf 2>/dev/null)
    printf 'nameserver 223.5.5.5\nnameserver 8.8.8.8\n' > /etc/resolv.conf
    RESTORE_DNS=1
fi
restore_dns() {
    [ "$RESTORE_DNS" = "1" ] && [ -n "$OLD_RESOLV" ] && \
        echo "$OLD_RESOLV" > /etc/resolv.conf
}
trap restore_dns EXIT

# ── I/O 调度优化 ────────────────────────────────────────────
USB_DEV=$(mount | grep " $USB_MOUNT " | awk '{print $1}' | sed 's|/dev/||;s|[0-9]*$||')
SCHED="/sys/block/${USB_DEV}/queue/scheduler"
if [ -n "$USB_DEV" ] && [ -f "$SCHED" ]; then
    if grep -q "mq-deadline" "$SCHED" 2>/dev/null; then
        echo "mq-deadline" > "$SCHED" 2>/dev/null
    else
        echo "deadline" > "$SCHED" 2>/dev/null
    fi
    log "⚡ I/O 调度器: $(cat "$SCHED" 2>/dev/null | grep -oE '\[[^]]+\]' | tr -d '[]')"
fi
echo "10"    > /proc/sys/vm/swappiness      2>/dev/null
echo "16384" > /proc/sys/vm/min_free_kbytes 2>/dev/null
log "⚡ 内存参数: swappiness=10, min_free_kbytes=16MB"

# ── Swap（原子写入，防断电损坏）────────────────────────────
if [ ! -f "$USB_MOUNT/swapfile" ]; then
    log "⏳ 创建 256MB Swap（原子写入）..."
    if dd if=/dev/zero of="$USB_MOUNT/swapfile.tmp" bs=1M count=256 2>/dev/null; then
        mv "$USB_MOUNT/swapfile.tmp" "$USB_MOUNT/swapfile"
        sync
        chmod 600 "$USB_MOUNT/swapfile"
        mkswap "$USB_MOUNT/swapfile" >/dev/null 2>&1
        log "✅ Swap 文件已创建"
    else
        rm -f "$USB_MOUNT/swapfile.tmp"
        log "⚠️  Swap 创建失败（U 盘空间不足？）"
    fi
fi
if [ -f "$USB_MOUNT/swapfile" ]; then
    swapon "$USB_MOUNT/swapfile" 2>/dev/null \
        && log "✅ Swap 已激活" \
        || log "ℹ️  Swap 已挂载或激活失败，跳过"
fi

# ── 等待 apk 数据库锁释放（最长 60 秒）─────────────────────
log "⏳ 等待 apk 数据库就绪..."
for i in $(seq 1 30); do
    apk info >/dev/null 2>&1 && break
    log "⏳ apk 数据库锁占用，等待... ($i/30)"
    sleep 2
done
if ! apk info >/dev/null 2>&1; then
    log "❌ apk 数据库长时间锁定，退出"
    rm -f "$USB_LOCK"; exit 1
fi
log "✅ apk 数据库就绪"

# ── 安装函数 ────────────────────────────────────────────────
INSTALL_FAIL=0
install_pkg() {
    local tmp ret
    tmp=$(mktemp /tmp/apk-out.XXXXXX)
    log "📦 安装: $*"
    apk add --no-cache "$@" > "$tmp" 2>&1
    ret=$?
    cat "$tmp" | logger -t "$LOG_TAG"
    rm -f "$tmp"
    if [ "$ret" -eq 0 ]; then
        log "✅ 完成: $*"
    else
        log "❌ 失败: $* (exit $ret)"
        INSTALL_FAIL=$((INSTALL_FAIL + 1))
    fi
}

# ── Flash 空间检测 ───────────────────────────────────────────
FLASH_FREE=$(df /overlay 2>/dev/null | awk 'NR==2 {print $4}')

# ── Docker 部署 ─────────────────────────────────────────────
log "📦 部署 Docker..."
mkdir -p "$USB_MOUNT/docker-data" /etc/docker
cat > /etc/docker/daemon.json << EOD
{
  "data-root": "$USB_MOUNT/docker-data",
  "storage-driver": "overlay2",
  "log-driver": "json-file",
  "log-opts": {"max-size": "5m", "max-file": "2"}
}
EOD

install_pkg docker

# dockerd 单独强制安装，绕过 kmod 版本依赖冲突
log "📦 强制安装: dockerd"
tmp=$(mktemp /tmp/apk-out.XXXXXX)
apk add --no-cache --force-broken-world dockerd > "$tmp" 2>&1
ret=$?
cat "$tmp" | logger -t "$LOG_TAG"
rm -f "$tmp"
if [ "$ret" -eq 0 ]; then
    log "✅ 完成: dockerd"
else
    log "❌ 失败: dockerd (exit $ret)"
    INSTALL_FAIL=$((INSTALL_FAIL + 1))
fi

if [ "${FLASH_FREE:-99999}" -ge 25000 ]; then
    install_pkg luci-app-dockerman luci-i18n-dockerman-zh-cn
else
    log "ℹ️  Flash <25MB，跳过 dockerman LuCI（可用 CLI 管理）"
fi

if [ "$INSTALL_FAIL" -eq 0 ]; then
    mountpoint -q /sys/fs/cgroup || mount -t cgroup2 none /sys/fs/cgroup 2>/dev/null || true
    /etc/init.d/dockerd enable 2>/dev/null || true
    /etc/init.d/dockerd start  2>/dev/null || true
    log "✅ Docker 已启动 | data-root: $USB_MOUNT/docker-data"
else
    log "⚠️  Docker 安装有失败项，跳过启动"
fi

# ── AdGuardHome 部署 ────────────────────────────────────────
log "📦 部署 AdGuardHome..."
install_pkg adguardhome

AGH_DIR="$USB_MOUNT/AdGuardHome"
mkdir -p "$AGH_DIR/config" "$AGH_DIR/data"
/etc/init.d/adguardhome stop 2>/dev/null || true

# 配置迁移（首次且 U 盘无旧配置时）
if [ ! -f "$AGH_DIR/config/adguardhome.yaml" ] \
&& [ -f "/etc/adguardhome/adguardhome.yaml" ]; then
    cp -a /etc/adguardhome/. "$AGH_DIR/config/" 2>/dev/null
    log "✅ AGH 配置已迁移至 U 盘（首次）"
else
    log "ℹ️  AGH 配置已存在或无源配置，不覆盖"
fi

# 运行数据迁移（首次且源目录非空时）
if [ ! "$(ls -A "$AGH_DIR/data" 2>/dev/null)" ] \
&& [ -d "/var/lib/adguardhome" ] \
&& [ "$(ls -A /var/lib/adguardhome 2>/dev/null)" ]; then
    cp -a /var/lib/adguardhome/. "$AGH_DIR/data/" 2>/dev/null
    log "✅ AGH 运行数据已迁移至 U 盘（首次）"
else
    log "ℹ️  AGH 数据目录已有内容或源为空，跳过迁移"
fi

uci set adguardhome.config.config_file="$AGH_DIR/config/adguardhome.yaml" 2>/dev/null || true
uci set adguardhome.config.work_dir="$AGH_DIR/data"                        2>/dev/null || true
uci commit adguardhome 2>/dev/null || true
/etc/init.d/adguardhome enable 2>/dev/null || true
/etc/init.d/adguardhome start  2>/dev/null || true
log "✅ AdGuardHome 已启动 | 配置+数据: $AGH_DIR"

if [ "${FLASH_FREE:-99999}" -ge 25000 ]; then
    install_pkg luci-app-adguardhome
else
    log "ℹ️  Flash <25MB，跳过 adguardhome LuCI（可用 :3000 Web 管理）"
fi

# ── 刷新 LuCI ───────────────────────────────────────────────
rm -f /tmp/luci-indexcache* 2>/dev/null || true
/etc/init.d/rpcd restart 2>/dev/null || true
rm -f "$USB_LOCK"

if [ "$INSTALL_FAIL" -eq 0 ]; then
    touch "$USB_DONE"
    log "🎉 重型应用部署完成"
    exit 0
else
    log "⚠️  $INSTALL_FAIL 组包失败，可手动重跑: rm -f /etc/install-usb-done && /usr/lib/install-extras/install-usb.sh"
    exit 1
fi
USBEOF
chmod +x /usr/lib/install-extras/install-usb.sh

# ══════════════════════════════════════════════════════════════
# 模块 B：run.sh（基础环境部署）
# ══════════════════════════════════════════════════════════════
cat > /usr/lib/install-extras/run.sh << 'RUNEOF'
#!/bin/sh
LOG_TAG="install-main"
DONE_FLAG="/etc/install-extras-done"
USB_DONE="/etc/install-usb-done"
LOCK="/tmp/install-main.lock"

log() { echo "[$(date '+%H:%M:%S')] $1" | logger -t "$LOG_TAG"; }

[ -f "$DONE_FLAG" ] && { log "ℹ️  基础环境已完成，跳过"; exit 0; }
[ -f "$LOCK" ]      && { log "⚠️  实例运行中，跳过"; exit 0; }
touch "$LOCK"

log "▶ Final v4.4 基础环境启动"

# ── 清理无效软件源 ───────────────────────────────────────────
for f in /etc/apk/repositories.d/*.list; do
    [ -f "$f" ] && sed -i '/\/video\//d' "$f"
done 2>/dev/null

# ── 等待网络（最长 3 分钟，串行双 DNS）─────────────────────
sleep 10
NETWORK_OK=0
for i in $(seq 1 36); do
    ping -c1 -W2 223.5.5.5 >/dev/null 2>&1 && { NETWORK_OK=1; break; }
    ping -c1 -W2 8.8.8.8   >/dev/null 2>&1 && { NETWORK_OK=1; break; }
    sleep 5
done
if [ "$NETWORK_OK" -eq 0 ]; then
    log "❌ 网络不可达，等待下次 WAN UP 重试"
    rm -f "$LOCK"; exit 1
fi
log "✅ 网络已就绪"

# ── DNS 注入（安装期间临时使用，完成后恢复）────────────────
printf 'nameserver 223.5.5.5\nnameserver 8.8.8.8\n' > /etc/resolv.conf
restore_dns() {
    printf 'nameserver 127.0.0.1\n' > /etc/resolv.conf
    /etc/init.d/dnsmasq restart 2>/dev/null || true
    log "✅ resolv.conf 已恢复，DNS 交还 dnsmasq"
}
trap restore_dns EXIT
log "✅ 临时 DNS 已注入"

# ── apk update（HTTPS → HTTP 自动降级）─────────────────────
apk_update_ok() {
    local tmp n
    tmp=$(mktemp /tmp/apk-upd.XXXXXX)
    apk update > "$tmp" 2>&1
    cat "$tmp" | logger -t "$LOG_TAG"
    n=$(grep -oE 'OK: [0-9]+ distinct' "$tmp" | grep -oE '[0-9]+')
    rm -f "$tmp"
    [ "${n:-0}" -gt 800 ] && return 0

    log "⚠️  HTTPS 源包数不足（${n:-0}），切换 HTTP 重试..."
    for f in /etc/apk/repositories.d/*.list; do
        [ -f "$f" ] && sed -i 's|https://|http://|g' "$f"
    done
    tmp=$(mktemp /tmp/apk-upd.XXXXXX)
    apk update > "$tmp" 2>&1
    cat "$tmp" | logger -t "$LOG_TAG"
    n=$(grep -oE 'OK: [0-9]+ distinct' "$tmp" | grep -oE '[0-9]+')
    rm -f "$tmp"
    [ "${n:-0}" -gt 800 ] && return 0
    return 1
}

if ! apk_update_ok; then
    log "❌ apk update 失败，等待下次重试"
    rm -f "$LOCK"; exit 1
fi
log "✅ apk update 成功"

# ── Flash 空间检测 ───────────────────────────────────────────
FLASH_FREE=$(df /overlay 2>/dev/null | awk 'NR==2 {print $4}')
FLASH_USED=$(df /overlay 2>/dev/null | awk 'NR==2 {print $5}' | tr -d '%')
log "📊 Flash: 已用 ${FLASH_USED:-?}% | 剩余 ${FLASH_FREE:-?}KB"

SKIP_LUCI=0
[ "${FLASH_FREE:-99999}" -lt 25000 ] && SKIP_LUCI=1 \
    && log "⚠️  Flash <25MB，跳过可选 LuCI"

# ── 安装函数 ────────────────────────────────────────────────
INSTALL_FAIL=0
install_pkg() {
    local tmp ret
    tmp=$(mktemp /tmp/apk-out.XXXXXX)
    log "📦 安装: $*"
    apk add --no-cache "$@" > "$tmp" 2>&1
    ret=$?
    cat "$tmp" | logger -t "$LOG_TAG"
    rm -f "$tmp"
    if [ "$ret" -eq 0 ]; then
        log "✅ 完成: $*"
    else
        log "❌ 失败: $* (exit $ret)"
        INSTALL_FAIL=$((INSTALL_FAIL + 1))
    fi
}

# ── 基础工具 ────────────────────────────────────────────────
install_pkg bash htop lsblk smartmontools fdisk

# ── Samba ────────────────────────────────────────────────────
install_pkg samba4-server
if [ "$SKIP_LUCI" -eq 0 ]; then
    install_pkg luci-app-samba4 luci-i18n-samba4-zh-cn
else
    log "ℹ️  跳过 luci-app-samba4（Flash 紧张）"
fi

# ── 修复 avahi 崩溃（Samba 热安装后 dbus 未重载）───────────
/etc/init.d/dbus restart 2>/dev/null || true
sleep 2
/etc/init.d/avahi-daemon restart 2>/dev/null || true
log "✅ dbus/avahi-daemon 已重载"

# ── 收尾基础环境 ────────────────────────────────────────────
rm -f "$LOCK"

if [ "$INSTALL_FAIL" -ne 0 ]; then
    log "⚠️  $INSTALL_FAIL 组包失败，下次 WAN UP 自动重试"
    exit 1
fi

touch "$DONE_FLAG"
FLASH_FINAL=$(df /overlay 2>/dev/null | awk 'NR==2 {print $5}' | tr -d '%')
log "🎉 基础环境部署完成！Flash: ${FLASH_FINAL:-?}%"
[ "${FLASH_FINAL:-0}" -gt 85 ] && log "⚠️  Flash >85%，建议: apk cache clean"

# ── 基础环境完成后主动检测 U 盘 ────────────────────────────
# v4.4 修复：block hotplug 挂载是异步的，run.sh 轮询时挂载可能尚未完成
# 策略：mountpoint 轮询 → 失败则主动尝试挂载块设备 → 再等 30 秒补检
if [ ! -f "$USB_DONE" ]; then
    log "⏳ 检测 U 盘（等待最长 60 秒）..."
    USB_MOUNT=""

    # 第一轮：mountpoint 轮询（60 秒）
    for i in $(seq 1 30); do
        for mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
            mountpoint -q "$mp" 2>/dev/null && { USB_MOUNT="$mp"; break 2; }
        done
        sleep 2
    done

    # 第二轮：若仍未找到，主动尝试挂载已存在的块设备（兼容挂载慢的情况）
    if [ -z "$USB_MOUNT" ]; then
        log "⏳ mountpoint 未就绪，尝试主动挂载块设备..."
        for dev in /dev/sda1 /dev/sda /dev/sdb1 /dev/sdb; do
            if [ -b "$dev" ]; then
                mp="/mnt/$(basename "$dev")"
                mkdir -p "$mp"
                if mount "$dev" "$mp" 2>/dev/null; then
                    log "✅ 主动挂载成功: $dev → $mp"
                    USB_MOUNT="$mp"
                    break
                fi
            fi
        done
    fi

    # 第三轮：再等 30 秒补检（应对系统异步挂载比预期更慢的极端情况）
    if [ -z "$USB_MOUNT" ]; then
        log "⏳ 等待 30 秒后补检挂载点..."
        sleep 30
        for mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
            mountpoint -q "$mp" 2>/dev/null && { USB_MOUNT="$mp"; break; }
        done
    fi

    if [ -n "$USB_MOUNT" ]; then
        log "✅ 检测到 U 盘: $USB_MOUNT，触发重型应用安装..."
        /usr/lib/install-extras/install-usb.sh "$USB_MOUNT"
    else
        log "ℹ️  未检测到 U 盘，启用 zram 兜底..."
        if modprobe zram num_devices=1 2>/dev/null && [ -e /sys/block/zram0/disksize ]; then
            echo "256M" > /sys/block/zram0/disksize 2>/dev/null
            mkswap /dev/zram0 >/dev/null 2>&1
            swapon /dev/zram0 2>/dev/null \
                && log "✅ zram 256MB 已启用" \
                || log "⚠️  zram 启用失败"
        else
            log "⚠️  zram 不可用（内核不支持）"
        fi
        log "ℹ️  插入 U 盘后将自动安装 Docker/AGH"
    fi
fi

log "💡 执行 '360v6-status' 查看完整状态"
RUNEOF
chmod +x /usr/lib/install-extras/run.sh

# ══════════════════════════════════════════════════════════════
# 模块 C：Hotplug 哨兵
# ══════════════════════════════════════════════════════════════

# 网络哨兵：WAN 上线 → 触发基础环境
cat > /etc/hotplug.d/iface/99-install-extras << 'EOF'
#!/bin/sh
[ "$ACTION" = "ifup" ] || exit 0
[ -f /etc/install-extras-done ] && exit 0
case "$INTERFACE" in
    wan|wan6|pppoe-wan)
        logger -t "hotplug" "🌐 WAN 上线，触发基础环境部署"
        /usr/lib/install-extras/run.sh &
        ;;
esac
EOF

# 磁盘哨兵：U 盘热插拔 → 触发重型应用
# 作为兜底：基础环境完成但 U 盘当时未就绪，热插后自动补装
cat > /etc/hotplug.d/block/99-usb-extras << 'EOF'
#!/bin/sh
[ "$ACTION" = "add" ]           || exit 0
[ -f /etc/install-usb-done ]    && exit 0
[ -f /etc/install-extras-done ] || exit 0

# 等待挂载点就绪（最长 30 秒）
MP=""
for i in $(seq 1 15); do
    for mp in /mnt/sda1 /mnt/sda /mnt/sdb1 /mnt/sdb /mnt/usb /mnt/mmcblk0p1; do
        mountpoint -q "$mp" 2>/dev/null && { MP="$mp"; break 2; }
    done
    sleep 2
done

if [ -z "$MP" ]; then
    logger -t "hotplug" "⚠️  U 盘插入但挂载点未就绪，跳过"
    exit 1
fi

logger -t "hotplug" "💾 U 盘已挂载: $MP，触发重型应用部署"
